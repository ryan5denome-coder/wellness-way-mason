# Cloudflare Pages _redirects — TWW Mason Wix → Astro migration
# Format: <from> <to> <status>
# Order matters — first match wins.

# Apex → www (canonical) is handled by a Cloudflare dashboard Redirect Rule, NOT
# here. Workers Static Assets _redirects rejects absolute/host-based URLs
# ("Only relative URLs are allowed"), so a host-match rule cannot live in this
# file. Canonical tags already point to www everywhere (Google dedupes), and both
# apex + www are attached as Custom Domains serving identical content.

# Decap CMS — production builds emit /admin (no trailing slash) due to
# build.format: 'file'. Redirect /admin/ → /admin for users who type the slash.
/admin/ /admin 301

# Path canonicalization (Phase 2 architecture decisions)
/services /our-services 301
/our-blog /blog 301
/event-list /events 301
/blog/categories/monday-meal-inspiration /blog 301

# Cosmetic service stubs — content removed entirely (Phase 1 finding)
/service-page/permanent-eyeliner /our-services 301
/service-page/lip-blushing /our-services 301
/service-page/brows-microblading /our-services 301
/service-page/scalp-micropigmentation /our-services 301
/service-page/beauty-marks-and-freckles /our-services 301
/service-page/scar-camouflage /our-services 301

# Wix-generated sitemaps (now superseded by /sitemap-index.xml)
/blog-categories-sitemap.xml /sitemap-index.xml 301
/booking-services-sitemap.xml /sitemap-index.xml 301
/blog-posts-sitemap.xml /sitemap-index.xml 301
/pages-sitemap.xml /sitemap-index.xml 301
/event-pages-sitemap.xml /sitemap-index.xml 301

# Conventional /sitemap.xml probe — Astro emits /sitemap-index.xml, but Semrush,
# Bing, and many auditors hit /sitemap.xml first by convention. 200-status alias
# so both resolve to the same content (302 would also work; using 200 means the
# file content is served directly rather than a follow-the-redirect step).
/sitemap.xml /sitemap-index.xml 200

# Post slug renames (preserve any inbound Wix-era equity)
/post/statins-and-heart-health-a-wellness-way-perspective-on-cholesterol-risk-and-root-causes /post/statins-and-heart-health-a-wellness-way-perspective-on-cholesterol-and-cardiovascular-risk 301
