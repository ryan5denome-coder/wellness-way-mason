---
import { Image } from 'astro:assets';
import BaseLayout from '../layouts/BaseLayout.astro';
import SectionContainer from '../components/SectionContainer.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';
import Button from '../components/Button.astro';
import FAQAccordion from '../components/FAQAccordion.astro';
import { clinic } from '../lib/site';
import labShelfReach from '../assets/clinic/lab-shelf-reach.jpg';

const approachFaqs = [
  {
    question: 'What is the Wellness Way Approach?',
    answer: '<p>A whole-person approach that asks <em>why</em> your body is doing what it\'s doing, not just what to manage on the surface. We use in-depth lab testing, chiropractic care, and personalized nutrition and lifestyle guidance to address the patterns underneath your health challenges.</p>',
  },
  {
    question: 'What are the 3 T\'s?',
    answer: '<p>Traumas, Toxins, and Thoughts. Three categories of stress that interact with everything from your hormones to your nervous system to your immune response. Investigation begins with assessing all three because the drivers of inflammation vary from person to person.</p>',
  },
  {
    question: 'How do you decide what tests to run?',
    answer: '<p>Based on your story, current symptoms, history, and goals. Testing is recommended (never required), and we walk through the cost and rationale before ordering anything. You stay in control of what gets tested.</p>',
  },
  {
    question: 'How long does health restoration usually take?',
    answer: '<p>It depends on what we\'re addressing. Acute pain may resolve in weeks. Chronic patterns and complex cases (autoimmune, hormone, gut) typically take three to six months of consistent care before meaningful change shows up. We build a Health Restoration Plan with realistic timelines and check in regularly.</p>',
  },
  {
    question: 'Will I have to stop my current medications?',
    answer: '<p>No, and we never advise stopping medications. Your prescribing physician makes those decisions. Our role is to help you understand the systems beneath your symptoms so you and your medical team can make better-informed choices over time. We work alongside conventional care, not in place of it.</p>',
  },
];

const threeTs = [
  {
    title: 'Traumas',
    short: 'Physical stress, stored in the structure.',
    body: "Car accidents you walked away from. Nine hours a day of desk posture. The labor job that built your shoulders and wore down your low back. Years of compensation change how your frame loads and moves, and that can interfere with how clearly your nervous system communicates. A thorough exam maps where old stress still lives, and specific adjustments may help restore better movement and clearer signaling.",
    image: '/images/homepage/traumas.jpg',
    alt: 'Woman doing a gentle stretch on a wooden floor, body-aware recovery and physical resilience',
  },
  {
    title: 'Toxins',
    short: 'Chemical stress, riding in quietly.',
    body: "It arrives in food, water, air, cookware, and the products on your skin, and your liver, gut, and hormones have to process all of it. When the load outpaces your capacity, symptoms can surface far from the source. Targeted lab work can show which exposures may be taxing your system, so reducing them becomes a plan instead of a guess.",
    image: '/images/homepage/toxins.jpg',
    alt: 'Hands rinsing fresh carrots under water, clean food prep representing reduced toxic load',
  },
  {
    title: 'Thoughts',
    short: 'Emotional stress, written into physiology.',
    body: "A nervous system stuck in fight-or-flight shifts cortisol, digestion, sleep, and hormone signaling all at once. That's physiology, not weakness, and it is not all in your head. We look at the stress patterns your body is still running, because a plan that ignores them is a plan that works against itself.",
    image: '/images/homepage/thoughts.jpg',
    alt: 'Open journal on a wooden table in soft morning light, calm reflection and mental clarity',
  },
];

const fourSteps = [
  {
    n: 1,
    title: 'A New Perspective',
    body: "Your first visit is a conversation, not a conveyor belt. You talk, we listen: what you've tried, what you've been told, and what you want your health to let you do again. If the drive to Mason is a barrier, virtual appointments are available for health restoration care.",
  },
  {
    n: 2,
    title: 'We Test',
    body: "Advanced functional lab work paired with detailed intake tools, chosen for your case rather than pulled from a template. The goal is to surface what may be driving your symptoms, including patterns a standard panel was never designed to catch.",
  },
  {
    n: 3,
    title: 'We Discover',
    body: "When results are in, we walk through them together in plain English: what's happening, why it may be happening, and what your body needs to start moving in a better direction. That conversation becomes your Health Restoration Plan.",
  },
  {
    n: 4,
    title: 'We Guide',
    body: "A plan only matters if you can live it. Hands-on chiropractic care, nutrition guidance, a supplement care plan, and lifestyle support, adjusted as your body responds. You're never handed a PDF and left to figure it out alone.",
  },
];
---

<BaseLayout
  title="Our Approach: Chiropractic + Health Restoration"
  description="The Wellness Way - Mason's approach: test, don't guess. Chiropractic care alongside in-depth lab testing to find what's actually driving your symptoms. Mason, OH."
>
  <!-- Section 1: Hero — pays off the homepage "See our approach" click -->
  <SectionContainer width="default" spacing="md" background="paper-soft">
    <Breadcrumbs trail={[{ label: 'Home', href: '/' }, { label: 'Our Approach' }]} />
    <div class="approach-hero" data-reveal>
      <div class="approach-hero-text">
        <h1>
          <span class="page-kicker">Our Approach: Chiropractic &amp; Health Restoration in Mason, OH</span>
          Told you're fine? We ask a different question.
        </h1>
        <p class="lede">
          Being dismissed is not the same as being well. When symptoms keep returning, the useful
          question is not how to quiet them but why they started. Here is how we ask it: three
          stressors, four steps, real testing.
        </p>
      </div>
      <div class="approach-hero-image">
        <Image
          src={labShelfReach}
          alt="Reaching for a functional lab kit on the shelf at The Wellness Way - Mason"
          widths={[400, 600, 800, 1200]}
          sizes="(min-width: 768px) 45vw, 100vw"
          loading="eager"
          fetchpriority="high"
          quality={82}
        />
      </div>
    </div>
  </SectionContainer>

  <!-- Section 2: The thesis — one level deeper than the homepage hook -->
  <SectionContainer width="prose" spacing="lg">
    <div class="intro">
      <p data-reveal>
        If you've spent years collecting referrals and reassurances, you know the script. Fifteen
        minutes, a standard panel, and a conclusion that doesn't match how you actually feel:
        "everything looks fine."
      </p>
      <p class="intro-turn" data-reveal="up-sm">
        We start from a different premise. Common is not normal.
      </p>
      <p data-reveal="up-sm">
        Running on empty, reacting to foods you've eaten your whole life, hurting in ways no scan
        has explained: all of that is common, and none of it is normal. Those symptoms are signals
        worth investigating, not noise to be managed.
      </p>
      <p data-reveal="up-sm">
        So instead of matching each complaint to something that quiets it, we ask what your body is
        responding to. Physical stress. Chemical stress. Emotional stress. We test for the pattern,
        explain it in plain English, and build a plan around what we find, working alongside your
        physician rather than in place of them. Patients come to us from Mason, West Chester,
        Loveland, and across greater Cincinnati for exactly this kind of second look.
      </p>
    </div>
  </SectionContainer>

  <!-- Section 3: The 3 T's — the framework, deeper than the homepage version -->
  <SectionContainer width="default" spacing="xl" background="paper-soft">
    <div class="section-head">
      <p class="eyebrow">The Wellness Way Approach</p>
      <h2>The Three T's</h2>
      <p class="section-lede">
        Nearly every stubborn health challenge involves inflammation, and inflammation always has
        drivers. They differ from person to person, so the investigation starts in the same three
        places every time.
      </p>
    </div>
    <div class="three-ts">
      {threeTs.map((t) => (
        <article class="t-card" data-reveal="up-sm">
          <img src={t.image} alt={t.alt} loading="lazy" />
          <div class="t-body">
            <h3>{t.title}</h3>
            <p class="t-short">{t.short}</p>
            <p>{t.body}</p>
          </div>
        </article>
      ))}
    </div>
    <p class="three-ts-close" data-reveal="up-sm">
      Address one T and ignore the other two, and the pattern usually finds its way back.
      We look at all three from the first visit.
    </p>
  </SectionContainer>

  <!-- Section 4: Testing philosophy — how panels get chosen, on the patient's terms -->
  <SectionContainer width="prose" spacing="lg" background="paper-warm-tint">
    <div class="testing-head" data-reveal>
      <h2>How we decide what to test</h2>
      <p class="value-line">Test, don't guess. Your story picks the panels, not a template.</p>
    </div>
    <div class="testing-body">
      <p data-reveal="up-sm">
        You wouldn't pay a mechanic to replace parts at random until the noise stopped. Your body
        deserves at least that much diligence. Testing exists so your plan is built on
        measurements instead of hunches.
      </p>
      <p data-reveal="up-sm">
        Based on your history, symptoms, and goals, Dr. DeNome recommends specific functional
        panels: hormones, thyroid, gut health, food sensitivities, toxic burden. Testing is
        recommended, never required, and you hear the cost and the reasoning behind every panel
        before anything is ordered. Labs are billed separately and transparently, so there are no
        mystery invoices.
      </p>
      <p data-reveal="up-sm">
        And when results come back, you don't get a portal upload and a shrug. We sit down
        together and translate the numbers: what they suggest, what they rule out, and what
        happens next.
      </p>
    </div>
  </SectionContainer>

  <!-- Section 5: The 4-Step Process — timeline that fills as you scroll -->
  <SectionContainer width="default" spacing="xl">
    <div class="section-head">
      <h2>The 4-Step Process</h2>
      <p class="section-lede">
        Whether you come in for an adjustment or for answers, the arc is the same. Here is the
        whole process, so you always know where you are in it.
      </p>
    </div>
    <ol class="steps">
      {fourSteps.map((s) => (
        <li>
          <div class="step-num">{s.n}</div>
          <div class="step-body">
            <h3>{s.title}</h3>
            <p>{s.body}</p>
          </div>
        </li>
      ))}
    </ol>
  </SectionContainer>

  <!-- Section 6: FAQ -->
  <SectionContainer width="default" spacing="lg" background="paper-soft">
    <div class="section-head">
      <h2>Common questions</h2>
    </div>
    <FAQAccordion items={approachFaqs} />
  </SectionContainer>

  <!-- Section 7: Conversion moment -->
  <SectionContainer width="narrow" spacing="lg">
    <div class="cta-block" data-reveal>
      <h2>Ready to ask a different question?</h2>
      <p>
        Your first visit is a flat $99, and you leave with a clear next step, whichever direction
        you choose. Bring your history, your old labs, and every question you've been saving.
      </p>
      <div class="cta-row">
        <Button href={`tel:${clinic.phoneTel}`} variant="ghost" size="lg">Call {clinic.phone}</Button>
        <Button href={clinic.bookingUrl} variant="primary" size="lg" external iconAfter>
          Book Your Appointment
        </Button>
      </div>
    </div>
  </SectionContainer>
</BaseLayout>

<style>
  /* === Hero === */
  .approach-hero {
    display: grid;
    gap: 2.5rem;
    align-items: center;
  }
  .approach-hero h1 {
    margin: 0;
    font-size: var(--text-4xl);
    line-height: 1.1;
  }
  /* SEO keyword string stays inside the H1 as a kicker line; the display
     line underneath carries the visual headline. */
  .page-kicker {
    display: block;
    font-family: var(--font-body);
    font-size: var(--text-xs);
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--color-mute);
    font-weight: 500;
    margin: 0 0 1rem;
  }
  .lede {
    color: var(--color-ink-muted);
    max-width: 58ch;
    font-size: var(--text-lg);
    margin: 1.25rem 0 0;
    line-height: 1.6;
  }
  .approach-hero-image img {
    width: 100%;
    aspect-ratio: 4 / 3;
    object-fit: cover;
    border-radius: var(--radius-xl);
    box-shadow: var(--shadow-card);
  }
  @media (min-width: 768px) {
    .approach-hero { grid-template-columns: 1.2fr 1fr; gap: 3.5rem; }
    .approach-hero h1 { font-size: var(--text-5xl); }
  }

  /* === Section heads (centered, established scale) === */
  .section-head {
    margin-bottom: 3.5rem;
    text-align: center;
    max-width: 60ch;
    margin-left: auto;
    margin-right: auto;
  }
  .eyebrow {
    font-size: var(--text-xs);
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--color-mute);
    margin: 0 0 1rem;
    font-weight: 500;
  }
  /* Eyebrow lockup: short TWW Green rule turns the caps label into a
     composed unit (auto-centered under centered heads). */
  .section-head .eyebrow::after {
    content: "";
    display: block;
    width: 32px;
    height: 2px;
    background: var(--color-brand-primary);
    margin: 0.9rem auto 0;
  }
  .section-head h2 {
    margin: 0 0 1.25rem;
    font-size: var(--text-3xl);
    color: var(--color-ink-strong);
  }
  .section-lede {
    color: var(--color-ink-muted);
    font-size: var(--text-lg);
    margin: 0;
    line-height: 1.6;
  }

  /* === Intro prose === */
  .intro p {
    color: var(--color-ink);
    font-size: var(--text-lg);
    line-height: 1.7;
    margin: 0 0 1.25rem;
  }
  .intro p:last-child { margin-bottom: 0; }
  .intro-turn {
    font-family: var(--font-display);
    color: var(--color-ink-strong) !important;
    font-size: var(--text-xl) !important;
    line-height: 1.5;
  }

  /* === Three T's cards === */
  .three-ts {
    display: grid;
    gap: 1.5rem;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
  }
  .t-card {
    background: var(--color-paper);
    border: 1px solid var(--color-line);
    border-radius: var(--radius-lg);
    overflow: hidden;
    box-shadow: var(--shadow-card);
    transition:
      transform var(--duration-normal) var(--ease-soft),
      box-shadow var(--duration-normal) var(--ease-soft);
  }
  .t-card:hover {
    transform: translateY(-4px);
    box-shadow: var(--shadow-card-hover);
  }
  .t-card img {
    width: 100%;
    aspect-ratio: 3 / 2;
    object-fit: cover;
  }
  .t-body { padding: 1.75rem; }
  .t-body h3 {
    margin: 0 0 0.35rem;
    font-size: var(--text-2xl);
    color: var(--color-ink-strong);
  }
  .t-short {
    font-family: var(--font-display);
    font-style: italic;
    color: var(--color-brand-primary-dark);
    font-size: var(--text-base);
    margin: 0 0 0.85rem;
  }
  .t-body p:last-child {
    color: var(--color-ink-muted);
    margin: 0;
    line-height: 1.65;
  }
  .three-ts-close {
    text-align: center;
    margin: 2.75rem auto 0;
    max-width: 56ch;
    color: var(--color-ink-strong);
    font-size: var(--text-lg);
    font-style: italic;
    font-family: var(--font-display);
  }

  /* === Testing philosophy === */
  .testing-head { margin-bottom: 1.75rem; }
  .testing-head h2 {
    margin: 0;
    font-size: var(--text-3xl);
    color: var(--color-ink-strong);
  }
  .value-line {
    font-family: var(--font-display);
    font-style: italic;
    color: var(--color-brand-primary-dark);
    font-size: var(--text-lg);
    line-height: 1.5;
    margin: 1rem 0 0;
    max-width: 52ch;
  }
  .testing-body p {
    color: var(--color-ink);
    font-size: var(--text-lg);
    line-height: 1.7;
    margin: 0 0 1.25rem;
  }
  .testing-body p:last-child { margin-bottom: 0; }

  /* === 4-step process — vertical timeline with scroll-fill === */
  .steps {
    list-style: none;
    padding: 0;
    margin: 0 auto;
    max-width: 56rem;
    position: relative;
  }
  .steps li {
    display: grid;
    grid-template-columns: 4rem 1fr;
    gap: 1.5rem;
    padding-bottom: 2.5rem;
    position: relative;
  }
  .steps li:not(:last-child)::before {
    content: "";
    position: absolute;
    left: 1.5rem;
    top: 3.5rem;
    bottom: 0;
    width: 2px;
    background: var(--color-line);
  }
  /* Green overlay line draws downward as each step reveals — the timeline
     "completes" itself while you scroll, enacting the 4-step narrative. */
  .steps li:not(:last-child)::after {
    content: "";
    position: absolute;
    left: 1.5rem;
    top: 3.5rem;
    bottom: 0;
    width: 2px;
    background: var(--color-brand-primary);
    transform: scaleY(0);
    transform-origin: top center;
    transition: transform 700ms var(--ease-soft) 200ms;
  }
  .steps li:global(.is-visible):not(:last-child)::after {
    transform: scaleY(1);
  }
  .step-num {
    width: 3rem;
    height: 3rem;
    border-radius: 50%;
    background: var(--color-paper);
    border: 2px solid var(--color-brand-primary);
    color: var(--color-brand-primary-dark);
    font-family: var(--font-display);
    font-weight: 500;
    font-size: var(--text-xl);
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    z-index: 1;
    transition: background 400ms var(--ease-soft) 200ms;
  }
  .steps li:global(.is-visible) .step-num {
    background: var(--color-brand-primary-soft);
  }
  .step-body { padding-top: 0.4rem; }
  .step-body h3 {
    margin: 0 0 0.5rem;
    font-size: var(--text-xl);
    color: var(--color-ink-strong);
  }
  .step-body p {
    margin: 0;
    color: var(--color-ink-muted);
    line-height: 1.65;
  }

  /* === Final CTA === */
  .cta-block { text-align: center; }
  .cta-block h2 {
    margin: 0 0 1rem;
    font-size: var(--text-3xl);
  }
  .cta-block p {
    color: var(--color-ink-muted);
    max-width: 50ch;
    margin: 0 auto 2rem;
    line-height: 1.65;
  }
  .cta-row {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
    justify-content: center;
  }

  /* === Responsive scale (established section-head rhythm) === */
  @media (min-width: 768px) {
    .section-head h2 { font-size: var(--text-4xl); }
    .testing-head h2 { font-size: var(--text-4xl); }
    .cta-block h2 { font-size: var(--text-4xl); }
    .steps li { grid-template-columns: 5rem 1fr; gap: 2rem; }
    .step-num { width: 3.5rem; height: 3.5rem; font-size: var(--text-2xl); }
    .steps li:not(:last-child)::before,
    .steps li:not(:last-child)::after { left: 1.75rem; top: 4rem; }
  }
  @media (min-width: 1024px) {
    .section-head { margin-bottom: 4rem; }
    .section-head h2 {
      font-size: var(--text-5xl);
      letter-spacing: -0.022em;
    }
  }
</style>
