---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import SectionContainer from '../components/SectionContainer.astro';
import BlogPostCard from '../components/BlogPostCard.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';
import NewsletterSignup from '../components/NewsletterSignup.astro';
import NewsletterTeaser from '../components/NewsletterTeaser.astro';
import { clinic } from '../lib/site';

const posts = (await getCollection('posts')).sort((a, b) => {
  const da = a.data.date?.getTime() ?? 0;
  const db = b.data.date?.getTime() ?? 0;
  return db - da;
});

// All categories present in the corpus
const allCategories = Array.from(
  new Set(posts.flatMap((p) => p.data.categories ?? []))
).sort();

// Upcoming community events — surfaced on /blog so engaged readers see live
// gatherings, AND so event pages get a second inbound internal link (Semrush fix).
const now = new Date();
const upcomingEvents = (await getCollection('events'))
  .filter((e) => {
    const end = e.data.endDate ?? e.data.date;
    return e.data.recurring || !end || end >= now;
  })
  .sort((a, b) => (a.data.date?.getTime() ?? 0) - (b.data.date?.getTime() ?? 0))
  .slice(0, 3);
---

<BaseLayout
  title="Health & Wellness Blog | Chiropractor in Mason, OH"
  description="Articles on chiropractic care, hormones, gut health, thyroid, and the test-don't-guess approach, from Dr. Ryan DeNome at The Wellness Way - Mason."
>
  <SectionContainer width="default" spacing="md" background="paper-soft">
    <Breadcrumbs trail={[{ label: 'Home', href: '/' }, { label: 'Blog' }]} />
    <div class="blog-hero" data-reveal>
      <h1>
        <span class="page-kicker">Health &amp; Wellness Blog</span>
        Real answers, written to be understood.
      </h1>
      <p class="lede">
        Thyroid, hormones, gut health, nutrition, and the questions patients actually
        ask, answered in plain English by Dr. Ryan DeNome, DC and the team
        at {clinic.brandName}.
      </p>
    </div>
  </SectionContainer>

  <SectionContainer width="default" spacing="sm">
    <div data-reveal="up-sm">
      <NewsletterTeaser />
    </div>
  </SectionContainer>

  <SectionContainer width="default" spacing="md">
    <div class="blog-head" data-reveal>
      <p class="eyebrow eyebrow-lockup">Latest from the clinic</p>
      <h2>Articles &amp; Recipes</h2>
      <p class="head-lede">
        Short reads on the patterns we see in the clinic, plus a few recipes worth
        keeping. Pick the topic that sounds like your week.
      </p>
    </div>
    {allCategories.length > 0 && (
      <div class="category-filter" role="navigation" aria-label="Filter by category" data-reveal="up-sm">
        <span class="filter-label">Topics:</span>
        {allCategories.map((cat) => (
          <a href={`#${cat}`} class="cat-link">{cat.replace(/-/g, ' ')}</a>
        ))}
      </div>
    )}
    <div class="post-grid">
      {posts.map((post) => (
        <BlogPostCard
          title={post.data.title}
          excerpt={post.data.excerpt ?? ''}
          href={`/post/${post.id}`}
          image={post.data.image}
          imageAlt={post.data.imageAlt ?? post.data.title}
          date={post.data.date}
          author={post.data.author}
          category={post.data.categories[0]?.replace(/-/g, ' ')}
          readTime={post.data.readTime}
        />
      ))}
    </div>
  </SectionContainer>

  {upcomingEvents.length > 0 && (
    <SectionContainer width="default" spacing="md">
      <div class="events-strip" data-reveal>
        <h2>Join us in person.</h2>
        <p class="events-intro">Community gatherings at {clinic.brandName}. Free, open to all. Bring a friend.</p>
        <ul class="events-list">
          {upcomingEvents.map((evt) => (
            <li>
              <a href={`/event-details/${evt.id}`}>
                <strong>{evt.data.title}</strong>
                {evt.data.excerpt && <span>{evt.data.excerpt}</span>}
              </a>
            </li>
          ))}
        </ul>
        <p class="events-more"><a href="/events">See all events &rarr;</a></p>
      </div>
    </SectionContainer>
  )}

  <SectionContainer width="default" spacing="lg" background="paper-soft">
    <div data-reveal="up-sm">
      <NewsletterSignup />
    </div>
  </SectionContainer>
</BaseLayout>

<style>
  .blog-hero { padding-top: 1.5rem; }
  .blog-hero h1 { font-size: var(--text-4xl); margin: 0 0 1rem; line-height: 1.1; }
  /* SEO keyword string stays inside the H1 as a kicker line; the display
     line underneath carries the visual headline. */
  .page-kicker {
    display: block;
    font-family: var(--font-body);
    font-size: var(--text-xs);
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--color-mute);
    font-weight: 500;
    margin: 0 0 1rem;
  }
  .blog-head {
    max-width: 70ch;
    margin: 0 0 1.75rem;
  }
  .blog-head .eyebrow {
    font-size: var(--text-xs);
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--color-mute);
    font-weight: 500;
    margin: 0 0 1rem;
  }
  /* Eyebrow lockup: short TWW Green rule turns the caps label into a
     composed unit (left-aligned head, so no auto-centering). */
  .eyebrow-lockup::after {
    content: "";
    display: block;
    width: 32px;
    height: 2px;
    background: var(--color-brand-primary);
    margin: 0.9rem 0 0;
  }
  .blog-head h2 {
    margin: 0 0 1rem;
    font-size: var(--text-3xl);
    line-height: 1.15;
    color: var(--color-ink-strong);
  }
  .head-lede {
    color: var(--color-ink-muted);
    font-size: var(--text-lg);
    line-height: 1.6;
    margin: 0;
    max-width: 58ch;
  }
  @media (min-width: 768px) {
    .blog-head h2 { font-size: var(--text-4xl); }
  }
  @media (min-width: 1024px) {
    .blog-head h2 { font-size: var(--text-5xl); letter-spacing: -0.022em; }
  }
  .lede { color: var(--color-ink-muted); max-width: 60ch; font-size: var(--text-lg); line-height: 1.6; }
  .category-filter {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    align-items: center;
    margin-bottom: 2rem;
    font-size: var(--text-sm);
  }
  .filter-label { color: var(--color-mute); margin-right: 0.5rem; }
  .cat-link {
    background: var(--color-paper-soft);
    color: var(--color-ink);
    padding: 0.35rem 0.85rem;
    border-radius: var(--radius-pill);
    text-decoration: none;
    text-transform: capitalize;
    transition: background var(--duration-fast) var(--ease-soft);
  }
  .cat-link:hover {
    background: var(--color-brand-primary-light);
  }
  .post-grid {
    display: grid;
    gap: 1.5rem;
    grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
  }
  .events-strip h2 {
    font-size: var(--text-3xl);
    margin: 0 0 0.75rem;
    color: var(--color-ink-strong);
  }
  .events-intro {
    color: var(--color-ink-muted);
    margin: 0 0 1.5rem;
  }
  .events-list {
    list-style: none;
    padding: 0;
    display: grid;
    gap: 1rem;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
  }
  .events-list a {
    display: block;
    padding: 1rem 1.25rem;
    border: 1px solid var(--color-line);
    border-radius: var(--radius-md);
    text-decoration: none;
    color: inherit;
    transition: background 0.15s ease, border-color 0.15s ease;
    height: 100%;
  }
  .events-list a:hover {
    background: var(--color-paper-warm-tint);
    border-color: var(--color-brand-primary);
  }
  .events-list strong {
    color: var(--color-brand-primary-dark);
    display: block;
    margin-bottom: 0.4rem;
  }
  .events-list span {
    font-size: var(--text-sm);
    color: var(--color-ink-muted);
    line-height: 1.5;
  }
  .events-more {
    margin-top: 1.25rem;
    font-size: var(--text-sm);
  }
  .events-more a {
    color: var(--color-brand-primary-dark);
    text-decoration: none;
    font-weight: 500;
  }
  .events-more a:hover { text-decoration: underline; }
  @media (min-width: 768px) {
    .blog-hero h1 { font-size: var(--text-5xl); }
    .events-strip h2 { font-size: var(--text-4xl); }
  }
</style>
