---
import { Image } from 'astro:assets';
import BaseLayout from '../layouts/BaseLayout.astro';
import SectionContainer from '../components/SectionContainer.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';
import Button from '../components/Button.astro';
import FAQAccordion from '../components/FAQAccordion.astro';
import { clinic, owner, site } from '../lib/site';
import pediatricPlayRoom from '../assets/clinic/pediatric-play-room.jpg';

const aboutFaqs = [
  {
    question: 'What kind of patients does The Wellness Way Mason treat?',
    answer: '<p>Adults, children, and prenatal patients across Mason and the greater Cincinnati area. Most patients have already been to multiple providers and been told their labs are "normal" while still not feeling well. Common patterns include fatigue, hormone imbalance, gut issues, autoimmune presentations, thyroid dysfunction, and complex cases that haven\'t responded to standard care.</p>',
  },
  {
    question: 'Where is the clinic located?',
    answer: `<p>5382 Cox-Smith Rd, Suite A, in Mason, Ohio. We serve patients from Mason, West Chester, Loveland, Lebanon, and the greater Cincinnati area. Virtual health-restoration consultations are also available for patients outside the immediate area.</p>`,
  },
  {
    question: 'Who is Dr. Ryan DeNome, DC?',
    answer: '<p>Dr. Ryan DeNome, DC is the clinic owner and chiropractic physician at The Wellness Way Mason. He is a graduate of Life University in Marietta, Georgia, a Cincinnati native, and certified in the Webster Technique for prenatal chiropractic care. His clinical focus is supporting men with health challenges, mothers juggling stress and wellness, and complex cases that haven\'t found answers in conventional care.</p>',
  },
  {
    question: 'What makes The Wellness Way Mason different from other chiropractors?',
    answer: '<p>We integrate chiropractic care with comprehensive health-restoration lab work — looking at the patterns underneath symptoms instead of just managing what shows up on the surface. We test before we guess. We work alongside your existing medical team, not in place of them.</p>',
  },
  {
    question: 'Do you accept new patients?',
    answer: '<p>Yes. The fastest way to schedule a new patient consultation is through our online booking. Both in-person (at our Mason clinic) and virtual health-restoration consultations are available.</p>',
  },
];

const personSchema = {
  '@context': 'https://schema.org',
  '@type': 'Person',
  '@id': `${site.url}/#owner`,
  name: owner.name,
  givenName: owner.givenName,
  familyName: owner.familyName,
  honorificPrefix: owner.honorificPrefix,
  honorificSuffix: owner.credentials,
  jobTitle: owner.jobTitle,
  alumniOf: { '@type': 'CollegeOrUniversity', name: owner.alumniOf },
  worksFor: { '@type': 'Organization', name: clinic.brandName, url: site.url },
  email: owner.email,
  url: owner.url,
};
---

<BaseLayout
  title="About Us"
  description="Meet Dr. Ryan DeNome, DC and the team at The Wellness Way Mason. We're driven by a mission to rethink healthcare and challenge the status quo."
  jsonLd={[personSchema]}
>
  <SectionContainer width="default" spacing="md" background="paper-soft">
    <Breadcrumbs trail={[{ label: 'Home', href: '/' }, { label: 'About' }]} />
    <h1>About Us</h1>
    <p class="lede">
      We are a network of health restoration clinics that think and act differently to solve
      the health challenges others can't.
    </p>
  </SectionContainer>

  <SectionContainer width="default" spacing="lg">
    <div class="values">
      <div class="value">
        <h3>Mission</h3>
        <p>Our philosophy is founded on the idea that the human body was not designed for illness, and when properly cared for, can use its innate ability to heal to restore itself.</p>
      </div>
      <div class="value">
        <h3>Philosophy</h3>
        <p>We are a health champion for all and a community for change — committed to disrupting the standard approach to care so that everyone can achieve the total wellness they deserve.</p>
      </div>
      <div class="value">
        <h3>Vision</h3>
        <p>A world where common is not normal — where people don't accept dismissal, mediocrity, or medication management as the only path to feeling well. We stand in the gap and make sure no stone goes unturned to get to the bottom of your health challenges.</p>
      </div>
    </div>
  </SectionContainer>

  <SectionContainer width="default" spacing="lg" background="paper-soft">
    <div class="our-space">
      <div class="our-space-image">
        <Image
          src={pediatricPlayRoom}
          alt="Family-friendly pediatric play room with green tree bookshelf at The Wellness Way - Mason"
          widths={[400, 600, 800, 1000]}
          sizes="(min-width: 768px) 45vw, 100vw"
          loading="lazy"
          quality={82}
        />
      </div>
      <div class="our-space-text">
        <p class="eyebrow">Our space</p>
        <h2>A clinic built for real families.</h2>
        <p>
          From newborns to grandparents, our Mason office is designed for the people who walk
          through our doors every day. A pediatric play space, prenatal-comfortable adjusting tables,
          calm natural lighting, and a team that knows your kids by name.
        </p>
      </div>
    </div>
  </SectionContainer>

  <SectionContainer width="prose" spacing="lg">
    <h2>Who We Are</h2>
    <p>
      At The Wellness Way, we believe health is not just the absence of disease — it's the presence
      of true vitality. As part of a nationwide network of clinics, we are driven by a mission to
      rethink healthcare and challenge the status quo. Our clinic is dedicated to uncovering the
      underlying drivers of health issues through in-depth testing, personalized care plans, and a
      health restoration approach that sets us apart from traditional healthcare.
    </p>
    <p>
      Led by our passion for helping others live their healthiest lives, we empower individuals
      with the knowledge, tools, and support they need to take control of their well-being.
      Whether you're dealing with chronic symptoms, hormone imbalances, immune challenges, or
      just want to feel your best, our team is here to walk alongside you.
    </p>
    <p>
      <a href="https://www.thewellnessway.com/" target="_blank" rel="noopener">Read more about The Wellness Way →</a>
    </p>
  </SectionContainer>

  <SectionContainer width="default" spacing="lg" id="meet-dr-ryan">
    <div class="provider-grid">
      <div class="provider-photo">
        <img
          src="https://static.wixstatic.com/media/629639_7c1b1385059c4c7897a2e529fd5d567f~mv2.jpg"
          alt="Dr. Ryan DeNome, DC at The Wellness Way - Mason"
          loading="lazy"
        />
      </div>
      <div class="provider-bio">
        <p class="eyebrow">Meet Your Chiropractor</p>
        <h2>Dr. Ryan DeNome, DC</h2>
        <p class="bio-title">{owner.jobTitle} | Clinic Owner</p>
        <p>
          Dr. Ryan DeNome is the clinic owner and chiropractic physician at {clinic.brandName}.
          He is passionate about helping patients overcome health challenges and reclaim their vitality.
          His journey into chiropractic began when his wife introduced him to the profession, and he
          immediately recognized the perfect blend of hands-on problem-solving and patient care.
        </p>
        <p>
          He pursued his Doctor of Chiropractic degree at <strong>Life University</strong> in Marietta, Georgia,
          where he discovered The Wellness Way Student Club during his first week. For nearly four years,
          he immersed himself in The Wellness Way philosophy — preparing to serve patients beyond
          conventional chiropractic care.
        </p>
        <p>
          Dr. Ryan is especially passionate about supporting <strong>men who feel limited by health challenges</strong>,
          and <strong>moms juggling the stress of home life and wellness struggles</strong>. His goal is to offer
          hope to those who feel stuck — providing comprehensive care that addresses the underlying
          drivers of symptoms instead of just managing them.
        </p>
        <p>
          Certified in the <strong>Webster Technique</strong>, he is dedicated to caring for pregnant mothers,
          weekend warriors, CrossFit competitors, gym-trained athletes, and the everyday blue-collar
          athlete moving through life — anyone who wants to optimize their health and performance.
        </p>
        <p>
          Outside of the clinic, Dr. Ryan enjoys spending time outdoors with his wife and son — hiking,
          kayaking, or simply soaking in the beauty of nature. A lifelong adventurer, he and his wife
          biked 100 miles on their second date.
        </p>
        <blockquote class="ryan-quote">
          "Take care of your body as if you were going to live forever; and take care of your soul as
          if you were going to die tomorrow."
          <cite>— Saint Augustine of Hippo</cite>
        </blockquote>
        <p>
          Dr. Ryan is honored to bring The Wellness Way approach to his community, helping patients
          achieve lasting health and a better quality of life.
        </p>
        <div class="provider-links">
          <a href={owner.url} target="_blank" rel="noopener">LinkedIn →</a>
          <a href={`mailto:${owner.email}`}>Email →</a>
        </div>
      </div>
    </div>
  </SectionContainer>

  <SectionContainer width="default" spacing="lg">
    <div class="section-head">
      <p class="eyebrow">Common questions</p>
      <h2>About The Wellness Way Mason</h2>
    </div>
    <FAQAccordion items={aboutFaqs} />
  </SectionContainer>

  <SectionContainer width="narrow" spacing="lg" background="paper-soft">
    <div class="cta-block">
      <h2>Schedule with Dr. Ryan</h2>
      <p>New patients welcome. Virtual consultations available.</p>
      <Button href={clinic.bookingUrl} variant="primary" size="lg" external>Book Appointment</Button>
    </div>
  </SectionContainer>
</BaseLayout>

<style>
  .lede { color: var(--color-ink-muted); max-width: 60ch; font-size: var(--text-lg); margin: 1rem 0 0; }
  .our-space {
    display: grid;
    gap: 2.5rem;
    align-items: center;
  }
  .our-space-image img {
    width: 100%;
    aspect-ratio: 4 / 5;
    object-fit: cover;
    border-radius: var(--radius-xl);
    box-shadow: var(--shadow-card);
  }
  .our-space-text .eyebrow {
    font-size: var(--text-xs);
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--color-mute);
    margin: 0 0 1rem;
    font-weight: 500;
  }
  .our-space-text h2 {
    margin: 0 0 1.25rem;
    font-size: var(--text-3xl);
  }
  .our-space-text p {
    color: var(--color-ink-muted);
    line-height: 1.7;
    font-size: var(--text-lg);
    margin: 0;
  }
  @media (min-width: 768px) {
    .our-space { grid-template-columns: 1fr 1.2fr; gap: 4rem; }
    .our-space-text h2 { font-size: var(--text-4xl); }
  }
  .values {
    display: grid;
    gap: 2rem;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
  }
  .value h3 {
    color: var(--color-brand-primary-dark);
    font-size: var(--text-xl);
    margin: 0 0 0.75rem;
  }
  .value p {
    color: var(--color-ink-muted);
    line-height: 1.7;
    margin: 0;
  }
  .provider-grid {
    display: grid;
    gap: 2.5rem;
  }
  .provider-photo img {
    width: 100%;
    border-radius: var(--radius-lg);
    box-shadow: var(--shadow-card);
    object-fit: cover;
    aspect-ratio: 4 / 5;
  }
  .eyebrow {
    font-size: var(--text-xs);
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--color-mute);
    margin: 0 0 0.5rem;
  }
  .provider-bio h2 { margin: 0 0 0.5rem; font-size: var(--text-3xl); }
  .bio-title {
    font-family: var(--font-display);
    font-style: italic;
    color: var(--color-brand-primary-dark);
    font-size: var(--text-lg);
    margin: 0 0 1.5rem;
  }
  .provider-bio p {
    color: var(--color-ink);
    line-height: 1.7;
    margin: 0 0 1rem;
  }
  .ryan-quote {
    background: var(--color-paper-soft);
    border-left: 4px solid var(--color-brand-primary);
    padding: 1.25rem 1.5rem;
    margin: 1.5rem 0;
    font-family: var(--font-display);
    font-style: italic;
    color: var(--color-ink);
    border-radius: 0 var(--radius-md) var(--radius-md) 0;
  }
  .ryan-quote cite {
    display: block;
    margin-top: 0.5rem;
    font-size: var(--text-sm);
    color: var(--color-ink-muted);
    font-style: normal;
  }
  .provider-links {
    display: flex;
    gap: 1.5rem;
    margin-top: 1.5rem;
  }
  .section-head {
    text-align: center;
    max-width: 60ch;
    margin: 0 auto 2.5rem;
  }
  .section-head .eyebrow {
    font-size: var(--text-xs);
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--color-mute);
    margin: 0 0 0.75rem;
    font-weight: 500;
  }
  .section-head h2 { margin: 0 0 1rem; font-size: var(--text-3xl); }

  .cta-block { text-align: center; }
  .cta-block h2 { margin: 0 0 0.75rem; }
  .cta-block p { color: var(--color-ink-muted); margin: 0 0 1.5rem; }

  @media (min-width: 768px) {
    .provider-grid { grid-template-columns: 0.8fr 1.4fr; gap: 3rem; align-items: start; }
  }
</style>
