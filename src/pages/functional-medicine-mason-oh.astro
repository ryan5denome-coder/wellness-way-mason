---
import BaseLayout from '../layouts/BaseLayout.astro';
import SectionContainer from '../components/SectionContainer.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';
import Button from '../components/Button.astro';
import { clinic, site, bylines } from '../lib/site';

// --- FAQ source of truth — used for both visible content and FAQPage schema ---
const faqs = [
  {
    q: "What is functional medicine, and how is it different from regular medicine?",
    a: "Regular medicine is built to identify a disease and match it with a drug or procedure, and that works well when you're in a crisis. Functional health asks a different question: what's loading stress onto your body, and why is it showing up this way? A standard panel measures a handful of markers. A functional panel measures dozens, including ones that may pick up a pattern earlier. Care can then address the input, not just the alarm.",
  },
  {
    q: "Is functional medicine in Mason, OH covered by insurance?",
    a: "We're a cash-pay practice. Most functional lab panels and the consultations around them are not billable to commercial insurance the way a standard sick visit is. The upside: pricing is transparent, your visit isn't squeezed into a short slot, and HSA/FSA cards are accepted. We'll walk through cost before any panel is ordered.",
  },
  {
    q: "Do I have to stop seeing my regular doctor?",
    a: "No, and we'd rather you didn't. We work alongside your primary care provider and any specialists you're already seeing. Functional testing fills in the picture standard labs miss. Your PCP still manages medications, referrals, and acute care. We're additive, not replacement.",
  },
  {
    q: "What labs do you actually run?",
    a: "The most common ones: the DUTCH panel for hormones (sex hormones, adrenal hormones, and how the body is clearing them), a complete thyroid panel including TPO and TgAb antibodies, a comprehensive stool analysis for gut function, a cardiometabolic panel that goes deeper than a basic lipid screen, and food sensitivity testing when symptoms point that direction. We choose based on what your story is telling us, not a one-size plan.",
  },
  {
    q: "How long until I feel a difference?",
    a: "Honest answer: it depends on what's driving the pattern and how long it's been there. Patients with a recent gut flare or a clearly modifiable hormone pattern may notice changes within a few weeks. Long-standing autoimmune or thyroid patterns take longer. The body often needs time to rebuild what got depleted. We map out an expected timeline at your results visit, after we've seen the lab work, not before.",
  },
  {
    q: "Do you treat children?",
    a: "Yes. We see kids for chiropractic care from infancy through teens, and we run age-appropriate functional panels when symptoms warrant it (recurrent ear infections, eczema, behavioral patterns tied to gut function). Pediatric adjustments are gentle (about the pressure you'd use to test the ripeness of a tomato) and we don't run blood work on a child without a specific reason to.",
  },
  {
    q: "I'm pregnant. Is this safe?",
    a: "Dr. DeNome is Webster Technique certified, which is the chiropractic adjustment protocol developed specifically for pregnant patients. Functional testing during pregnancy is more conservative: most hormone panels aren't useful during pregnancy itself, but thyroid and basic nutrient status can be valuable. We coordinate with your OB or midwife to make sure care stays inside what's appropriate for you and the baby.",
  },
  {
    q: "What's the first visit like?",
    a: "We sit down and you tell us what's been going on. Not the 7-minute version. The actual story. We review any labs you've had recently, we listen for the patterns, and we talk about whether functional testing makes sense for you. If it does, we walk you through which panels we'd recommend and what each one costs. You leave with a plan. No pressure to commit before you've slept on it.",
  },
];

const pageUrl = `${site.url}/functional-medicine-mason-oh`;

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqs.map((f) => ({
    '@type': 'Question',
    name: f.q,
    acceptedAnswer: { '@type': 'Answer', text: f.a },
  })),
};

// Note: an earlier version of this file emitted a MedicalBusiness schema block
// here with provider + availableService properties. Removed 2026-05-19 because:
// (a) MedicalBusiness extends LocalBusiness and requires address — Semrush
//     flagged "value for the address field is required";
// (b) The page already gets a full LocalBusiness block (with address, geo,
//     openingHours, sameAs) emitted by BaseLayout on every page; this was a
//     duplicate that conflicted with the canonical entity.
// FAQPage + BreadcrumbList + the BaseLayout-emitted LocalBusiness + Person
// give Google all the structured data signal it needs for this URL.

const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: site.url },
    { '@type': 'ListItem', position: 2, name: 'Functional Medicine in Mason, OH', item: pageUrl },
  ],
};
---

<BaseLayout
  title="Functional Medicine in Mason, OH"
  description="Functional health testing and chiropractic care in Mason, OH. Dr. Ryan DeNome, DC pairs DUTCH, comprehensive thyroid, and gut testing with chiropractic. We test, we don't guess."
  jsonLd={[faqSchema, breadcrumbSchema]}
>
  <SectionContainer width="default" spacing="md" background="paper-soft">
    <Breadcrumbs trail={[
      { label: 'Home', href: '/' },
      { label: 'Functional Medicine in Mason, OH' },
    ]} />
    <div class="hero">
      <h1>
        <span class="page-kicker">Functional Medicine in Mason, OH</span>
        Deeper testing for the symptoms nobody has explained.
      </h1>
      <p class="lede">
        You've been told your labs look normal, and you still don't feel like yourself.
        You're not imagining it. Functional testing looks at markers the standard panel
        usually leaves out, and it runs alongside the care you already have.
      </p>
      <div class="hero-cta">
        <Button href={clinic.bookingUrl} variant="primary" size="lg" external iconAfter>
          Book Your Appointment
        </Button>
        <Button href={`tel:${clinic.phoneTel}`} variant="ghost" size="lg">
          Call {clinic.phone}
        </Button>
      </div>
    </div>
  </SectionContainer>

  <SectionContainer width="prose" spacing="md">
    <p>
      Functional health starts from a different question than conventional medicine asks.
      Conventional care is excellent at identifying disease and matching it with a treatment,
      and you should absolutely keep your primary care provider in the loop. We work alongside
      conventional care, not in place of it. But if you've had blood work pulled at three
      different offices, heard "everything looks fine" every time, and you still feel like
      something is off, your body is raising a signal the standard panel wasn't built to catch.
    </p>
    <p data-reveal="up-sm">
      That's the gap functional testing fills. Different markers. Deeper resolution. A picture
      instead of a snapshot.
    </p>
    <p>
      At <strong>The Wellness Way - Mason</strong>, Dr. Ryan DeNome, Doctor of Chiropractic,
      pairs <a href="/our-services#chiropractic">chiropractic care</a> with comprehensive
      functional lab panels through our
      <a href="/our-services#health-restoration">health restoration arm</a>. We're cash-pay,
      transparent on pricing, and we don't order a test we can't explain to you. Patients drive
      from Mason, West Chester, Loveland, Lebanon, and the greater Cincinnati area, and a few
      from further out when their own neighborhood doesn't have what they're looking for.
    </p>

    <h2 data-reveal>What "normal" labs don't tell you</h2>
    <p>
      Lab ranges are built on population averages, and the population they're built on includes
      a lot of people who are tired, gaining weight, and not sleeping well. "Normal" can mean
      average for that population, not optimal for you.
    </p>
    <p>
      A TSH of 3.5 lands inside the standard range and gets called normal. But your thyroid
      may be working overtime to hold that number, and you may be paying for it in energy,
      hair, mood, and weight. A single estrogen level pulled on day 21 of a cycle and called
      balanced is a little like checking your car's fuel gauge at one moment in the day and
      deciding the entire fuel system works. The DUTCH panel maps the whole cycle and shows
      the metabolites (the breakdown products that reflect how your body is using and clearing
      estrogen). That's often where a pattern hides: not in production, but in clearance
      and conversion.
    </p>
    <p>
      None of that is a criticism of your doctor. Standard care is built to move quickly
      because it has to be. We're built for the conversation that doesn't fit inside a
      short visit.
    </p>

    <h2 data-reveal>How we work: the process</h2>
    <p>
      We use The Wellness Way's four-step process: <strong>New Perspective → We Test → We
      Discover → We Guide</strong>. In practice, that looks like four phases:
    </p>
    <ol data-reveal="up-sm">
      <li>
        <strong>New patient visit.</strong> You tell us the story. The actual story, not the
        rushed version. It's a flat $99, covering the intake conversation and a review of any
        labs you've had run elsewhere, while we listen for the patterns the standard workup
        wasn't looking for.
      </li>
      <li>
        <strong>Testing plan.</strong> If functional testing makes sense for you, we recommend
        a specific panel set (usually two or three labs that map together) and we walk through
        what each one costs before we order anything. Typical first-day lab spend lands between
        $300 and $700, depending on what we're looking at.
      </li>
      <li>
        <strong>Results review.</strong> At your Plan / Discovery visit ($300), we sit down
        with the actual lab reports, side by side with your history, and name what's loading
        stress on your system. The Wellness Way framework is the 3 T's: Traumas (physical),
        Toxins (chemical), Thoughts (emotional). One or two of those is usually doing most
        of the work.
      </li>
      <li>
        <strong>Care plan + follow-through.</strong> Chiropractic adjustments where the nervous
        system may need support. Targeted nutrition, supplementation, and lifestyle changes
        where the lab findings point. Retesting at the right interval so we can see whether
        the plan is doing its job, and adjust it if it isn't.
      </li>
    </ol>

    <h2 data-reveal>What we see most</h2>
    <p>
      Some patterns show up over and over in our practice. The body keeps the same
      conversations going, even when the surface symptoms look different from person to person.
    </p>
    <ul data-reveal="up-sm">
      <li>
        <a href="/conditions/thyroid"><strong>Thyroid patterns.</strong></a> Cold,
        tired, hair loss, weight that won't move, "normal TSH but I don't feel normal."
      </li>
      <li>
        <a href="/conditions/hormone-imbalance"><strong>Hormone imbalance.</strong></a> PMS
        that took over the second half of the cycle, perimenopause showing up early,
        anxiety that tracks with cycle phase.
      </li>
      <li>
        <a href="/conditions/autoimmune"><strong>Autoimmune patterns.</strong></a> Hashimoto's,
        rheumatoid, and the long stretch where labs look a little off but nothing has
        a name yet.
      </li>
      <li>
        <a href="/conditions/digestive-issues"><strong>Digestive issues.</strong></a> Bloating,
        reflux, IBS, the patient who has tried every elimination diet and still
        doesn't know what's driving it.
      </li>
      <li>
        <a href="/conditions/fatigue"><strong>Chronic fatigue.</strong></a> Not
        sleepy. Tired. The kind that doesn't fix with a nap.
      </li>
      <li>
        <a href="/conditions/heart-disease"><strong>Cardiometabolic risk.</strong></a> Cholesterol
        that came back "borderline" and left you with more questions than answers.
        Advanced lipid and inflammation markers can fill in the rest of that picture.
      </li>
      <li>
        <a href="/conditions/mental-health-brain"><strong>Brain fog and mood patterns.</strong></a> The
        nervous-system end of the conversation, where gut function, hormone status, and
        thoughts (the third T) all converge.
      </li>
      <li>
        <a href="/conditions/joint-and-muscle-pain"><strong>Joint and muscle pain.</strong></a> Chiropractic
        territory, but often with an inflammation or nutrient pattern underneath.
      </li>
    </ul>

    <h2 data-reveal>Labs we run</h2>
    <p>
      We don't run a fixed panel for everyone. We run what fits your story. The ones we order
      most:
    </p>
    <ul data-reveal="up-sm">
      <li>
        <a href="/dutch-test-mason-oh"><strong>DUTCH panel</strong></a> (Dried Urine Test for
        Comprehensive Hormones): sex hormones, adrenal hormones, and the metabolites that show
        how your body is actually using and clearing them. Maps across the cycle, not a single
        timepoint.
      </li>
      <li>
        <strong>Complete thyroid panel with antibodies:</strong> TSH, Free T3, Free T4, Reverse
        T3, TPO, TgAb. The full picture, not just TSH alone.
      </li>
      <li>
        <strong>Comprehensive stool analysis:</strong> gut microbiome composition, digestive
        markers, inflammation markers, evidence of dysbiosis (imbalanced gut flora) or pathogens.
      </li>
      <li>
        <strong>Cardiometabolic panel:</strong> advanced lipid markers including particle size
        and inflammation, fasting insulin, and HbA1c. What a standard lipid panel doesn't show.
      </li>
      <li>
        <strong>Food sensitivity testing:</strong> for when symptoms point toward an immune
        reaction to specific foods. The Immuno Food Allergy Test is the panel we use most.
      </li>
      <li>
        <strong>TWW Basic Panel:</strong> broad foundational labs the parent brand designed
        to capture inflammation, blood sugar, liver and kidney function, and a few markers
        a routine panel usually doesn't include.
      </li>
    </ul>
    <p class="aside-note" data-reveal="up-sm">
      Tests are recommended, never required. We walk through cost and rationale before ordering
      anything. Cash-pay pricing only: most functional panels are not billable to commercial
      insurance, but HSA/FSA cards are accepted. <a href="/pricing">See the full breakdown on
      our pricing page</a>.
    </p>

    <h2 data-reveal>Why a Doctor of Chiropractic pairs with functional testing</h2>
    <p>
      Most patients searching for functional medicine in Mason are weighing two structures:
      lab work without hands-on care for the spine and nervous system, or hands-on care
      without the lab work. The Wellness Way model is the integrated version. Adjustments may
      support the parts of the nervous system that help regulate digestion, immune response,
      and hormone signaling, and functional labs can show what's happening downstream. The two
      are designed to work together. You can see how both arms of the practice fit together
      on <a href="/our-services">our services page</a>.
    </p>
    <p>
      Dr. DeNome's training is as a Doctor of Chiropractic (chiropractic physician), and his
      certification as a Webster Technique provider gives him a specific protocol for prenatal
      care. The functional-testing layer comes through The Wellness Way's nationwide network,
      so the panels and the interpretation are consistent with how the parent brand runs care
      across the country.
    </p>

    <h2 data-reveal>Pricing, insurance, and what to expect</h2>
    <p>
      We're a cash-pay practice, and that's a deliberate choice. Insurance dictates visit
      length, what gets covered, and what doesn't. Cash-pay means we can structure visits
      around what the patient actually needs, run the labs that fit the picture, and charge
      transparently without surprise bills three months later. <strong>HSA and FSA cards are
      accepted</strong> for both visits and most lab panels.
    </p>
    <p>
      The numbers: your <strong>new patient visit is a flat $99</strong>, which covers the
      intake conversation and a review of any labs you already have. Follow-up adjustments
      are $50, with soft tissue work, cupping, and scraping included at no upcharge. Labs are
      billed separately and transparently, quoted before anything is ordered; for a patient
      with no recent prior testing, first-day lab spend usually lands between $300 and $700.
      The Plan / Discovery visit, where we walk through your results and build the care plan,
      is $300.
    </p>
    <p>
      What you should never see from us: a bill you weren't expecting, a panel ordered without
      consent, or a recommendation we can't explain in plain language. <a href="/pricing">Full
      transparent pricing is on the pricing page</a>.
    </p>

    <h2 data-reveal>Frequently asked questions</h2>
    <div class="faq-list" data-reveal="up-sm">
      {faqs.map((f) => (
        <details class="faq-item">
          <summary>{f.q}</summary>
          <p>{f.a}</p>
        </details>
      ))}
    </div>

    <h2 data-reveal>You don't have to pick a side</h2>
    <p>
      You don't have to feel guilty for not feeling well. You don't have to settle for "your
      labs look fine." And you don't have to choose between conventional medicine and a
      different conversation. You can have both running at the same time.
    </p>
    <p>
      <strong>Common is not normal. Normal doesn't always mean optimal. You have options.</strong>
    </p>
    <p class="byline">{bylines.reviewed} · Doctor of Chiropractic, The Wellness Way - Mason, Mason, Ohio</p>
  </SectionContainer>

  <SectionContainer width="prose" spacing="lg" background="paper-soft">
    <div class="closer-cta" data-reveal>
      <h2>Your first visit is a flat $99.</h2>
      <p class="value-line">One transparent price. Labs quoted before anything is ordered.</p>
      <p>
        We'll listen to the whole story, look at what's already been run, and tell you
        honestly whether functional testing makes sense for what you're dealing with.
        If it doesn't, we'll say so.
      </p>
      <div class="cta-row">
        <Button href={clinic.bookingUrl} variant="primary" size="lg" external iconAfter>
          Book Your Appointment
        </Button>
        <Button href={`tel:${clinic.phoneTel}`} variant="ghost" size="lg">
          Call {clinic.phone}
        </Button>
      </div>
    </div>
  </SectionContainer>
</BaseLayout>

<style>
  /* SEO keyword string stays inside the H1 as a kicker line; the display
     line underneath carries the visual headline. (Pattern from our-services.) */
  .page-kicker {
    display: block;
    font-family: var(--font-body);
    font-size: var(--text-xs);
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--color-mute);
    font-weight: 500;
    margin: 0 0 1rem;
  }
  .hero h1 {
    font-size: var(--text-4xl);
    line-height: 1.1;
    margin: 0 0 1rem;
    max-width: 22ch;
  }
  .lede {
    color: var(--color-ink-muted);
    font-size: var(--text-lg);
    line-height: 1.6;
    max-width: 64ch;
    margin: 0 0 1.75rem;
  }
  .hero-cta {
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
  }

  /* Article section heads — established scale, ink-strong not green. */
  h2 {
    color: var(--color-ink-strong);
    font-size: var(--text-3xl);
    line-height: 1.15;
    margin-top: 3rem;
    margin-bottom: 1.25rem;
  }
  p { line-height: 1.75; }
  ul, ol { line-height: 1.75; padding-left: 1.5rem; }
  li { margin: 0.5rem 0; }
  .aside-note {
    background: var(--color-paper-warm-tint);
    border-left: 3px solid var(--color-brand-primary);
    padding: 0.75rem 1.25rem;
    border-radius: 0.4rem;
    font-size: var(--text-sm);
    color: var(--color-ink-muted);
  }
  .faq-list {
    display: grid;
    gap: 0.5rem;
    margin: 1.5rem 0;
  }
  .faq-item {
    border: 1px solid var(--color-line);
    border-radius: var(--radius-md);
    padding: 1rem 1.25rem;
    background: var(--color-paper);
  }
  .faq-item summary {
    font-family: var(--font-display);
    font-weight: 600;
    color: var(--color-ink-strong);
    cursor: pointer;
    list-style: none;
  }
  .faq-item summary::-webkit-details-marker { display: none; }
  .faq-item summary::after {
    content: '+';
    float: right;
    font-size: 1.25rem;
    color: var(--color-brand-primary-dark);
    line-height: 1;
  }
  .faq-item[open] summary::after { content: '−'; }
  .faq-item p {
    margin: 0.75rem 0 0;
    color: var(--color-ink-muted);
    line-height: 1.7;
  }
  .byline {
    margin-top: 2rem;
    padding-top: 1rem;
    border-top: 1px solid var(--color-line);
    font-size: var(--text-sm);
    color: var(--color-ink-muted);
    font-style: italic;
  }

  /* Closer — the page's one conversion moment. */
  .closer-cta { text-align: center; }
  .closer-cta h2 { margin-top: 0; margin-bottom: 0.75rem; }
  /* Value-line pattern from our-services: italic Lora proof line. */
  .value-line {
    font-family: var(--font-display);
    font-style: italic;
    color: var(--color-brand-primary-dark);
    font-size: var(--text-lg);
    line-height: 1.5;
    margin: 0 auto 1.25rem;
    max-width: 52ch;
  }
  .closer-cta p:not(.value-line) {
    max-width: 50ch;
    margin: 0 auto 1.75rem;
    color: var(--color-ink-muted);
  }
  .cta-row {
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
    justify-content: center;
  }

  @media (min-width: 768px) {
    .hero h1 { font-size: var(--text-5xl); }
    h2 { font-size: var(--text-4xl); }
  }
  @media (min-width: 1024px) {
    h2 { letter-spacing: -0.022em; }
    .closer-cta h2 { font-size: var(--text-5xl); }
  }
</style>
