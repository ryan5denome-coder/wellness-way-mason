---
import { getCollection, render } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import SectionContainer from '../../components/SectionContainer.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import Button from '../../components/Button.astro';
import { clinic, site, bylines } from '../../lib/site';
import { articleSchema } from '../../lib/schema';

export async function getStaticPaths() {
  const posts = await getCollection('posts');
  return posts.map((post) => ({
    params: { slug: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);

// Article schema with shared Person @id and LocalBusiness @id.
const schema = articleSchema({
  title: post.data.title,
  description: post.data.excerpt ?? post.data.seoDescription ?? '',
  image: post.data.image ? new URL(post.data.image, site.url).toString() : undefined,
  datePublished: post.data.date?.toISOString(),
  dateModified: post.data.date?.toISOString(),
  url: new URL(`/post/${post.id}`, site.url).toString(),
});

const dateStr = post.data.date
  ? post.data.date.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })
  : '';
---

<BaseLayout
  title={post.data.seoTitle ?? post.data.title}
  description={post.data.seoDescription ?? post.data.excerpt ?? clinic.tagline}
  ogImage={post.data.ogImage ?? post.data.image}
  jsonLd={[schema]}
>
  <SectionContainer width="prose" spacing="md" background="paper-soft">
    <Breadcrumbs trail={[{ label: 'Home', href: '/' }, { label: 'Blog', href: '/blog' }, { label: post.data.title }]} />
  </SectionContainer>

  <article>
    <SectionContainer width="prose" spacing="md">
      <header class="post-header">
        {post.data.categories.length > 0 && (
          <p class="post-categories">
            {post.data.categories.map((c) => <span class="cat-pill">{c.replace(/-/g, ' ')}</span>)}
          </p>
        )}
        <h1>{post.data.title}</h1>
        <div class="post-meta">
          <span>{post.data.author}</span>
          {dateStr && <span class="meta-sep">·</span>}
          {dateStr && <span>{dateStr}</span>}
          {post.data.readTime && <span class="meta-sep">·</span>}
          {post.data.readTime && <span>{post.data.readTime}</span>}
        </div>
      </header>
    </SectionContainer>

    {post.data.image && (
      <SectionContainer width="default" spacing="sm" background="paper">
        <img
          src={post.data.image}
          alt={post.data.imageAlt ?? post.data.title}
          class="post-hero-image"
          loading="eager"
          decoding="async"
        />
      </SectionContainer>
    )}

    <SectionContainer width="prose" spacing="md">
      <div class="post-body">
        <Content />
      </div>
      <p class="post-byline">{bylines.reviewed}</p>
    </SectionContainer>
  </article>

  <SectionContainer width="prose" spacing="lg" background="paper-soft">
    <div class="post-cta">
      <h2>Ready to Take the Next Step?</h2>
      <p>Comprehensive testing, personalized care, and an approach that asks <em>why</em> instead of just chasing symptoms.</p>
      <Button href={clinic.bookingUrl} variant="primary" size="lg" external>Book a Consultation</Button>
    </div>
  </SectionContainer>
</BaseLayout>

<style>
  .post-header {
    text-align: left;
  }
  .post-categories {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin: 0 0 1rem;
  }
  .cat-pill {
    background: var(--color-brand-primary-light);
    color: var(--color-ink-strong);
    padding: 0.2rem 0.75rem;
    border-radius: var(--radius-pill);
    font-size: var(--text-xs);
    font-weight: 500;
    text-transform: capitalize;
  }
  .post-header h1 {
    font-size: var(--text-4xl);
    line-height: 1.15;
    margin: 0 0 1rem;
  }
  .post-meta {
    color: var(--color-ink-muted);
    font-size: var(--text-sm);
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    align-items: center;
  }
  .meta-sep { color: var(--color-line); }
  .post-hero-image {
    width: 100%;
    max-height: 480px;
    object-fit: cover;
    border-radius: var(--radius-lg);
    box-shadow: var(--shadow-card);
  }
  .post-body :global(h2) {
    margin-top: 2.5rem;
    font-size: var(--text-2xl);
  }
  .post-body :global(h3) {
    margin-top: 2rem;
    font-size: var(--text-xl);
  }
  .post-body :global(p) {
    margin: 1rem 0;
    line-height: 1.7;
  }
  .post-body :global(img) {
    border-radius: var(--radius-md);
    margin: 1.5rem 0;
  }
  .post-body :global(ul), .post-body :global(ol) {
    line-height: 1.7;
    padding-left: 1.5rem;
  }
  .post-body :global(li) {
    margin: 0.5rem 0;
  }
  .post-body :global(blockquote) {
    border-left: 4px solid var(--color-brand-primary);
    padding: 0.5rem 0 0.5rem 1.25rem;
    margin: 1.5rem 0;
    color: var(--color-ink-muted);
    font-style: italic;
  }
  .post-body :global(strong) { color: var(--color-ink-strong); }
  .post-byline {
    margin-top: 3rem;
    padding-top: 1.5rem;
    border-top: 1px solid var(--color-line);
    font-size: var(--text-sm);
    color: var(--color-ink-muted);
    font-style: italic;
  }
  .post-cta {
    text-align: center;
  }
  .post-cta h2 {
    font-size: var(--text-3xl);
    margin: 0 0 1rem;
  }
  .post-cta p {
    max-width: 50ch;
    margin: 0 auto 2rem;
    color: var(--color-ink-muted);
  }
  @media (min-width: 768px) {
    .post-header h1 { font-size: var(--text-5xl); }
  }
</style>
