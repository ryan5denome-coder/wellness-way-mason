---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import SectionContainer from '../components/SectionContainer.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';
import Button from '../components/Button.astro';
import { clinic, bylines } from '../lib/site';

const conditions = (await getCollection('conditions')).sort(
  (a, b) => a.data.order - b.data.order
);

const featured = conditions.filter((c) => c.data.featured);
const standard = conditions.filter((c) => !c.data.featured);
---

<BaseLayout
  title="Find Your Condition: Thyroid, Gut, Hormones"
  description="Thyroid, hormones, autoimmune, gut health, fatigue and more — the patterns we see most at The Wellness Way - Mason. Test, don't guess. Mason, OH."
>
  <SectionContainer width="default" spacing="md" background="paper-soft">
    <Breadcrumbs trail={[{ label: 'Home', href: '/' }, { label: 'Find My Condition' }]} />
    <h1>Find My Condition</h1>
    <p class="lede">
      If you've been told your labs are "normal" but you don't feel normal — you're not alone.
    </p>
  </SectionContainer>

  <SectionContainer width="prose" spacing="md">
    <p>
      Most of the people who walk through our doors in Mason have already been to two, three, or four
      other providers across the Cincinnati area. They've been handed a prescription, told to manage
      stress, or sent home with the words <em>"everything looks fine."</em> But something is still off.
    </p>
    <p>
      At <strong>{clinic.brandName}</strong>, we don't accept "common" as the same thing as "normal."
      <em>Common is not normal.</em> We ask <em>why</em> your body is doing what it's doing.
      <strong>We don't guess — we test.</strong>
    </p>
    <p>
      Below are the patterns we see most at our Mason, OH clinic. Each links to a deeper page with the
      testing approach, the 3 T's framework that applies, and how a Health Restoration Plan may help.
      We serve patients across Mason, West Chester, Loveland, Lebanon, and the greater Cincinnati area.
    </p>
    <div class="hero-cta">
      <Button href={clinic.bookingUrl} variant="primary" size="lg" external>Schedule a Consultation</Button>
      <Button href="/our-services" variant="ghost" size="lg">See Our Services</Button>
    </div>
  </SectionContainer>

  {featured.length > 0 && (
    <SectionContainer width="default" spacing="lg" background="paper-soft">
      <p class="eyebrow">The patterns we see most</p>
      <h2>Featured Conditions</h2>
      <div class="condition-grid featured-grid">
        {featured.map((c) => (
          <article class="condition-card featured">
            <a href={`/conditions/${c.id}`} class="card-link">
              {c.data.image && (
                <img
                  src={c.data.image}
                  alt={c.data.imageAlt}
                  class="card-image"
                  loading="lazy"
                  width="800"
                  height="500"
                />
              )}
              <div class="card-body">
                <h3>{c.data.title.replace(' — What Most Doctors Miss', '').replace(' in Mason, OH', '')}</h3>
                <p>{c.data.excerpt}</p>
                <span class="card-cta">Learn more →</span>
              </div>
            </a>
          </article>
        ))}
      </div>
    </SectionContainer>
  )}

  <SectionContainer width="default" spacing="lg">
    <h2>All Conditions We See</h2>
    <div class="condition-grid standard-grid">
      {standard.map((c) => (
        <article class="condition-card">
          <a href={`/conditions/${c.id}`} class="card-link">
            <div class="card-body">
              <h3>{c.data.title.replace(' — What Most Doctors Miss', '').replace(' in Mason, OH', '')}</h3>
              <p>{c.data.excerpt}</p>
              <span class="card-cta">Learn more →</span>
            </div>
          </a>
        </article>
      ))}
    </div>
  </SectionContainer>

  <SectionContainer width="prose" spacing="lg" background="paper-soft">
    <h2>Take the First Step Toward Better Health</h2>
    <p>
      If you've recognized yourself in even one of these descriptions — your body is talking. The
      question is whether anyone has been listening.
    </p>
    <p>
      We do health differently. We don't guess — we test. We work alongside the physicians on your
      care team, not in place of them. And we believe, because we see it daily in our Mason clinic,
      that the body was designed to heal when the right inputs are in place.
    </p>
    <p>
      <strong>Schedule a discovery consultation. Bring your story. Bring your questions. Bring whatever labs and history you have.</strong>
    </p>
    <p>We'll listen. We'll test. We'll build a plan with you.</p>
    <div class="hero-cta">
      <Button href={clinic.bookingUrl} variant="primary" size="lg" external>Schedule Your Consultation</Button>
    </div>
    <p class="byline">{bylines.reviewed} — Doctor of Chiropractic, {clinic.brandName}</p>
  </SectionContainer>
</BaseLayout>

<style>
  .lede {
    color: var(--color-brand-primary-dark);
    font-style: italic;
    font-family: var(--font-display);
    font-size: var(--text-2xl);
    margin: 1rem 0 0;
  }
  .eyebrow {
    color: var(--color-brand-primary-dark);
    font-family: var(--font-display);
    font-size: var(--text-sm);
    letter-spacing: 0.1em;
    text-transform: uppercase;
    margin: 0 0 0.5rem;
  }
  .hero-cta {
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
    margin-top: 1.5rem;
  }
  .condition-grid {
    display: grid;
    gap: 1.5rem;
  }
  .featured-grid {
    grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
  }
  .standard-grid {
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
  }
  .condition-card {
    border: 1px solid var(--color-line);
    border-radius: 0.6rem;
    overflow: hidden;
    background: var(--color-paper);
    transition: transform 0.18s ease, box-shadow 0.18s ease;
  }
  .condition-card:hover {
    transform: translateY(-2px);
    box-shadow: 0 8px 22px -10px rgba(0, 0, 0, 0.15);
  }
  .card-link {
    display: block;
    text-decoration: none;
    color: inherit;
  }
  .card-image {
    width: 100%;
    height: 180px;
    object-fit: cover;
    display: block;
  }
  .card-body {
    padding: 1.25rem;
  }
  .card-body h3 {
    color: var(--color-brand-primary-dark);
    margin: 0 0 0.5rem;
    font-size: var(--text-lg);
  }
  .card-body p {
    line-height: 1.6;
    color: var(--color-ink-muted);
    margin: 0 0 0.75rem;
  }
  .card-cta {
    color: var(--color-brand-primary-dark);
    font-weight: 600;
    font-size: var(--text-sm);
  }
  .byline {
    margin-top: 2rem;
    padding-top: 1rem;
    border-top: 1px solid var(--color-line);
    font-size: var(--text-sm);
    color: var(--color-ink-muted);
    font-style: italic;
  }
</style>
