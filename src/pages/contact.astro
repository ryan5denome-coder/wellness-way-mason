---
import BaseLayout from '../layouts/BaseLayout.astro';
import SectionContainer from '../components/SectionContainer.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';
import Button from '../components/Button.astro';
import HoursTable from '../components/HoursTable.astro';
import MapEmbed from '../components/MapEmbed.astro';
import ContactForm from '../components/ContactForm.astro';
import FAQAccordion from '../components/FAQAccordion.astro';
import { clinic } from '../lib/site';

const wasSent = Astro.url.searchParams.get('sent') === 'true';

const contactFaqs = [
  {
    question: 'Do you accept insurance?',
    answer: '<p>We are a cash-pay practice — that decision keeps us free to spend the time, run the testing, and recommend the care your situation actually calls for, instead of what an insurance code allows. We can provide a superbill on request that you may submit to your insurance for out-of-network reimbursement, but we don\'t bill insurance directly. Our pricing is flat and posted publicly on the <a href="/pricing">Pricing page</a>.</p>',
  },
  {
    question: 'Do I need a referral?',
    answer: '<p>No. You can self-refer for chiropractic care or a discovery consultation. If you\'re bringing labs from another provider, please bring them to your visit — we\'d rather build on what already exists than duplicate testing unnecessarily.</p>',
  },
  {
    question: 'What should I bring to my first appointment?',
    answer: '<p>Bring any recent labs, imaging reports, current medications and supplement list, and a brief written history of when symptoms started and what you\'ve already tried. If you\'re a pediatric or pregnant patient, bring relevant prenatal or pediatric records. Comfortable clothing is fine — you don\'t need to change for an exam.</p>',
  },
  {
    question: 'Where do I park?',
    answer: '<p>Free parking is available directly in front of the building at 5382 Cox-Smith Rd, Suite A. The entrance is ground-level and accessible.</p>',
  },
  {
    question: 'How long is a first visit?',
    answer: '<p>Plan on 60–75 minutes for a new patient discovery consultation and exam. Follow-up adjustments and review-of-findings visits are typically 20–30 minutes.</p>',
  },
  {
    question: 'Do you see kids and pregnant moms?',
    answer: '<p>Yes — pediatric chiropractic and prenatal care are core specialties. Dr. Ryan is certified in the Webster Technique for prenatal patients. We see newborns through teens for chiropractic care and have a pediatric-friendly play space at the clinic.</p>',
  },
  {
    question: 'Are virtual consultations available?',
    answer: '<p>Yes — virtual <em>health restoration consultations</em> are available for patients outside the immediate Mason / Cincinnati area. In-person chiropractic care obviously requires being in the clinic.</p>',
  },
];

---

<BaseLayout
  title="Contact Us | Chiropractor in Mason, OH"
  description={`Contact ${clinic.brandName} in Mason, OH. Address, hours, phone, and how to schedule a new patient appointment for chiropractic care or comprehensive testing.`}
>
  <SectionContainer width="default" spacing="md" background="paper-soft">
    <Breadcrumbs trail={[{ label: 'Home', href: '/' }, { label: 'Contact' }]} />
    <h1>Contact Us</h1>
    <p class="lede">
      Whether you're a new patient ready to schedule, or you have a question first — we'd love to hear from you.
    </p>
  </SectionContainer>

  <SectionContainer width="prose" spacing="md">
    <p>
      You don't have to have it all figured out before you reach out. Most of the people who
      contact us are somewhere in the middle of their story — they've had labs run that came back
      "fine," they've been bounced between providers, and they're trying to figure out whether
      what we do is the right next step.
    </p>
    <p>
      That's exactly the conversation we want to have. A short call or message is a no-pressure
      way to ask whether chiropractic care, functional lab testing, or both might fit what
      you're dealing with. We'll tell you honestly if we're not the right fit and where to look
      instead.
    </p>
    <h2>What to expect when you reach out</h2>
    <ul>
      <li>
        <strong>Booking a new patient visit</strong> — the fastest path is the booking button
        below or on our <a href="/our-services">services page</a>. Self-registration takes about
        three minutes and you'll get a confirmation email immediately.
      </li>
      <li>
        <strong>General questions</strong> — call <a href={`tel:${clinic.phoneTel}`}>{clinic.phone}</a>
        during clinic hours or send a message through the form below. We respond to messages
        within one business day, usually faster.
      </li>
      <li>
        <strong>Pricing or insurance questions</strong> — the short version is we're cash-pay,
        HSA/FSA accepted, no insurance billing. Full transparent pricing lives on the
        <a href="/pricing">pricing page</a>.
      </li>
      <li>
        <strong>Already a patient</strong> — for billing, lab orders, or follow-up scheduling,
        call directly during office hours. The clinic line gets answered by a real person, not
        a phone tree.
      </li>
    </ul>
    <h2>How we work alongside your existing care</h2>
    <p>
      Most of our patients keep their primary care provider and any specialists they're seeing.
      What we do sits alongside conventional medicine, not in place of it. Bring your recent labs
      and medication list to your first visit — we'd rather build on what's already been done
      than duplicate testing unnecessarily.
    </p>
    <p>
      Serving patients across <strong>Mason, West Chester, Loveland, Lebanon, Maineville, and the
      greater Cincinnati area</strong>. Free parking on-site and an accessible ground-level
      entrance.
    </p>
  </SectionContainer>

  {wasSent && (
    <SectionContainer width="default" spacing="sm" background="paper">
      <div class="success-banner">
        ✓ Thanks — your message went through. We'll be in touch within one business day.
      </div>
    </SectionContainer>
  )}

  <SectionContainer width="default" spacing="lg" id="book">
    <div class="contact-grid">
      <div class="contact-info">
        <p class="eyebrow">Quick contact</p>

        <div class="info-block">
          <h3>Visit us</h3>
          <address>
            {clinic.address.streetAddress}<br />
            {clinic.address.addressLocality}, {clinic.address.addressRegion} {clinic.address.postalCode}
          </address>
        </div>

        <div class="info-block">
          <h3>Call</h3>
          <p><a href={`tel:${clinic.phoneTel}`}>{clinic.phone}</a></p>
        </div>

        <div class="info-block">
          <h3>Email</h3>
          <p><a href={`mailto:${clinic.email}`}>{clinic.email}</a></p>
        </div>

        <div class="info-block">
          <h3>Book online</h3>
          <p>The fastest way to schedule a new patient visit:</p>
          <Button href={clinic.bookingUrl} variant="primary" size="md" external>Book Appointment</Button>
        </div>

        <div class="info-block">
          <h3>Hours</h3>
          <HoursTable />
        </div>
      </div>

      <div class="contact-form-col">
        <p class="eyebrow">Send us a message</p>
        <p class="form-intro">
          For general questions, scheduling, and connecting. <strong>For new patient intake, please use the
          Book Appointment button</strong> — that flow is set up to take your full history securely.
        </p>
        <ContactForm />
      </div>
    </div>
  </SectionContainer>

  <SectionContainer width="default" spacing="lg" background="paper-soft">
    <h2>Find us</h2>
    <MapEmbed height="450px" />
  </SectionContainer>

  <SectionContainer width="prose" spacing="lg">
    <h2>Frequently Asked Questions</h2>
    <FAQAccordion items={contactFaqs} />
  </SectionContainer>
</BaseLayout>

<style>
  .lede { color: var(--color-ink-muted); max-width: 60ch; font-size: var(--text-lg); margin: 1rem 0 0; }
  .success-banner {
    background: var(--color-brand-primary-light);
    color: var(--color-ink-strong);
    padding: 1rem 1.5rem;
    border-radius: var(--radius-md);
    border-left: 4px solid var(--color-brand-primary);
    font-weight: 500;
  }
  .contact-grid {
    display: grid;
    gap: 3rem;
  }
  .eyebrow {
    font-size: var(--text-xs);
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--color-mute);
    margin: 0 0 1rem;
  }
  .info-block {
    margin-bottom: 1.75rem;
  }
  .info-block h3 {
    font-size: var(--text-base);
    color: var(--color-ink-strong);
    margin: 0 0 0.5rem;
    font-family: var(--font-body);
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
  }
  .info-block address {
    font-style: normal;
    line-height: 1.6;
    color: var(--color-ink);
  }
  .info-block p { margin: 0.5rem 0; }
  .form-intro {
    color: var(--color-ink-muted);
    margin: 0 0 1.5rem;
    line-height: 1.6;
  }

  @media (min-width: 900px) {
    .contact-grid {
      grid-template-columns: 1fr 1.3fr;
      gap: 4rem;
      align-items: start;
    }
  }
</style>
