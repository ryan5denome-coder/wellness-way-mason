---
import { getCollection, render } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import SectionContainer from '../../components/SectionContainer.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import Button from '../../components/Button.astro';
import HoursTable from '../../components/HoursTable.astro';
import { clinic, site, bylines } from '../../lib/site';

export async function getStaticPaths() {
  const locations = await getCollection('locations');
  return locations.map((entry) => ({
    params: { slug: entry.id },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);

// Other locations we serve — cross-link to sibling pages.
// (Semrush "only one internal link" fix, 2026-05-12: each location was only
// linked from /locations index; this adds 3 inbound links per location page.)
const allLocations = await getCollection('locations');
const otherLocations = allLocations
  .filter((loc) => loc.id !== entry.id)
  .sort((a, b) => (a.data.order ?? 99) - (b.data.order ?? 99));

// Place schema (locale). Expanded with the clinic's PostalAddress, GeoCoordinates,
// and containedInPlace (the locale's county/region) so it carries real local-SEO
// signal instead of a name + description stub (Manus audit 1.5 / 1F). The clinic
// address is the same physical location serving every locale page — these pages
// describe the service area, anchored to the one Mason office.
const placeSchema = {
  '@context': 'https://schema.org',
  '@type': 'Place',
  name: `${entry.data.locale}, ${entry.data.state}`,
  description: entry.data.excerpt,
  url: new URL(`/locations/${entry.id}`, site.url).toString(),
  address: {
    '@type': 'PostalAddress',
    streetAddress: clinic.address.streetAddress,
    addressLocality: clinic.address.addressLocality,
    addressRegion: clinic.address.addressRegion,
    postalCode: clinic.address.postalCode,
    addressCountry: clinic.address.addressCountry,
  },
  ...(clinic.geo.latitude && clinic.geo.longitude
    ? {
        geo: {
          '@type': 'GeoCoordinates',
          latitude: clinic.geo.latitude,
          longitude: clinic.geo.longitude,
        },
      }
    : {}),
  containedInPlace: {
    '@type': 'AdministrativeArea',
    name: `${entry.data.locale}, ${entry.data.state}`,
  },
  telephone: clinic.phoneTel,
};
---

<BaseLayout
  title={entry.data.seoTitle ?? entry.data.title}
  description={entry.data.seoDescription ?? entry.data.excerpt}
  ogImage={entry.data.image}
  jsonLd={[placeSchema]}
>
  <SectionContainer width="prose" spacing="md" background="paper-soft">
    <Breadcrumbs
      trail={[
        { label: 'Home', href: '/' },
        { label: 'Locations', href: '/locations' },
        { label: entry.data.locale },
      ]}
    />
  </SectionContainer>

  <article>
    <SectionContainer width="prose" spacing="md">
      <header class="loc-header">
        <p class="eyebrow">Service Area</p>
        <h1>{entry.data.title}</h1>
        <p class="lede">{entry.data.excerpt}</p>
        {entry.data.distanceFromClinic && (
          <p class="distance">
            <strong>{entry.data.drivingTime ?? entry.data.distanceFromClinic}</strong>
            {entry.data.drivingTime && entry.data.distanceFromClinic && (
              <span> · {entry.data.distanceFromClinic}</span>
            )}
          </p>
        )}
      </header>
    </SectionContainer>

    <SectionContainer width="prose" spacing="md">
      <div class="loc-body">
        <Content />
      </div>
      <p class="loc-byline">{bylines.reviewed} — Doctor of Chiropractic, {clinic.brandName}</p>
    </SectionContainer>
  </article>

  {otherLocations.length > 0 && (
    <SectionContainer width="prose" spacing="lg">
      <h2 class="other-loc-heading">Other Communities We Serve</h2>
      <p class="other-loc-intro">
        We see patients from across the greater Cincinnati area. Here are the other communities closest to our Mason office:
      </p>
      <ul class="other-locations">
        {otherLocations.map((loc) => (
          <li>
            <a href={`/locations/${loc.id}`}>
              <strong>{loc.data.locale}, {loc.data.state}</strong>
              {loc.data.drivingTime && <span class="loc-meta">{loc.data.drivingTime}</span>}
              <span class="loc-excerpt">{loc.data.excerpt}</span>
            </a>
          </li>
        ))}
      </ul>
    </SectionContainer>
  )}

  <SectionContainer width="prose" spacing="lg" background="paper-soft">
    <h2>The Wellness Way - Mason</h2>
    <address class="clinic-nap">
      <strong>{clinic.brandName}</strong><br />
      {clinic.addressLine1}<br />
      {clinic.city}, {clinic.state} {clinic.zip}<br />
      <a href={`tel:${clinic.phoneTel}`}>{clinic.phone}</a>
    </address>
    <HoursTable />
    <div class="cta-row">
      <Button href={clinic.bookingUrl} variant="primary" size="lg" external>Schedule a Consultation</Button>
      <Button href={`tel:${clinic.phoneTel}`} variant="ghost" size="lg">Call {clinic.phone}</Button>
    </div>
  </SectionContainer>
</BaseLayout>

<style>
  .eyebrow {
    color: var(--color-brand-primary-dark);
    font-family: var(--font-display);
    font-size: var(--text-sm);
    letter-spacing: 0.1em;
    text-transform: uppercase;
    margin: 0 0 0.5rem;
  }
  .lede {
    color: var(--color-ink-muted);
    font-size: var(--text-lg);
    margin: 1rem 0 0.5rem;
  }
  .distance {
    font-size: var(--text-sm);
    color: var(--color-ink-muted);
    margin: 0;
  }
  .loc-body :global(h2) {
    color: var(--color-brand-primary-dark);
    margin-top: 2.5rem;
  }
  .loc-body :global(p) {
    line-height: 1.7;
  }
  .loc-byline {
    margin-top: 2rem;
    padding-top: 1rem;
    border-top: 1px solid var(--color-line);
    font-size: var(--text-sm);
    color: var(--color-ink-muted);
    font-style: italic;
  }
  .clinic-nap {
    font-style: normal;
    line-height: 1.7;
    margin: 1rem 0;
  }
  .cta-row {
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
    margin-top: 1.5rem;
  }
  .other-loc-heading {
    font-size: var(--text-2xl);
    margin: 0 0 1rem;
    color: var(--color-brand-primary-dark);
  }
  .other-loc-intro {
    color: var(--color-ink-muted);
    margin: 0 0 1.5rem;
  }
  .other-locations {
    list-style: none;
    padding: 0;
    display: grid;
    gap: 1rem;
  }
  .other-locations a {
    display: block;
    padding: 1rem 1.25rem;
    border: 1px solid var(--color-line);
    border-radius: var(--radius-md);
    text-decoration: none;
    color: inherit;
    transition: background 0.15s ease, border-color 0.15s ease;
  }
  .other-locations a:hover {
    background: var(--color-paper-warm-tint);
    border-color: var(--color-brand-primary);
  }
  .other-locations strong {
    color: var(--color-brand-primary-dark);
    display: block;
    margin-bottom: 0.3rem;
  }
  .loc-meta {
    display: block;
    font-size: var(--text-sm);
    color: var(--color-brand-primary-dark);
    margin-bottom: 0.4rem;
    font-weight: 500;
  }
  .loc-excerpt {
    display: block;
    font-size: var(--text-sm);
    color: var(--color-ink-muted);
    line-height: 1.5;
  }
</style>
