---
import { getCollection } from 'astro:content';
import { Image } from 'astro:assets';
import BaseLayout from '../layouts/BaseLayout.astro';
import SectionContainer from '../components/SectionContainer.astro';
import Button from '../components/Button.astro';
import BlogPostCard from '../components/BlogPostCard.astro';
import HoursTable from '../components/HoursTable.astro';
import MapEmbed from '../components/MapEmbed.astro';
import { clinic } from '../lib/site';
import pediatricAdjustment from '../assets/clinic/pediatric-adjustment.jpg';
import adultAdjustment from '../assets/clinic/adult-adjustment.jpg';
import labKitsFlatLay from '../assets/clinic/lab-kits-flat-lay.jpg';
import pediatricPlayRoom from '../assets/clinic/pediatric-play-room.jpg';

const featured = (await getCollection('posts'))
  .sort((a, b) => (b.data.date?.getTime() ?? 0) - (a.data.date?.getTime() ?? 0))
  .slice(0, 3);

// Conditions list — links each item to /find-my-condition with anchor where one
// exists, otherwise the general page. Chiropractic-first ordering for local SEO.
const conditions: { label: string; href: string }[] = [
  { label: 'Back pain', href: '/find-my-condition#joint-and-muscle-pain' },
  { label: 'Neck pain', href: '/find-my-condition#joint-and-muscle-pain' },
  { label: 'Sciatica', href: '/find-my-condition#joint-and-muscle-pain' },
  { label: 'Headaches', href: '/find-my-condition#joint-and-muscle-pain' },
  { label: 'Sports injury & recovery', href: '/our-services#chiropractic' },
  { label: 'Pregnancy & Webster Technique', href: '/our-services#chiropractic' },
  { label: 'Pediatric care', href: '/our-services#chiropractic' },
  { label: 'Hormone imbalance', href: '/find-my-condition#hormone-imbalance' },
  { label: 'Thyroid dysfunction', href: '/find-my-condition#thyroid' },
  { label: 'Digestive issues', href: '/find-my-condition#digestive-issues' },
  { label: 'Autoimmune patterns', href: '/find-my-condition#autoimmune' },
  { label: 'Fatigue & low energy', href: '/find-my-condition#fatigue' },
];

const fourSteps = [
  {
    n: 1,
    title: 'A New Perspective',
    body: "You're a person with a real story, not a chart number. Your first visit is a conversation with a clinician who starts from the premise that you shouldn't have to settle for feeling this way.",
  },
  {
    n: 2,
    title: 'We Test',
    body: "Advanced lab work paired with detailed intake tools to look for what may be driving your symptoms, not just what shows up on the surface.",
  },
  {
    n: 3,
    title: 'We Discover',
    body: "We sit down with you and walk through your results: what's actually happening, why it's happening, and what your body needs to start moving in a different direction. That becomes your individual care plan.",
  },
  {
    n: 4,
    title: 'We Guide',
    body: "Hands-on chiropractic care, targeted nutrition, a supplement care plan, and lifestyle support: built around your physiology and the patterns we found together.",
  },
];

const twoArms = [
  {
    title: 'Chiropractic',
    slogan: 'Do Health Differently.',
    body: 'Manual, specific adjustments for the conditions chiropractors are known for: back pain, neck pain, sciatica, headaches, sports injury, prenatal (Webster Technique), and pediatric care.',
    callout: 'Soft tissue work, cupping, and scraping are included with every adjustment. We don\'t upcharge for adjunctive techniques.',
    cta: { label: 'See chiropractic', href: '/our-services#chiropractic' },
  },
  {
    title: 'Health Restoration',
    slogan: "We don't guess. We test.",
    body: 'Lab testing paired with nutrition guidance, a supplement care plan, and lifestyle support. For patients who are ready to ask why symptoms keep coming back.',
    callout: 'New patient visits are a flat $99. Lab work and supplements are billed separately so you stay in control of what you spend.',
    cta: { label: 'See health restoration', href: '/our-services#health-restoration' },
  },
];

const threeTs = [
  {
    title: 'Traumas',
    short: 'Physical stress your body has absorbed.',
    body: "Old injuries, repetitive strain, the way you sit at your desk. Years of compensation change how your frame loads and moves, and a chiropractic exam with movement assessment can help show where your structure is still working around old stress.",
    image: '/images/homepage/traumas.jpg',
    alt: 'Woman doing a gentle stretch on a wooden floor, body-aware recovery and physical resilience',
  },
  {
    title: 'Toxins',
    short: 'Chemical stress accumulates quietly.',
    body: 'From what you eat, breathe, and put on your skin. Food sensitivities, environmental exposures, medication side effects: they add up. Targeted lab work can show where your body may be under stress you did not know about.',
    image: '/images/homepage/toxins.jpg',
    alt: 'Hands rinsing fresh carrots under water, clean food prep representing reduced toxic load',
  },
  {
    title: 'Thoughts',
    short: 'Emotional stress is physiological.',
    body: 'It shows up as nervous-system dysregulation, hormone shifts, sleep disturbance, and gut symptoms. Restoring health means addressing the stress patterns your nervous system is still running, not just the body parts they affect.',
    image: '/images/homepage/thoughts.jpg',
    alt: 'Open journal on a wooden table in soft morning light, calm reflection and mental wellness',
  },
];

// First-visit walkthrough — pricing figures must stay in sync with
// /pricing (pricing.astro FAQ + price cards). Change all locations together.
const firstVisitSteps = [
  {
    title: 'We listen first.',
    body: 'Bring your story, your symptoms, and any labs you already have. Your history gets real time, not a rushed visit.',
  },
  {
    title: 'A thorough chiropractic exam.',
    body: 'Dr. DeNome performs a full exam, with X-rays only if they are clinically needed. If deeper lab work makes sense, we explain exactly what each test looks for and why.',
  },
  {
    title: 'You leave with a clear next step.',
    body: 'Most chiropractic patients receive their first adjustment the same day. Health restoration patients leave knowing which labs come next and what those results may show us. Either way, you set the pace. You have options.',
  },
];

const credentials = [
  'Doctor of Chiropractic (DC)',
  'Life University graduate',
  'Webster Technique certified',
  'Works alongside your PCP',
];

const labPartners = [
  { src: '/images/partners/access.png', alt: 'Access Medical Labs', width: 548, height: 130 },
  { src: '/images/partners/dutch.svg', alt: 'Dutch Test by Precision Analytical' },
  { src: '/images/partners/genova.svg', alt: 'Genova Diagnostics' },
  { src: '/images/partners/immunolabs.jpg', alt: 'ImmunoLabs', width: 340, height: 100 },
  { src: '/images/partners/mosaic.svg', alt: 'Mosaic Diagnostics (OAT and heavy metal testing)' },
];
---

<BaseLayout
  title="Chiropractor in Mason, OH | The Wellness Way"
  description="Chiropractic care and health restoration in Mason, OH. Thyroid, hormones, gut health. We don't guess. We test. Serving Cincinnati, West Chester, Loveland, Lebanon."
>
  <!-- Section 1: Hero — full-bleed photo background with overlay -->
  <section class="hero-bleed" aria-label="Hero">
    <Image
      class="hero-bleed-image"
      src={pediatricAdjustment}
      alt="Gentle pediatric chiropractic adjustment at The Wellness Way - Mason"
      widths={[640, 960, 1280, 1920, 2560]}
      sizes="100vw"
      loading="eager"
      fetchpriority="high"
      quality={82}
    />
    <div class="hero-bleed-scrim" aria-hidden="true"></div>
    <div class="hero-bleed-inner">
      <div class="hero-bleed-text">
        <h1 class="hero-headline hero-stagger">
          <span class="hero-kicker">Chiropractic Care in Mason, OH</span>
          Your labs are <em>normal.</em> You still feel awful.
        </h1>
        <p class="hero-lede hero-stagger">
          The body never does anything without a reason. We test to find yours.
        </p>
        <div class="hero-bleed-ctas hero-stagger">
          <Button href={clinic.bookingUrl} variant="primary" size="lg" external iconAfter>
            Start Getting Answers
          </Button>
          <Button href="/our-approach" variant="inverse" size="lg" iconAfter>
            See our approach
          </Button>
        </div>
      </div>
    </div>
  </section>

  <!-- Section 2: Hook — validate the dismissal before teaching anything -->
  <SectionContainer width="narrow" spacing="xl" background="paper">
    <div class="hook">
      <h2 data-reveal>You've been bounced from doctor to doctor. And you're still tired.</h2>
      <p data-reveal="up-sm">
        Another referral, another fifteen-minute visit, another "everything looks fine."
        Someone told you to manage your stress and never said how. And somewhere on the
        drive home, you started wondering if it's all in your head.
      </p>
      <p class="hook-turn" data-reveal="up-sm">
        It isn't. Feeling this way may be common, but common is not normal.
        You're not alone, and you're not out of options.
      </p>
    </div>
  </SectionContainer>

  <!-- Section 3: Problem / Solution — why symptom-chasing fails, what we do instead -->
  <SectionContainer width="default" spacing="lg" background="paper-soft">
    <div class="ps-grid">
      <div class="ps-col ps-problem">
        <h2 data-reveal>Why chasing symptoms never quite works</h2>
        <p data-reveal="up-sm">
          Most care is built to quiet the symptom in front of it. Pain? Something for
          pain. Fatigue? A shrug and a sleep tip. Each specialist sees one body part, so
          nobody is watching how your hormones, gut, immune system, and nervous system
          talk to each other.
        </p>
        <p data-reveal="up-sm">
          That model is excellent in a crisis. It just wasn't built for the slow,
          stubborn stuff. The body never does anything without a reason, and when one
          quick fix follows another while you still feel <em>off</em>, the problem
          usually isn't you. It's care that manages symptoms without ever asking why
          they're there.
        </p>
      </div>
      <div class="ps-col ps-solution">
        <h2 data-reveal>Find the fire, not just the alarm</h2>
        <p data-reveal="up-sm">
          A smoke alarm doing its job is loud, annoying, and right. Silencing it doesn't
          put out the fire, and your symptoms work the same way: signals, not
          malfunctions. So we start with a different question. Why is your body
          sounding the alarm?
        </p>
        <p data-reveal="up-sm">
          Targeted functional lab work looks for the pattern underneath, across three
          kinds of stress: Traumas (physical), Toxins (chemical), and Thoughts
          (emotional). Then we sit down together, walk through your results in plain
          English, and build a plan that fits your real life. Test, don't guess. And all
          of it happens alongside your PCP and specialists, never in place of them.
        </p>
        <p class="ps-bridge" data-reveal="up-sm">
          And when we say test, we mean real labs. Here's who runs them.
        </p>
      </div>
    </div>
  </SectionContainer>

  <!-- Section 4: Lab partners — single slow marquee, the receipt for "we test" -->
  <SectionContainer width="wide" spacing="md" background="paper-soft" ariaLabel="Lab partners">
    <div class="lab-strip">
      <p class="lab-strip-eyebrow" data-reveal>Lab partners we trust</p>
      <div class="lab-marquee">
        <div class="lab-track">
          <ul class="lab-strip-list" role="list">
            {labPartners.map((p) => (
              <li><img src={p.src} alt={p.alt} loading="lazy" width={p.width} height={p.height} /></li>
            ))}
          </ul>
          <ul class="lab-strip-list" role="presentation" aria-hidden="true">
            {labPartners.map((p) => (
              <li><img src={p.src} alt="" loading="lazy" width={p.width} height={p.height} /></li>
            ))}
          </ul>
        </div>
      </div>
      <p class="lab-strip-caption" data-reveal="up-sm">
        We work with Access, Dutch, Genova, ImmunoLabs, and Mosaic (for OAT and heavy metal panels), so health restoration reaches the depth that standard panels miss.
      </p>
    </div>
  </SectionContainer>

  <!-- Section 5: The 3 T's — image-led, alternating layout -->
  <SectionContainer width="default" spacing="xl" background="paper-soft">
    <div class="section-head">
      <p class="eyebrow">The Wellness Way Approach</p>
      <h2>Traumas. Toxins. Thoughts.</h2>
      <p class="section-lede">
        Three categories of stress that interact with everything from your hormones to your nervous
        system to your immune response. We test for the patterns underneath your symptoms, rather
        than just managing the symptoms themselves.
      </p>
    </div>
    <div class="three-ts">
      {threeTs.map((t, i) => (
        <article class={`t-row ${i % 2 ? 'reverse' : ''}`}>
          <div class="t-image">
            <img src={t.image} alt={t.alt} loading="lazy" />
            <span class="t-numeral" aria-hidden="true">{i + 1}</span>
          </div>
          <div class="t-text">
            <h3>{t.title}</h3>
            <p class="t-short">{t.short}</p>
            <p>{t.body}</p>
          </div>
        </article>
      ))}
    </div>
  </SectionContainer>

  <!-- Section 6: First visit — proof panel: walkthrough, transparent pricing,
       verifiable credentials. Everything here is checkable before you visit. -->
  <SectionContainer width="default" spacing="xl" background="paper-warm-tint" ariaLabel="Your first visit">
    <div class="visit-grid">
      <div class="visit-intro" data-reveal>
        <p class="eyebrow eyebrow-lockup">Your first visit</p>
        <h2>What your first visit looks like.</h2>
        <p class="visit-lede">
          No mystery pricing and no pressure. Here is the whole visit, start to finish,
          so you can walk in knowing what to expect.
        </p>
        <div class="price-card">
          <p class="price-title">Every new patient visit</p>
          <p class="price-amount">$99<span class="price-flat">flat</span></p>
          <p class="price-body">
            For chiropractic, that covers your exam, X-rays if they're needed, and your
            first adjustment. Follow-up adjustments are $50 with soft tissue work,
            cupping, and scraping included. For health restoration, it covers your
            intake conversation and a review of any labs you bring.
          </p>
        </div>
        <div class="visit-ctas">
          <Button href={clinic.bookingUrl} variant="primary" size="lg" external iconAfter>
            Start Getting Answers
          </Button>
          {clinic.gbpUrl && (
            <a class="reviews-link" href={clinic.gbpUrl} target="_blank" rel="noopener noreferrer">
              Read our Google reviews
            </a>
          )}
        </div>
      </div>
      <div class="visit-steps-col">
        <ol class="visit-steps">
          {firstVisitSteps.map((s, i) => (
            <li data-reveal="up-sm">
              <span class="visit-num" aria-hidden="true">{i + 1}</span>
              <div>
                <h3>{s.title}</h3>
                <p>{s.body}</p>
              </div>
            </li>
          ))}
        </ol>
        <Image
          class="visit-photo"
          src={labKitsFlatLay}
          alt="Functional lab kits from Access, DUTCH, Genova, and ImmunoLabs at The Wellness Way - Mason"
          widths={[480, 720, 960, 1440]}
          sizes="(min-width: 1024px) 45vw, 100vw"
          loading="lazy"
          quality={82}
        />
      </div>
    </div>
    <ul class="cred-strip" role="list" data-reveal="up-sm">
      {credentials.map((c) => (
        <li>
          <svg aria-hidden="true" width="14" height="14" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M2.5 8.5l3.5 3.5L13.5 4" /></svg>
          {c}
        </li>
      ))}
    </ul>
  </SectionContainer>

  <!-- Section 7: Conditions — refined typography list, not card grid -->
  <SectionContainer width="narrow" spacing="lg">
    <div class="section-head">
      <h2>Common, but not normal.</h2>
      <p class="section-lede">
        Patients often walk through our doors after being told their labs are "normal" while still
        feeling anything but. Here are some of the patterns we see most.
      </p>
    </div>
    <ul class="conditions-list">
      {conditions.map((c) => (
        <li><a href={c.href}>{c.label}</a></li>
      ))}
    </ul>
    <div class="section-cta">
      <Button href="/find-my-condition" variant="link" iconAfter>See all conditions we address</Button>
    </div>
  </SectionContainer>

  <!-- Section 8: Two arms intro — chiropractic vs health restoration -->
  <SectionContainer width="default" spacing="lg" background="paper-soft">
    <div class="section-head">
      <h2>Pick the door that fits where you are right now.</h2>
      <p class="section-lede">
        Chiropractic for hands-on adjustments and the pain you can point to.
        Health restoration for the deeper testing-based work. Same approach, two paths in.
      </p>
    </div>
    <div class="arms-grid">
      {twoArms.map((arm) => (
        <article class="arm-tile">
          <h3 class="arm-title">{arm.title}</h3>
          <p class="arm-slogan">{arm.slogan}</p>
          <p class="arm-body">{arm.body}</p>
          <aside class="arm-callout">{arm.callout}</aside>
          <Button href={arm.cta.href} variant="ghost" size="md" iconAfter>
            {arm.cta.label}
          </Button>
        </article>
      ))}
    </div>
  </SectionContainer>

  <!-- Section 9: 4-Step Process — vertical timeline, line fills as you scroll -->
  <SectionContainer width="default" spacing="xl">
    <div class="section-head">
      <h2>How we work with you.</h2>
      <p class="section-lede">
        Whichever door you came through, The Wellness Way 4-Step Process is the same.
      </p>
    </div>
    <ol class="steps">
      {fourSteps.map((s) => (
        <li>
          <div class="step-num">{s.n}</div>
          <div class="step-body">
            <h3>{s.title}</h3>
            <p>{s.body}</p>
          </div>
        </li>
      ))}
    </ol>
  </SectionContainer>

  <!-- Section 10: Atmosphere — full-bleed clinic interior with overlay panel -->
  <section class="atmosphere-bleed" aria-label="Our space">
    <Image
      class="atmosphere-bleed-image"
      src={pediatricPlayRoom}
      alt="Family-friendly pediatric play room with green tree bookshelf at The Wellness Way - Mason"
      widths={[640, 960, 1280, 1920, 2560]}
      sizes="100vw"
      loading="lazy"
      quality={82}
    />
    <div class="atmosphere-bleed-scrim" aria-hidden="true"></div>
    <div class="atmosphere-bleed-inner">
      <div class="atmosphere-card">
        <h2>Pediatric &amp; prenatal care in a space for every age.</h2>
        <p>
          From newborns to grandparents, the clinic is designed for real families with real lives.
          Pediatric play space, prenatal-comfortable adjusting tables, calm lighting, and a team
          that knows your kids by name.
        </p>
      </div>
    </div>
  </section>

  <!-- Section 11: Meet Dr. Ryan — image-text grid -->
  <SectionContainer width="default" spacing="xl" background="paper-warm">
    <div class="provider-teaser">
      <div class="provider-text">
        <p class="eyebrow eyebrow-lockup">Meet Your Chiropractor</p>
        <h2>Dr. Ryan DeNome, DC</h2>
        <p class="provider-lede">
          Doctor of Chiropractic, Life University graduate, and Cincinnati native.
          Certified in the Webster Technique. Especially passionate about supporting men feeling
          limited by health challenges, mothers running on empty while caring for everyone else,
          and patients with complex cases who haven't found answers in conventional care.
        </p>
        <blockquote class="ryan-quote">
          "It is health that is real wealth and not pieces of gold and silver."
          <cite>Mahatma Gandhi</cite>
        </blockquote>
        <Button href="/about-us" variant="link" iconAfter>Read full bio</Button>
      </div>
      <div class="provider-photo">
        <img
          src="/images/people/dr-ryan-denome.jpg"
          alt="Dr. Ryan DeNome, DC at The Wellness Way - Mason"
          loading="lazy"
          width="1500"
          height="1500"
        />
      </div>
    </div>
  </SectionContainer>

  <!-- Section 12: Featured posts -->
  <SectionContainer width="default" spacing="lg" background="paper-soft">
    <div class="section-head">
      <h2>Latest insights</h2>
      <p class="section-lede">Real answers, real conditions, real explanations.</p>
    </div>
    <div class="post-grid">
      {featured.map((post) => (
        <BlogPostCard
          title={post.data.title}
          excerpt={post.data.excerpt ?? ''}
          href={`/post/${post.id}`}
          image={post.data.image}
          imageAlt={post.data.imageAlt ?? post.data.title}
          date={post.data.date}
          author={post.data.author}
          category={post.data.categories[0]?.replace(/-/g, ' ')}
          readTime={post.data.readTime}
        />
      ))}
    </div>
    <div class="section-cta">
      <Button href="/blog" variant="link" iconAfter>All posts</Button>
    </div>
  </SectionContainer>

  <!-- Section 13: Service area + map -->
  <SectionContainer width="default" spacing="lg">
    <div class="service-area-grid">
      <div>
        <h2>Serving Mason and the Greater Cincinnati Area</h2>
        <p class="service-lede">
          We see patients from {clinic.serviceArea.join(', ')}, and beyond.
          Virtual health-restoration consultations are available for patients outside the area.
        </p>
        <address class="nap-block">
          <strong>{clinic.brandName}</strong><br />
          {clinic.address.streetAddress}<br />
          {clinic.address.addressLocality}, {clinic.address.addressRegion} {clinic.address.postalCode}<br />
          <a href={`tel:${clinic.phoneTel}`}>{clinic.phone}</a><br />
          <a href={`mailto:${clinic.email}`}>{clinic.email}</a>
        </address>
      </div>
      <MapEmbed height="420px" />
    </div>
  </SectionContainer>

  <!-- Section 14: Hours -->
  <SectionContainer width="narrow" spacing="md" background="paper-soft">
    <div class="hours-section">
      <h2>Clinic Hours</h2>
      <HoursTable />
    </div>
  </SectionContainer>

  <!-- Section 15: Final CTA — full-bleed photo with TWW Green tint overlay -->
  <section class="final-cta-bleed" aria-label="Book a consultation">
    <Image
      class="final-cta-image"
      src={adultAdjustment}
      alt=""
      role="presentation"
      widths={[640, 960, 1280, 1920, 2560]}
      sizes="100vw"
      loading="lazy"
      quality={78}
    />
    <div class="final-cta-scrim" aria-hidden="true"></div>
    <div class="final-cta-inner">
      <h2>Start with a conversation, not a commitment.</h2>
      <p>
        Come with your questions, your history, and the folder of labs no one has
        explained yet. Your first visit is a flat $99, and you'll leave knowing exactly
        what happens next. We'll listen. We'll ask why. We'll build the plan with you.
      </p>
      <Button href={clinic.bookingUrl} variant="secondary" size="lg" external iconAfter>
        Start Getting Answers
      </Button>
    </div>
  </section>
</BaseLayout>

<style>
  .section-head {
    margin-bottom: 3.5rem;
    text-align: center;
    max-width: 60ch;
    margin-left: auto;
    margin-right: auto;
  }
  .eyebrow {
    font-size: var(--text-xs);
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--color-mute);
    margin: 0 0 1rem;
    font-weight: 500;
  }
  /* Eyebrow lockup: the one added ornament — a short TWW Green rule that
     turns a grey caps label into a composed unit. */
  .section-head .eyebrow::after,
  .eyebrow-lockup::after {
    content: "";
    display: block;
    width: 32px;
    height: 2px;
    background: var(--color-brand-primary);
    margin: 0.9rem 0 0;
  }
  .section-head .eyebrow::after {
    margin-left: auto;
    margin-right: auto;
  }
  .section-head h2 {
    margin: 0 0 1.25rem;
    font-size: var(--text-3xl);
    color: var(--color-ink-strong);
  }
  .section-lede {
    color: var(--color-ink-muted);
    font-size: var(--text-lg);
    margin: 0;
    line-height: 1.6;
  }
  .section-cta {
    text-align: center;
    margin-top: 2.5rem;
  }

  /* === Hook — editorial validation moment === */
  .hook h2 {
    font-family: var(--font-display);
    font-size: var(--text-3xl);
    line-height: 1.12;
    color: var(--color-ink-strong);
    margin: 0 0 1.75rem;
    max-width: 24ch;
  }
  .hook p {
    color: var(--color-ink);
    font-size: var(--text-lg);
    line-height: 1.7;
    margin: 0 0 1.25rem;
    max-width: 58ch;
  }
  .hook-turn {
    font-family: var(--font-display);
    color: var(--color-ink-strong);
    font-size: var(--text-xl);
    line-height: 1.5;
  }

  /* === Problem / Solution bridge === */
  .ps-grid {
    display: grid;
    gap: 3rem;
    align-items: start;
  }
  .ps-col h2 {
    font-family: var(--font-display);
    font-size: var(--text-3xl);
    line-height: 1.15;
    color: var(--color-ink-strong);
    margin: 0 0 1.25rem;
    max-width: 22ch;
  }
  .ps-col p {
    color: var(--color-ink);
    font-size: var(--text-lg);
    line-height: 1.65;
    margin: 0 0 1rem;
  }
  .ps-col p:last-child { margin-bottom: 0; }
  .ps-problem h2 em,
  .ps-solution h2 em,
  .ps-col p em {
    font-style: italic;
    color: var(--color-brand-primary-dark);
  }
  .ps-solution {
    position: relative;
    padding-left: 0;
  }
  .ps-bridge {
    margin-top: 1.5rem !important;
    font-family: var(--font-display);
    font-style: italic;
    color: var(--color-brand-primary-dark);
    font-size: var(--text-lg);
  }

  /* === 3 T's image-led rows === */
  .three-ts {
    display: flex;
    flex-direction: column;
    gap: 5rem;
  }
  .t-row {
    display: grid;
    gap: 2.5rem;
    align-items: center;
  }
  .t-image {
    position: relative;
    border-radius: var(--radius-xl);
    overflow: hidden;
    box-shadow: var(--shadow-card);
  }
  .t-image img {
    width: 100%;
    aspect-ratio: 4 / 3;
    object-fit: cover;
    transition: transform 600ms var(--ease-soft);
  }
  /* Quiet zoom signals the whole row is one unit — the editorial-site tell. */
  .t-row:hover .t-image img {
    transform: scale(1.03);
  }
  .t-numeral {
    position: absolute;
    top: 1.5rem;
    left: 1.5rem;
    font-family: var(--font-display);
    font-style: italic;
    font-size: var(--text-5xl);
    color: var(--color-paper);
    text-shadow: 0 2px 8px rgba(0,0,0,0.35);
    line-height: 1;
  }
  .t-text h3 {
    font-family: var(--font-display);
    font-size: var(--text-3xl);
    margin: 0 0 0.75rem;
    color: var(--color-ink-strong);
  }
  .t-short {
    font-style: italic;
    color: var(--color-brand-primary-dark);
    font-size: var(--text-lg);
    margin: 0 0 1rem;
    font-family: var(--font-display);
  }
  .t-text p:last-child {
    color: var(--color-ink-muted);
    line-height: 1.7;
    margin: 0;
  }

  /* === First visit proof panel === */
  .visit-grid {
    display: grid;
    gap: 3rem;
    align-items: start;
  }
  .visit-intro .eyebrow { margin-bottom: 1rem; }
  .visit-intro h2 {
    font-size: var(--text-3xl);
    margin: 0 0 1rem;
    color: var(--color-ink-strong);
  }
  .visit-lede {
    color: var(--color-ink-muted);
    font-size: var(--text-lg);
    line-height: 1.6;
    margin: 0 0 2rem;
    max-width: 42ch;
  }
  .price-card {
    background: var(--color-paper);
    border: 1px solid var(--color-line);
    border-radius: var(--radius-lg);
    padding: 1.75rem 2rem;
    box-shadow: var(--shadow-card);
    margin-bottom: 2rem;
  }
  .price-title {
    font-family: var(--font-display);
    font-size: var(--text-lg);
    color: var(--color-ink-muted);
    font-weight: 500;
    margin: 0 0 0.5rem;
  }
  .price-amount {
    font-family: var(--font-display);
    font-size: var(--text-5xl);
    line-height: 1;
    color: var(--color-ink-strong);
    margin: 0 0 1rem;
    display: flex;
    align-items: baseline;
    gap: 0.6rem;
  }
  .price-flat {
    font-family: var(--font-display);
    font-style: italic;
    font-size: var(--text-xl);
    color: var(--color-brand-primary-dark);
  }
  .price-body {
    color: var(--color-ink-muted);
    font-size: var(--text-sm);
    line-height: 1.6;
    margin: 0;
  }
  .visit-ctas {
    display: flex;
    align-items: center;
    gap: 1.5rem;
    flex-wrap: wrap;
  }
  .reviews-link {
    color: var(--color-ink-strong);
    font-weight: 500;
    font-size: var(--text-base);
  }
  .visit-steps {
    list-style: none;
    margin: 0 0 2.5rem;
    padding: 0;
  }
  .visit-steps li {
    display: grid;
    grid-template-columns: 3rem 1fr;
    gap: 1.25rem;
    padding: 1.5rem 0;
    border-bottom: 1px solid var(--color-line);
  }
  .visit-steps li:first-child { padding-top: 0; }
  .visit-num {
    font-family: var(--font-display);
    font-style: italic;
    font-size: var(--text-3xl);
    line-height: 1;
    color: var(--color-brand-primary-dark);
  }
  .visit-steps h3 {
    font-size: var(--text-xl);
    margin: 0 0 0.5rem;
    color: var(--color-ink-strong);
  }
  .visit-steps p {
    margin: 0;
    color: var(--color-ink-muted);
    line-height: 1.6;
  }
  .visit-photo {
    width: 100%;
    aspect-ratio: 3 / 2;
    object-fit: cover;
    border-radius: var(--radius-lg);
    box-shadow: var(--shadow-card);
  }
  .cred-strip {
    list-style: none;
    margin: 3rem 0 0;
    padding: 1.5rem 0 0;
    border-top: 1px solid var(--color-line);
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1rem 2rem;
  }
  .cred-strip li {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    color: var(--color-ink-strong);
    font-weight: 500;
    font-size: var(--text-sm);
  }
  .cred-strip svg {
    color: var(--color-brand-primary-dark);
    flex-shrink: 0;
  }

  /* === Conditions list (refined typography, interactive links) === */
  .conditions-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    gap: 0;
  }
  .conditions-list li {
    border-bottom: 1px solid var(--color-line);
    position: relative;
  }
  .conditions-list li a {
    display: block;
    padding: 1rem 0 1rem 2rem;
    color: var(--color-ink-strong);
    font-size: var(--text-lg);
    font-family: var(--font-display);
    font-weight: 400;
    text-decoration: none;
    position: relative;
    transition: padding-left var(--duration-fast) var(--ease-soft),
                color var(--duration-fast) var(--ease-soft),
                background var(--duration-fast) var(--ease-soft);
  }
  .conditions-list li a:hover {
    color: var(--color-brand-primary-dark);
    padding-left: 2.5rem;
    background: var(--color-brand-primary-soft);
  }
  .conditions-list li a::before {
    content: "›";
    position: absolute;
    left: 0;
    top: 50%;
    transform: translateY(-50%);
    color: var(--color-brand-primary);
    font-weight: 600;
    transition: transform var(--duration-fast) var(--ease-soft);
  }
  .conditions-list li a:hover::before {
    transform: translateY(-50%) translateX(4px);
  }
  .conditions-list li:last-child { border-bottom: none; }

  /* === Two-arms grid (chiro vs health restoration) === */
  .arms-grid {
    display: grid;
    gap: 1.5rem;
    grid-template-columns: 1fr;
  }
  .arm-tile {
    background: var(--color-paper);
    border: 1px solid var(--color-line);
    border-top: 4px solid var(--color-brand-primary);
    border-radius: var(--radius-lg);
    padding: 2rem;
    box-shadow: var(--shadow-card);
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }
  .arm-title {
    font-family: var(--font-display);
    font-size: var(--text-2xl);
    margin: 0;
    color: var(--color-ink-strong);
  }
  .arm-slogan {
    font-family: var(--font-display);
    font-style: italic;
    color: var(--color-brand-primary-dark);
    font-size: var(--text-lg);
    margin: 0;
  }
  .arm-body {
    color: var(--color-ink-muted);
    line-height: 1.65;
    margin: 0;
    flex: 1;
  }
  .arm-callout {
    background: var(--color-brand-primary-soft);
    color: var(--color-ink-strong);
    border-radius: var(--radius-md);
    padding: 1rem 1.25rem;
    font-size: var(--text-sm);
    line-height: 1.5;
    border-left: 3px solid var(--color-brand-primary);
  }
  @media (min-width: 768px) {
    .arms-grid {
      grid-template-columns: 1fr 1fr;
      gap: 2rem;
    }
  }

  /* === 4-step process — vertical timeline with scroll-fill === */
  .steps {
    list-style: none;
    padding: 0;
    margin: 0 auto;
    max-width: 56rem;
    counter-reset: step;
    position: relative;
  }
  .steps li {
    display: grid;
    grid-template-columns: 4rem 1fr;
    gap: 1.5rem;
    padding-bottom: 2.5rem;
    position: relative;
  }
  .steps li:not(:last-child)::before {
    content: "";
    position: absolute;
    left: 1.5rem;
    top: 3.5rem;
    bottom: 0;
    width: 2px;
    background: var(--color-line);
  }
  /* Green overlay line draws downward as each step reveals — the timeline
     "completes" itself while you scroll, enacting the 4-step narrative. */
  .steps li:not(:last-child)::after {
    content: "";
    position: absolute;
    left: 1.5rem;
    top: 3.5rem;
    bottom: 0;
    width: 2px;
    background: var(--color-brand-primary);
    transform: scaleY(0);
    transform-origin: top center;
    transition: transform 700ms var(--ease-soft) 200ms;
  }
  .steps li:global(.is-visible):not(:last-child)::after {
    transform: scaleY(1);
  }
  .step-num {
    width: 3rem;
    height: 3rem;
    border-radius: 50%;
    background: var(--color-paper);
    border: 2px solid var(--color-brand-primary);
    color: var(--color-brand-primary-dark);
    font-family: var(--font-display);
    font-weight: 500;
    font-size: var(--text-xl);
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    z-index: 1;
    transition: background 400ms var(--ease-soft) 200ms;
  }
  .steps li:global(.is-visible) .step-num {
    background: var(--color-brand-primary-soft);
  }
  .step-body { padding-top: 0.4rem; }
  .step-body h3 {
    margin: 0 0 0.5rem;
    font-size: var(--text-xl);
    color: var(--color-ink-strong);
  }
  .step-body p {
    margin: 0;
    color: var(--color-ink-muted);
    line-height: 1.6;
  }

  /* === Posts === */
  .post-grid {
    display: grid;
    gap: 1.5rem;
    grid-template-columns: 1fr;
  }

  /* === Lab partners marquee === */
  .lab-strip {
    text-align: center;
  }
  .lab-strip-eyebrow {
    font-size: var(--text-xs);
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--color-mute);
    margin: 0 0 1.75rem;
    font-weight: 500;
  }
  .lab-marquee {
    overflow: hidden;
    mask-image: linear-gradient(90deg, transparent, black 8%, black 92%, transparent);
    -webkit-mask-image: linear-gradient(90deg, transparent, black 8%, black 92%, transparent);
    margin-bottom: 1.75rem;
  }
  .lab-track {
    display: flex;
    width: max-content;
    animation: lab-drift 40s linear infinite;
  }
  .lab-marquee:hover .lab-track {
    animation-play-state: paused;
  }
  @keyframes lab-drift {
    to { transform: translateX(-50%); }
  }
  .lab-strip-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    align-items: center;
    gap: 4.5rem;
    padding-right: 4.5rem;
  }
  .lab-strip-list li {
    display: flex;
    align-items: center;
    justify-content: center;
    min-height: 56px;
  }
  .lab-strip-list img {
    max-height: 48px;
    max-width: 190px;
    width: auto;
    height: auto;
    object-fit: contain;
    filter: grayscale(100%) opacity(0.65);
    transition: filter var(--duration-normal) var(--ease-soft);
  }
  .lab-strip-list li:hover img {
    filter: grayscale(0%) opacity(1);
  }
  .lab-strip-caption {
    color: var(--color-ink-muted);
    font-size: var(--text-sm);
    max-width: 50ch;
    margin: 0 auto;
    line-height: 1.55;
    font-style: italic;
  }
  @media (prefers-reduced-motion: reduce) {
    .lab-track {
      animation: none;
      width: 100%;
      justify-content: center;
    }
    .lab-track .lab-strip-list[aria-hidden="true"] { display: none; }
    .lab-strip-list {
      flex-wrap: wrap;
      justify-content: center;
      gap: 2rem 2.5rem;
      padding-right: 0;
    }
    .lab-marquee {
      mask-image: none;
      -webkit-mask-image: none;
    }
  }

  /* === Provider teaser === */
  .provider-teaser {
    display: grid;
    gap: 3rem;
    align-items: center;
  }
  .provider-text h2 {
    font-size: var(--text-4xl);
    margin: 0 0 1.25rem;
  }
  .provider-text .eyebrow { margin-bottom: 1.25rem; }
  .provider-lede {
    color: var(--color-ink);
    line-height: 1.7;
    font-size: var(--text-lg);
    margin: 0 0 1.5rem;
  }
  .ryan-quote {
    font-family: var(--font-display);
    font-style: italic;
    font-size: var(--text-lg);
    line-height: 1.5;
    margin: 1.5rem 0 2rem;
    padding-left: 1.25rem;
    border-left: 3px solid var(--color-brand-primary);
    color: var(--color-ink-strong);
  }
  .ryan-quote cite {
    display: block;
    margin-top: 0.5rem;
    font-size: var(--text-sm);
    color: var(--color-ink-muted);
    font-style: normal;
    font-family: var(--font-body);
  }
  .provider-photo img {
    width: 100%;
    border-radius: var(--radius-xl);
    box-shadow: var(--shadow-card);
    aspect-ratio: 4 / 5;
    object-fit: cover;
  }

  /* === Service area === */
  .service-area-grid {
    display: grid;
    gap: 2.5rem;
    align-items: start;
  }
  .service-area-grid h2 {
    margin: 0 0 1rem;
    font-size: var(--text-3xl);
  }
  .service-lede {
    color: var(--color-ink-muted);
    line-height: 1.65;
    font-size: var(--text-lg);
  }
  .nap-block {
    background: var(--color-paper-soft);
    padding: 1.75rem;
    border-radius: var(--radius-md);
    margin-top: 1.75rem;
    font-style: normal;
    line-height: 1.75;
    border: 1px solid var(--color-line);
  }

  /* === Hours === */
  .hours-section { text-align: center; }
  .hours-section h2 {
    margin: 0 0 2rem;
    font-size: var(--text-3xl);
  }
  .hours-section :global(.hours-table) {
    max-width: 28rem;
    margin: 0 auto;
    text-align: left;
  }

  /* === Full-bleed Hero === */
  .hero-bleed {
    position: relative;
    min-height: 78vh;
    display: flex;
    align-items: center;
    overflow: hidden;
    isolation: isolate;
  }
  .hero-bleed-image {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center 35%;
    z-index: -2;
  }
  /* One-shot 14s settle from 1.06 to 1.0 — a considered, expensive open.
     Gated behind html.js so crawlers and no-JS visitors see a static hero. */
  :global(html.js) .hero-bleed-image {
    animation: hero-settle 14s var(--ease-soft) forwards;
  }
  @keyframes hero-settle {
    from { transform: scale(1.06); }
    to { transform: scale(1); }
  }
  .hero-bleed-scrim {
    position: absolute;
    inset: 0;
    background:
      linear-gradient(105deg,
        rgba(31, 34, 34, 0.78) 0%,
        rgba(31, 34, 34, 0.55) 45%,
        rgba(31, 34, 34, 0.18) 80%,
        rgba(31, 34, 34, 0.05) 100%);
    z-index: -1;
  }
  .hero-bleed-inner {
    width: 100%;
    max-width: var(--container-default);
    margin: 0 auto;
    padding: 5rem 1.5rem;
    color: var(--color-paper);
  }
  .hero-bleed-text {
    max-width: 44rem;
  }
  /* Entrance stagger walks the eye headline -> subtitle -> CTA in reading
     order. JS-gated; reduced-motion renders static below. */
  :global(html.js) .hero-stagger {
    opacity: 0;
    transform: translateY(18px);
    animation: hero-rise 850ms cubic-bezier(0.16, 1, 0.3, 1) forwards;
  }
  :global(html.js) .hero-stagger:nth-child(2) { animation-delay: 110ms; }
  :global(html.js) .hero-stagger:nth-child(3) { animation-delay: 220ms; }
  @keyframes hero-rise {
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }
  @media (prefers-reduced-motion: reduce) {
    :global(html.js) .hero-stagger {
      opacity: 1;
      transform: none;
      animation: none;
    }
    :global(html.js) .hero-bleed-image {
      animation: none;
    }
  }
  /* Keyword kicker lives INSIDE the h1 so the primary keyword is part of
     the H1 text Google reads (Manus audit 2A), while the visitor-mirroring
     headline keeps the visual punch. */
  .hero-kicker {
    display: block;
    font-family: var(--font-body);
    font-size: var(--text-xs);
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--color-paper);
    opacity: 0.85;
    margin: 0 0 1.25rem;
    font-weight: 500;
  }
  .hero-headline {
    font-family: var(--font-display);
    font-weight: 500;
    font-size: var(--text-4xl);
    line-height: 1.08;
    letter-spacing: -0.02em;
    margin: 0 0 1.5rem;
    color: var(--color-paper);
    max-width: 21ch;
  }
  .hero-headline em {
    font-style: italic;
    color: var(--color-brand-primary);
    font-weight: 400;
  }
  .hero-lede {
    color: var(--color-paper);
    opacity: 0.94;
    font-size: var(--text-xl);
    line-height: 1.5;
    margin: 0 0 2.5rem;
    max-width: 34ch;
    text-shadow: 0 1px 8px rgba(0,0,0,0.35);
  }
  .hero-bleed-ctas {
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
  }

  /* === Full-bleed Atmosphere band === */
  .atmosphere-bleed {
    position: relative;
    min-height: 60vh;
    display: flex;
    align-items: center;
    overflow: hidden;
    isolation: isolate;
  }
  .atmosphere-bleed-image {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
    z-index: -2;
  }
  .atmosphere-bleed-scrim {
    position: absolute;
    inset: 0;
    background: linear-gradient(95deg,
      rgba(31, 34, 34, 0.35) 0%,
      rgba(31, 34, 34, 0.05) 60%);
    z-index: -1;
  }
  .atmosphere-bleed-inner {
    width: 100%;
    max-width: var(--container-default);
    margin: 0 auto;
    padding: 5rem 1.5rem;
  }
  .atmosphere-card {
    background: rgba(255, 255, 255, 0.94);
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
    padding: 2.5rem;
    border-radius: var(--radius-xl);
    box-shadow: var(--shadow-card);
    max-width: 32rem;
    border: 1px solid rgba(255,255,255,0.6);
  }
  .atmosphere-card h2 {
    margin: 0 0 1rem;
    font-size: var(--text-3xl);
    color: var(--color-ink-strong);
  }
  .atmosphere-card p {
    color: var(--color-ink-muted);
    line-height: 1.65;
    margin: 0;
  }

  /* === Full-bleed Final CTA === */
  .final-cta-bleed {
    position: relative;
    min-height: 65vh;
    display: flex;
    align-items: center;
    overflow: hidden;
    isolation: isolate;
  }
  .final-cta-image {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
    z-index: -2;
  }
  .final-cta-scrim {
    position: absolute;
    inset: 0;
    background:
      linear-gradient(135deg,
        rgba(128, 183, 65, 0.94) 0%,
        rgba(110, 160, 55, 0.88) 100%);
    z-index: -1;
  }
  .final-cta-inner {
    width: 100%;
    max-width: var(--container-narrow);
    margin: 0 auto;
    padding: 5rem 1.5rem;
    text-align: center;
    color: var(--color-ink-strong);
  }
  .final-cta-inner h2 {
    color: var(--color-ink-strong);
    font-size: var(--text-4xl);
    line-height: 1.1;
    margin: 0 0 1.5rem;
    max-width: 22ch;
    margin-left: auto;
    margin-right: auto;
  }
  .final-cta-inner p {
    color: var(--color-ink-strong);
    max-width: 50ch;
    margin: 0 auto 2.5rem;
    line-height: 1.6;
    font-size: var(--text-lg);
  }

  /* === Responsive === */
  @media (min-width: 768px) {
    .section-head h2 { font-size: var(--text-4xl); }
    .hook h2 { font-size: var(--text-4xl); }
    .ps-grid {
      grid-template-columns: 1fr 1fr;
      gap: 4rem;
    }
    .ps-solution {
      padding-left: 3rem;
      border-left: 1px solid var(--color-line);
    }
    .ps-col h2 { font-size: var(--text-4xl); }
    .t-row {
      grid-template-columns: 1fr 1fr;
      gap: 4rem;
    }
    .t-row.reverse > .t-image { order: 2; }
    .conditions-list {
      grid-template-columns: 1fr 1fr;
      column-gap: 2.5rem;
    }
    .visit-grid {
      grid-template-columns: 5fr 6fr;
      gap: 4rem;
    }
    .visit-intro h2 { font-size: var(--text-4xl); }
    .cred-strip {
