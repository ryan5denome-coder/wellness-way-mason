---
import { Image } from 'astro:assets';
import BaseLayout from '../layouts/BaseLayout.astro';
import SectionContainer from '../components/SectionContainer.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';
import Button from '../components/Button.astro';
import { clinic, site, bylines } from '../lib/site';
import adultAdjustment from '../assets/clinic/adult-adjustment.jpg';

const faqs = [
  {
    q: "What is the Webster Technique?",
    a: "The Webster Technique is a specific chiropractic adjustment developed for pregnant patients. It focuses on analyzing and balancing the pelvis (the sacrum, the surrounding muscles, and the ligaments that support the uterus) without any twisting, cracking, or popping. The goal is to ease tension and imbalance in the pelvis, which may help the body keep the room and alignment it's designed to have through pregnancy and birth.",
  },
  {
    q: "Does the Webster Technique turn a breech baby?",
    a: "No. The Webster Technique is not a maneuver to turn a baby, and we never describe it that way. It's a pelvic-balancing adjustment. The reasoning is that when the pelvis and its ligaments are balanced and free of excess tension, the uterus may be less constrained, and the baby may have more room to find its own optimal position. We work alongside your OB or midwife, who manage fetal positioning and any breech presentation directly.",
  },
  {
    q: "Is the Webster Technique safe during pregnancy?",
    a: "It's a gentle, low-force adjustment designed specifically for pregnancy. You're positioned comfortably with support for your belly, and there's no twisting or forceful motion. Dr. DeNome is certified in the technique. As with any prenatal care, we coordinate with your OB or midwife and stay inside what's appropriate for your specific pregnancy.",
  },
  {
    q: "When should I start prenatal chiropractic care?",
    a: "Many patients begin in the first or second trimester and continue through delivery, but there's no single right time to start: care can begin whenever you're experiencing discomfort or want support. Some come in specifically in the third trimester as the body prepares for birth. We'll talk through a schedule that fits where you are.",
  },
];

const pageUrl = `${site.url}/webster-technique-mason-oh`;

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqs.map((f) => ({
    '@type': 'Question',
    name: f.q,
    acceptedAnswer: { '@type': 'Answer', text: f.a },
  })),
};

const procedureSchema = {
  '@context': 'https://schema.org',
  '@type': 'MedicalProcedure',
  name: 'Webster Technique (prenatal chiropractic)',
  description:
    'A specific, gentle chiropractic adjustment for pregnant patients that balances the pelvis, sacrum, and supporting ligaments. Provided by Dr. Ryan DeNome, DC at The Wellness Way - Mason, serving Mason, OH and the greater Cincinnati area.',
  url: pageUrl,
  performer: { '@type': 'Person', '@id': `${site.url}/#owner` },
};

const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: site.url },
    { '@type': 'ListItem', position: 2, name: 'Webster Technique in Mason, OH', item: pageUrl },
  ],
};

const whoFor = [
  'Pregnant patients with low back, hip, or sacroiliac (SI joint) discomfort',
  'Round ligament pain (the sharp, pulling sensation low in the abdomen)',
  'Anyone who wants to support pelvic alignment and comfort through pregnancy',
  'Patients preparing their body for the physical demands of labor and delivery',
  "Those who've had prior pregnancies with significant pelvic or back discomfort",
];
---

<BaseLayout
  title="Webster Technique in Mason, OH | Prenatal Chiropractic"
  description="Webster Technique certified prenatal chiropractor in Mason, OH. Dr. Ryan DeNome, DC offers gentle pelvic-balancing adjustments for pregnancy. Serving the greater Cincinnati area."
  jsonLd={[faqSchema, procedureSchema, breadcrumbSchema]}
>
  <!-- Section 1: Hero — H1 lockup + real clinic photo -->
  <SectionContainer width="default" spacing="md" background="paper-soft">
    <Breadcrumbs trail={[
      { label: 'Home', href: '/' },
      { label: 'Webster Technique in Mason, OH' },
    ]} />
    <div class="hero">
      <div class="hero-text">
        <h1>
          <span class="page-kicker">Webster Technique in Mason, OH</span>
          Pregnancy asks a lot of your pelvis.
        </h1>
        <p class="lede">
          The Webster Technique is a gentle, pregnancy-specific chiropractic adjustment
          that may help keep your pelvis balanced and comfortable, working alongside
          your OB or midwife the whole way.
        </p>
        <div class="hero-cta">
          <Button href={clinic.bookingUrl} variant="primary" size="lg" external iconAfter>Schedule a Prenatal Visit</Button>
          <Button href={`tel:${clinic.phoneTel}`} variant="ghost" size="lg">Call {clinic.phone}</Button>
        </div>
      </div>
      <div class="hero-image">
        <Image
          src={adultAdjustment}
          alt="Hands-on chiropractic adjustment at The Wellness Way - Mason"
          widths={[400, 600, 800, 1200]}
          sizes="(min-width: 768px) 42vw, 100vw"
          loading="eager"
          fetchpriority="high"
          quality={82}
        />
      </div>
    </div>
  </SectionContainer>

  <!-- Section 2: Empathy intro — validate before explaining -->
  <SectionContainer width="prose" spacing="md">
    <p class="intro-open" data-reveal>
      If you're pregnant and dealing with low back pain, hip discomfort, round ligament pain,
      or that deep ache in the back of the pelvis that shows up by the second trimester, you
      don't have to just wait it out. Discomfort in pregnancy is common, but common isn't the
      same as nothing-can-be-done.
    </p>
    <p class="intro-body" data-reveal="up-sm">
      At <strong>The Wellness Way - Mason</strong>, Dr. Ryan DeNome is a Doctor of Chiropractic
      certified in the Webster Technique, a chiropractic adjustment developed specifically for
      pregnant patients. Patients come to us from Mason, West Chester, Loveland, Lebanon, and
      across the greater Cincinnati area for prenatal care that works alongside their birth team.
    </p>
  </SectionContainer>

  <!-- Section 3: What it is / what it is not — two-column clarity moment -->
  <SectionContainer width="default" spacing="lg" background="paper-soft">
    <div class="section-head">
      <p class="eyebrow">Prenatal Chiropractic</p>
      <h2>What it is. And what it is not.</h2>
      <p class="value-line">
        A gentle pelvic-balancing adjustment, never a maneuver to turn a baby.
      </p>
    </div>
    <div class="duo">
      <div class="duo-col" data-reveal="up-sm">
        <h3 class="sub-h">What the Webster Technique is</h3>
        <p>
          A specific chiropractic analysis and adjustment of the pelvis. It looks at the
          sacrum (the triangular bone at the base of the spine), the muscles around it, and
          the ligaments that support the uterus, then works to gently ease tension and
          imbalance where it shows up. There's no twisting, no cracking, no forceful motion.
          You're positioned comfortably, with support for your belly, the whole time.
        </p>
        <p>
          The thinking is mechanical, not mysterious. Pregnancy loads the pelvis in new ways,
          and the ligaments soften and shift to make room. When one side pulls tighter than
          the other, that uneven tension may show up as discomfort, and it may constrain the
          space the uterus has to work with. Balancing the pelvis may help create more space
          and may help the body keep the symmetry it's designed to have.
        </p>
      </div>
      <div class="duo-col" data-reveal="up-sm">
        <h3 class="sub-h">What it is not</h3>
        <p>
          This matters, so we say it plainly: <strong>the Webster Technique is not a maneuver
          to turn a breech baby.</strong> You'll sometimes see it described that way online,
          and that description is wrong.
        </p>
        <p>
          It's a pelvic-balancing adjustment. The idea is that a balanced, low-tension pelvis
          may support optimal fetal positioning by leaving your baby room to move on its own.
          Turning a baby and managing breech presentation are your OB or midwife's domain,
          not ours. We stay in our lane and coordinate with yours.
        </p>
      </div>
    </div>
  </SectionContainer>

  <!-- Section 4: Who it's for + the visit + safety + birth team -->
  <SectionContainer width="prose" spacing="lg">
    <div class="article-block" data-reveal="up-sm">
      <h2>Who it's for</h2>
      <ul class="who-list" role="list">
        {whoFor.map((item) => (
          <li>
            <svg aria-hidden="true" width="15" height="15" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M2.5 8.5l3.5 3.5L13.5 4" /></svg>
            {item}
          </li>
        ))}
      </ul>
    </div>

    <div class="article-block" data-reveal="up-sm">
      <h2>What to expect at a visit</h2>
      <p>
        Your first visit starts with the story: how your pregnancy is going, what's
        uncomfortable, and what your birth team is managing. Dr. DeNome assesses pelvic
        balance and sacral alignment, then performs the gentle Webster adjustment if it's
        indicated. You're supported and comfortable throughout. Visits are short, typically
        20 to 30 minutes for an established prenatal patient, and we'll map out a schedule
        that fits your trimester and how you're feeling.
      </p>
      <div class="price-note">
        <p class="price-note-title">Simple, transparent pricing</p>
        <p class="price-note-body">
          Your first visit is a flat $99. Follow-up adjustments are $50, with soft tissue
          work included when it's indicated. No add-on menu, no mystery invoices.
        </p>
      </div>
    </div>

    <div class="article-block" data-reveal="up-sm">
      <h2>Is it safe?</h2>
      <p>
        The Webster Technique is a gentle, low-force adjustment designed for pregnancy,
        performed by a certified provider. There's no forceful twisting, and you're
        positioned with belly support. As with everything we do, we work alongside your OB
        or midwife and stay inside what's appropriate for your specific pregnancy. If
        anything about your pregnancy needs medical management, that stays with your
        physician. We're an additive layer of care, not a replacement for prenatal medical
        care.
      </p>
    </div>

    <div class="article-block" data-reveal="up-sm">
      <h2>How it fits into your birth team</h2>
      <p>
        Think of a Webster-certified chiropractor as one member of a complete birth team:
        your OB or midwife leads the medical care, and chiropractic care focuses on pelvic
        comfort and alignment alongside it. We're happy to coordinate with your providers,
        and we'll always defer to them on anything inside their scope. The goal is simple:
        a more comfortable pregnancy, and walking into your birth feeling supported.
      </p>
    </div>
  </SectionContainer>

  <!-- Section 5: FAQ (schema emitted from faqs array above) -->
  <SectionContainer width="prose" spacing="lg" background="paper-soft">
    <h2 class="faq-head">Frequently asked questions</h2>
    <div class="faq-list">
      {faqs.map((f) => (
        <details class="faq-item" data-reveal="up-sm">
          <summary>{f.q}</summary>
          <p>{f.a}</p>
        </details>
      ))}
    </div>
  </SectionContainer>

  <!-- Section 6: Closing reassurance + byline -->
  <SectionContainer width="prose" spacing="md">
    <div class="article-block" data-reveal="up-sm">
      <h2>You don't have to white-knuckle it</h2>
      <p>
        You don't have to wait out the aches, and you don't have to choose between your OB
        and a chiropractor. Pelvic comfort during pregnancy is something you can get real
        support for.
      </p>
      <p class="closing-line">
        <strong>Common is not normal. You have options. We're here when you're ready.</strong>
      </p>
      <p class="byline">{bylines.reviewed}, Doctor of Chiropractic, Webster Technique certified, {clinic.brandName}</p>
    </div>
  </SectionContainer>

  <!-- Section 7: Conversion moment -->
  <SectionContainer width="prose" spacing="lg" background="paper-warm-tint">
    <div class="closer-cta" data-reveal>
      <h2>Prenatal chiropractic in Mason, OH</h2>
      <p>
        Schedule a prenatal visit, or call with questions first. We see expecting patients
        from Mason, West Chester, Loveland, Lebanon, and the greater Cincinnati area. Your
        first visit is a flat $99.
      </p>
      <div class="cta-row">
        <Button href={clinic.bookingUrl} variant="primary" size="lg" external iconAfter>Schedule a Prenatal Visit</Button>
        <Button href={`tel:${clinic.phoneTel}`} variant="ghost" size="lg">Call {clinic.phone}</Button>
      </div>
    </div>
  </SectionContainer>
</BaseLayout>

<style>
  /* === Hero === */
  .hero {
    display: grid;
    gap: 2.5rem;
    align-items: center;
  }
  .hero h1 {
    margin: 0;
    font-size: var(--text-4xl);
    line-height: 1.1;
  }
  /* SEO keyword string stays inside the H1 as a kicker line; the display
     line underneath carries the visual headline. */
  .page-kicker {
    display: block;
    font-family: var(--font-body);
    font-size: var(--text-xs);
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--color-mute);
    font-weight: 500;
    margin: 0 0 1rem;
  }
  .lede {
    color: var(--color-ink-muted);
    font-size: var(--text-lg);
    line-height: 1.6;
    max-width: 56ch;
    margin: 1rem 0 1.75rem;
  }
  .hero-cta {
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
  }
  .hero-image img {
    width: 100%;
    aspect-ratio: 4 / 3;
    object-fit: cover;
    border-radius: var(--radius-xl);
    box-shadow: var(--shadow-card);
  }
  @media (min-width: 768px) {
    .hero {
      grid-template-columns: 1.2fr 1fr;
      gap: 3.5rem;
    }
    .hero h1 { font-size: var(--text-5xl); }
  }

  /* === Intro === */
  .intro-open {
    font-family: var(--font-display);
    font-size: var(--text-xl);
    line-height: 1.55;
    color: var(--color-ink-strong);
    margin: 0 0 1.25rem;
  }
  .intro-body {
    color: var(--color-ink);
    font-size: var(--text-lg);
    line-height: 1.7;
    margin: 0;
  }

  /* === Section head (centered, established scale) === */
  .section-head {
    margin-bottom: 3rem;
    text-align: center;
    max-width: 60ch;
    margin-left: auto;
    margin-right: auto;
  }
  .eyebrow {
    font-size: var(--text-xs);
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--color-mute);
    margin: 0 0 1rem;
    font-weight: 500;
  }
  /* Eyebrow lockup: short TWW Green rule turns the caps label into a
     composed unit (auto-centered under a centered head). */
  .section-head .eyebrow::after {
    content: "";
    display: block;
    width: 32px;
    height: 2px;
    background: var(--color-brand-primary);
    margin: 0.9rem auto 0;
  }
  .section-head h2 {
    margin: 0;
    font-size: var(--text-3xl);
    line-height: 1.15;
    color: var(--color-ink-strong);
  }
  .value-line {
    font-family: var(--font-display);
    font-style: italic;
    color: var(--color-brand-primary-dark);
    font-size: var(--text-lg);
    line-height: 1.5;
    margin: 1rem auto 0;
    max-width: 52ch;
  }
  @media (min-width: 768px) {
    .section-head h2 { font-size: var(--text-4xl); }
  }
  @media (min-width: 1024px) {
    .section-head { margin-bottom: 3.5rem; }
    .section-head h2 {
      font-size: var(--text-5xl);
      letter-spacing: -0.022em;
    }
  }

  /* === Duo (is / is not) === */
  .duo {
    display: grid;
    gap: 2.5rem;
    align-items: start;
    max-width: 68rem;
    margin: 0 auto;
  }
  .sub-h {
    font-family: var(--font-display);
    font-size: var(--text-xl);
    color: var(--color-ink-strong);
    font-weight: 500;
    margin: 0 0 1rem;
    padding-bottom: 0.5rem;
    border-bottom: 2px solid var(--color-brand-primary);
    display: inline-block;
  }
  .duo-col p {
    color: var(--color-ink);
    font-size: var(--text-lg);
    line-height: 1.7;
    margin: 0 0 1.1rem;
  }
  .duo-col p:last-child { margin-bottom: 0; }
  @media (min-width: 768px) {
    .duo {
      grid-template-columns: 1fr 1fr;
      gap: 4rem;
    }
    .duo-col:last-child {
      padding-left: 3rem;
      border-left: 1px solid var(--color-line);
    }
  }

  /* === Article blocks === */
  .article-block { margin: 0 0 3rem; }
  .article-block:last-child { margin-bottom: 0; }
  .article-block h2 {
    font-family: var(--font-display);
    font-size: var(--text-2xl);
    color: var(--color-ink-strong);
    margin: 0 0 1rem;
    line-height: 1.2;
  }
  .article-block p {
    color: var(--color-ink);
    font-size: var(--text-lg);
    line-height: 1.75;
    margin: 0 0 1.1rem;
  }
  .article-block p:last-child { margin-bottom: 0; }
  @media (min-width: 768px) {
    .article-block h2 { font-size: var(--text-3xl); }
  }

  /* === Who it's for check-list === */
  .who-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    gap: 0.85rem;
  }
  .who-list li {
    display: flex;
    align-items: flex-start;
    gap: 0.75rem;
    color: var(--color-ink);
    font-size: var(--text-lg);
    line-height: 1.55;
  }
  .who-list svg {
    color: var(--color-brand-primary-dark);
    flex-shrink: 0;
    margin-top: 0.4rem;
  }

  /* === Price note callout === */
  .price-note {
    margin-top: 1.75rem;
    padding: 1.5rem 1.75rem;
    border-radius: var(--radius-lg);
    border-left: 4px solid var(--color-brand-primary);
    background: var(--color-paper-soft);
  }
  .price-note-title {
    font-family: var(--font-display);
    font-size: var(--text-lg);
    color: var(--color-ink-strong);
    font-weight: 500;
    margin: 0 0 0.5rem;
  }
  .price-note-body {
    margin: 0;
    color: var(--color-ink);
    font-size: var(--text-base) !important;
    line-height: 1.6;
  }

  /* === FAQ === */
  .faq-head {
    font-family: var(--font-display);
    font-size: var(--text-2xl);
    color: var(--color-ink-strong);
    margin: 0 0 1.5rem;
  }
  @media (min-width: 768px) {
    .faq-head { font-size: var(--text-3xl); }
  }
  .faq-list { display: grid; gap: 0.5rem; margin: 0; }
  .faq-item {
    border: 1px solid var(--color-line);
    border-radius: var(--radius-md);
    padding: 1rem 1.25rem;
    background: var(--color-paper);
  }
  .faq-item summary {
    font-family: var(--font-display);
    font-weight: 600;
    color: var(--color-ink-strong);
    cursor: pointer;
    list-style: none;
  }
  .faq-item summary::-webkit-details-marker { display: none; }
  .faq-item summary::after {
    content: '+';
    float: right;
    font-size: 1.25rem;
    color: var(--color-brand-primary-dark);
  }
  .faq-item[open] summary::after { content: '\2212'; }
  .faq-item p {
    margin: 0.75rem 0 0;
    color: var(--color-ink-muted);
    line-height: 1.7;
  }

  /* === Closing + byline === */
  .closing-line {
    font-family: var(--font-display);
    font-size: var(--text-xl) !important;
    line-height: 1.5 !important;
    color: var(--color-ink-strong);
  }
  .closing-line strong { font-weight: 500; }
  .byline {
    margin: 2rem 0 0 !important;
    padding-top: 1rem;
    border-top: 1px solid var(--color-line);
    font-size: var(--text-sm) !important;
    color: var(--color-ink-muted);
    font-style: italic;
  }

  /* === Closer CTA === */
  .closer-cta { text-align: center; }
  .closer-cta h2 {
    margin: 0 0 1rem;
    font-size: var(--text-3xl);
    color: var(--color-ink-strong);
  }
  .closer-cta p {
    max-width: 52ch;
    margin: 0 auto 2rem;
    color: var(--color-ink-muted);
    line-height: 1.65;
    font-size: var(--text-lg);
  }
  .cta-row {
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
    justify-content: center;
  }
  @media (min-width: 768px) {
    .closer-cta h2 { font-size: var(--text-4xl); }
  }
</style>
