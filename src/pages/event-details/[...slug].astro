---
import { getCollection, render } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import SectionContainer from '../../components/SectionContainer.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import Button from '../../components/Button.astro';
import { clinic, site } from '../../lib/site';

export async function getStaticPaths() {
  const events = await getCollection('events');
  return events.map((event) => ({
    params: { slug: event.id },
    props: { event },
  }));
}

const { event } = Astro.props;
const { Content } = await render(event);

const eventSchema = {
  '@context': 'https://schema.org',
  '@type': 'Event',
  name: event.data.title,
  description: event.data.excerpt ?? '',
  ...(event.data.date ? { startDate: event.data.date.toISOString() } : {}),
  ...(event.data.endDate ? { endDate: event.data.endDate.toISOString() } : {}),
  eventAttendanceMode: 'https://schema.org/OfflineEventAttendanceMode',
  eventStatus: 'https://schema.org/EventScheduled',
  location: {
    '@type': 'Place',
    name: clinic.brandName,
    address: {
      '@type': 'PostalAddress',
      streetAddress: clinic.address.streetAddress,
      addressLocality: clinic.address.addressLocality,
      addressRegion: clinic.address.addressRegion,
      postalCode: clinic.address.postalCode,
      addressCountry: clinic.address.addressCountry,
    },
  },
  organizer: {
    '@type': 'Organization',
    name: clinic.brandName,
    url: site.url,
  },
  ...(event.data.image ? { image: [event.data.image] } : {}),
};
---

<BaseLayout
  title={event.data.title}
  description={event.data.excerpt ?? clinic.tagline}
  ogImage={event.data.image}
  jsonLd={[eventSchema]}
>
  <SectionContainer width="prose" spacing="md" background="paper-soft">
    <Breadcrumbs trail={[{ label: 'Home', href: '/' }, { label: 'Events', href: '/events' }, { label: event.data.title }]} />
  </SectionContainer>

  <SectionContainer width="prose" spacing="md">
    <h1>{event.data.title}</h1>
    {event.data.recurring && <p class="recurring-flag">Recurring event — multiple dates</p>}
    {event.data.image && (
      <img src={event.data.image} alt={event.data.imageAlt ?? event.data.title} class="event-image" />
    )}
    <div class="event-body">
      <Content />
    </div>
    {event.data.rsvpUrl && (
      <Button href={event.data.rsvpUrl} variant="primary" size="lg" external>RSVP</Button>
    )}
  </SectionContainer>
</BaseLayout>

<style>
  .recurring-flag {
    display: inline-block;
    background: var(--color-brand-primary-light);
    padding: 0.4rem 1rem;
    border-radius: var(--radius-pill);
    font-size: var(--text-sm);
    color: var(--color-ink-strong);
    margin: 0 0 1.5rem;
  }
  .event-image {
    width: 100%;
    max-height: 420px;
    object-fit: cover;
    border-radius: var(--radius-lg);
    margin: 1.5rem 0;
  }
  .event-body :global(p) { line-height: 1.7; margin: 1rem 0; }
  .event-body :global(h2), .event-body :global(h3) { margin-top: 2rem; }
  /* In-body CTA button — usable from markdown via <a class="event-cta">…</a>.
     Mirrors the primary Button component visually so markdown-authored events
     can place multiple CTAs without needing Astro component support. */
  .event-body :global(a.event-cta) {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.85rem 1.75rem;
    background: var(--color-brand-primary);
    color: var(--color-ink-strong);
    font-family: var(--font-display);
    font-size: var(--text-base);
    font-weight: 600;
    text-decoration: none;
    border-radius: var(--radius-pill);
    box-shadow: var(--shadow-card);
    margin: 1.5rem 0;
    transition: background 0.15s ease, transform 0.15s ease;
  }
  .event-body :global(a.event-cta:hover) {
    background: var(--color-brand-primary-dark);
    transform: translateY(-1px);
    color: var(--color-ink-strong);
  }
</style>
