---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import SectionContainer from '../components/SectionContainer.astro';
import Card from '../components/Card.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';
import Button from '../components/Button.astro';
import { clinic } from '../lib/site';

const allEvents = await getCollection('events');
const now = Date.now();

// Recurring gatherings always stay listed. One-off events move to
// "Recently hosted" once their date passes. NOTE: this check runs at
// build time, so the split refreshes on each site rebuild.
const upcoming = allEvents
  .filter((e) => e.data.recurring || (e.data.date?.getTime() ?? 0) >= now)
  .sort((a, b) => {
    if (a.data.recurring !== b.data.recurring) {
      return a.data.recurring ? -1 : 1;
    }
    return (a.data.date?.getTime() ?? 0) - (b.data.date?.getTime() ?? 0);
  });

const past = allEvents
  .filter((e) => !e.data.recurring && (e.data.date?.getTime() ?? 0) < now)
  .sort((a, b) => (b.data.date?.getTime() ?? 0) - (a.data.date?.getTime() ?? 0))
  .slice(0, 4);

const fmtDay = (d: Date) =>
  d.toLocaleDateString('en-US', {
    weekday: 'long',
    month: 'long',
    day: 'numeric',
    timeZone: 'America/New_York',
  });
const fmtShort = (d: Date) =>
  d.toLocaleDateString('en-US', {
    month: 'long',
    day: 'numeric',
    year: 'numeric',
    timeZone: 'America/New_York',
  });
---

<BaseLayout
  title="Events at The Wellness Way - Mason, OH"
  description={`Upcoming health events, workshops, and community gatherings at ${clinic.brandName}. Mason, OH.`}
>
  <SectionContainer width="default" spacing="md" background="paper-soft">
    <Breadcrumbs trail={[{ label: 'Home', href: '/' }, { label: 'Events' }]} />
    <div class="events-hero">
      <h1>
        <span class="page-kicker">Health Events &amp; Workshops in Mason, OH</span>
        Learn alongside people who get it.
      </h1>
      <p class="lede">
        Book studies, workshops, and pop-up adjustments around Mason and the greater
        Cincinnati area. Free or low-cost, always welcoming, never preachy.
      </p>
    </div>
  </SectionContainer>

  <SectionContainer width="prose" spacing="md">
    <div class="framing">
      <p data-reveal>
        The clinical work happens one patient at a time. The bigger conversation, the one
        about how to actually feel well in a culture that sells sickness, needs more than
        a treatment room. That's what these events are for.
      </p>
      <p data-reveal="up-sm">
        We host gatherings at <strong>The Wellness Way - Mason</strong> for moms, families,
        and anyone in the Cincinnati area who would rather learn in good company than piece
        it together alone: book studies, workshops, pop-up adjustments at partner spaces,
        and the occasional community open house. Sit in a room of people asking the same
        questions you are, and you find out something the internet can't tell you.
        You're not alone.
      </p>
      <h2 class="sub-h" data-reveal="up-sm">What you'll find here</h2>
      <p data-reveal="up-sm">
        The <strong>Cincy Crunchy Book Study</strong> runs monthly: a recurring gathering
        for health-curious moms and friends, no homework required, no judgment either.
        Around it you'll find <strong>pop-up clinic events</strong> at local studios, gyms,
        and community spaces across Mason, West Chester, Loveland, and greater Cincinnati.
        <strong>Educational workshops</strong> cover the topics patients ask about most:
        hormones, thyroid, gut health, kids' immune support, and prenatal chiropractic.
      </p>
      <p data-reveal="up-sm">
        <strong>Want to host a Wellness Way event at your studio, gym, or community space?</strong>
        We're open to partnerships. <a href="/contact">Reach out</a> and we'll figure out
        what makes sense.
      </p>
    </div>
  </SectionContainer>

  <SectionContainer width="default" spacing="lg">
    <div class="section-head" data-reveal>
      <h2>On the calendar.</h2>
      {upcoming.length > 0 && (
        <p class="section-lede">
          Tap through for dates, directions, and how to save your seat.
        </p>
      )}
    </div>
    {upcoming.length === 0 ? (
      <div class="empty-state" data-reveal="up-sm">
        <p class="empty-title">Nothing scheduled right now.</p>
        <p class="empty-body">
          Events here run in seasons, and the next one is usually already taking shape.
          If there's a topic you want covered, <a href="/contact">tell us</a>. Good
          gatherings usually start with someone asking.
        </p>
      </div>
    ) : (
      <div class="event-grid" data-reveal="up-sm">
        {upcoming.map((event) => (
          <Card
            href={`/event-details/${event.id}`}
            image={event.data.image}
            imageAlt={event.data.imageAlt ?? event.data.title}
            title={event.data.title}
            eyebrow={event.data.recurring ? 'Recurring' : undefined}
          >
            {event.data.date && (
              <p class="event-meta">
                {event.data.recurring ? `Next: ${fmtDay(event.data.date)}` : fmtDay(event.data.date)}
              </p>
            )}
            <p class="event-excerpt">{event.data.excerpt ?? ''}</p>
            <span slot="footer" class="event-cta">View details →</span>
          </Card>
        ))}
      </div>
    )}
    {past.length > 0 && (
      <div class="past-block" data-reveal="up-sm">
        <h3 class="sub-h">Recently hosted</h3>
        <ul class="past-list">
          {past.map((event) => (
            <li>
              <a href={`/event-details/${event.id}`}>{event.data.title}</a>
              {event.data.date && <span class="past-date">{fmtShort(event.data.date)}</span>}
            </li>
          ))}
        </ul>
      </div>
    )}
  </SectionContainer>

  <SectionContainer width="narrow" spacing="lg" background="paper-soft">
    <div class="events-cta" data-reveal>
      <h2>Bring us to your people.</h2>
      <p>
        Studio, gym, mom group, or a living room full of curious friends: if your community
        wants a workshop or a pop-up, we're glad to come teach. Topic requests are welcome
        too. Tell us what you're thinking.
      </p>
      <Button href="/contact" variant="primary" size="lg" iconAfter>Get in touch</Button>
    </div>
  </SectionContainer>
</BaseLayout>

<style>
  /* === Hero lockup === */
  .events-hero h1 {
    margin: 0;
    font-size: var(--text-4xl);
    line-height: 1.1;
    max-width: 22ch;
  }
  /* SEO keyword string stays inside the H1 as a kicker line; the display
     line underneath carries the visual headline. */
  .page-kicker {
    display: block;
    font-family: var(--font-body);
    font-size: var(--text-xs);
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--color-mute);
    font-weight: 500;
    margin: 0 0 1rem;
  }
  .lede {
    color: var(--color-ink-muted);
    max-width: 60ch;
    font-size: var(--text-lg);
    margin: 1rem 0 0;
    line-height: 1.55;
  }

  /* === Framing prose === */
  .framing p {
    margin: 0 0 1.25rem;
    color: var(--color-ink);
    font-size: var(--text-lg);
    line-height: 1.7;
  }
  .framing p:last-child { margin-bottom: 0; }
  .sub-h {
    font-family: var(--font-display);
    font-size: var(--text-xl);
    color: var(--color-ink-strong);
    font-weight: 500;
    margin: 2.25rem 0 1rem;
    padding-bottom: 0.5rem;
    border-bottom: 2px solid var(--color-brand-primary);
    display: inline-block;
  }

  /* === Section head (established scale) === */
  .section-head {
    margin-bottom: 3rem;
    text-align: center;
    max-width: 60ch;
    margin-left: auto;
    margin-right: auto;
  }
  .section-head h2 {
    margin: 0 0 1rem;
    font-size: var(--text-3xl);
    color: var(--color-ink-strong);
  }
  .section-lede {
    color: var(--color-ink-muted);
    font-size: var(--text-lg);
    margin: 0;
    line-height: 1.6;
  }

  /* === Event grid === */
  .event-grid {
    display: grid;
    gap: 1.5rem;
    grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
  }
  .event-meta {
    margin: 0;
    color: var(--color-brand-primary-dark);
    font-size: var(--text-sm);
    font-weight: 500;
  }
  .event-excerpt {
    color: var(--color-ink-muted);
    margin: 0;
    line-height: 1.55;
  }
  .event-cta {
    color: var(--color-brand-primary-dark);
    font-weight: 600;
  }

  /* === Empty state === */
  .empty-state {
    text-align: center;
    background: var(--color-paper-soft);
    border: 1px solid var(--color-line);
    border-radius: var(--radius-lg);
    padding: 3rem 2rem;
    max-width: 36rem;
    margin: 0 auto;
  }
  .empty-title {
    font-family: var(--font-display);
    font-size: var(--text-2xl);
    color: var(--color-ink-strong);
    margin: 0 0 0.75rem;
  }
  .empty-body {
    color: var(--color-ink-muted);
    line-height: 1.65;
    margin: 0;
  }

  /* === Recently hosted === */
  .past-block {
    max-width: 44rem;
    margin: 4rem auto 0;
  }
  .past-list {
    list-style: none;
    margin: 0;
    padding: 0;
  }
  .past-list li {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    gap: 1rem;
    flex-wrap: wrap;
    padding: 0.9rem 0;
    border-bottom: 1px solid var(--color-line);
  }
  .past-list li:last-child { border-bottom: none; }
  .past-list a {
    font-family: var(--font-display);
    font-size: var(--text-lg);
    color: var(--color-ink-strong);
  }
  .past-list a:hover { color: var(--color-brand-primary-dark); }
  .past-date {
    color: var(--color-mute);
    font-size: var(--text-sm);
    white-space: nowrap;
  }

  /* === Host CTA === */
  .events-cta { text-align: center; }
  .events-cta h2 {
    margin: 0 0 1rem;
    font-size: var(--text-3xl);
  }
  .events-cta p {
    color: var(--color-ink-muted);
    max-width: 50ch;
    margin: 0 auto 2rem;
    line-height: 1.65;
  }

  /* === Responsive scale ramp === */
  @media (min-width: 768px) {
    .events-hero h1 { font-size: var(--text-5xl); }
    .section-head h2 { font-size: var(--text-4xl); }
    .events-cta h2 { font-size: var(--text-4xl); }
  }
  @media (min-width: 1024px) {
    .section-head h2 {
      font-size: var(--text-5xl);
      letter-spacing: -0.022em;
    }
  }
</style>
