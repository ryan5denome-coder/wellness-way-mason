---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import SectionContainer from '../components/SectionContainer.astro';
import Card from '../components/Card.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';
import Button from '../components/Button.astro';
import { clinic } from '../lib/site';

const events = (await getCollection('events')).sort((a, b) => {
  // Recurring events first, then by date
  if (a.data.recurring !== b.data.recurring) {
    return a.data.recurring ? -1 : 1;
  }
  const da = a.data.date?.getTime() ?? 0;
  const db = b.data.date?.getTime() ?? 0;
  return db - da;
});
---

<BaseLayout
  title="Events at The Wellness Way - Mason, OH"
  description={`Upcoming health events, workshops, and community gatherings at ${clinic.brandName}. Mason, OH.`}
>
  <SectionContainer width="default" spacing="md" background="paper-soft">
    <Breadcrumbs trail={[{ label: 'Home', href: '/' }, { label: 'Events' }]} />
    <h1>Upcoming Events</h1>
    <p class="lede">Workshops, book studies, and community gatherings. Stay connected, get empowered.</p>
  </SectionContainer>

  <SectionContainer width="prose" spacing="md">
    <p>
      The clinical work happens one patient at a time. The bigger conversation — the one about
      how to actually feel well in a culture that sells sickness — needs more than a treatment
      room. That's what events are for.
    </p>
    <p>
      We host gatherings at <strong>The Wellness Way - Mason</strong> for moms, families, and
      anyone in the Cincinnati area who wants to learn alongside other people instead of going
      it alone. Book studies, workshops, pop-up adjustments at partner spaces, and the
      occasional community open house. Free or low-cost, always welcoming, never preachy.
    </p>
    <h2>What you'll find here</h2>
    <ul>
      <li>
        <strong>Recurring community gatherings</strong> like the Cincy Crunchy Book Study —
        a monthly book club for health-curious moms and friends, no homework, no judgment.
      </li>
      <li>
        <strong>Pop-up clinic events</strong> at local wellness studios, gyms, and community
        spaces around Mason, West Chester, Loveland, and the greater Cincinnati area.
      </li>
      <li>
        <strong>Educational workshops</strong> on topics patients ask about most: hormones,
        thyroid, gut health, kids' immune support, prenatal chiropractic.
      </li>
    </ul>
    <p>
      <strong>Want to host a Wellness Way event at your studio, gym, or community space?</strong>
      We're open to partnerships. <a href="/contact">Reach out</a> and we'll figure out what
      makes sense.
    </p>
  </SectionContainer>

  <SectionContainer width="default" spacing="md">
    {events.length === 0 ? (
      <p>No events scheduled right now. Check back soon, or <a href="/contact">contact us</a> to suggest a topic.</p>
    ) : (
      <div class="event-grid">
        {events.map((event) => (
          <Card
            href={`/event-details/${event.id}`}
            image={event.data.image}
            imageAlt={event.data.imageAlt ?? event.data.title}
            title={event.data.title}
            eyebrow={event.data.recurring ? 'Recurring' : undefined}
          >
            <p class="event-excerpt">{event.data.excerpt ?? ''}</p>
            <span slot="footer" class="event-cta">View details →</span>
          </Card>
        ))}
      </div>
    )}
  </SectionContainer>

  <SectionContainer width="narrow" spacing="lg" background="paper-soft">
    <div class="events-cta">
      <h2>Want to host or suggest an event?</h2>
      <p>We're always open to community partnerships and topic requests.</p>
      <Button href="/contact" variant="ghost" size="md">Get in touch</Button>
    </div>
  </SectionContainer>
</BaseLayout>

<style>
  .lede {
    color: var(--color-ink-muted);
    max-width: 60ch;
    font-size: var(--text-lg);
    margin: 1rem 0 0;
  }
  .event-grid {
    display: grid;
    gap: 1.5rem;
    grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
  }
  .event-excerpt {
    color: var(--color-ink-muted);
    margin: 0;
    line-height: 1.55;
  }
  .event-cta {
    color: var(--color-brand-primary-dark);
    font-weight: 600;
  }
  .events-cta { text-align: center; }
  .events-cta h2 { margin: 0 0 1rem; }
  .events-cta p { color: var(--color-ink-muted); max-width: 50ch; margin: 0 auto 1.5rem; }
</style>
