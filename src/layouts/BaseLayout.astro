---
import '../styles/global.css';
import { clinic, site } from '../lib/site';
import { jsonLdString, localBusiness, personSchema } from '../lib/schema';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import PageLoader from '../components/PageLoader.astro';

interface Props {
  title: string;
  description?: string;
  ogImage?: string;
  noIndex?: boolean;
  /**
   * Optional extra JSON-LD blocks (Article, Person, BreadcrumbList, FAQPage,
   * etc.). LocalBusiness is always emitted on every page.
   */
  jsonLd?: Array<Record<string, unknown>>;
  /** Skip the global LocalBusiness schema if a more specific schema is on this page. */
  skipDefaultSchema?: boolean;
}

const {
  title,
  description = clinic.tagline,
  ogImage = site.defaultOgImage,
  noIndex = false,
  jsonLd = [],
  skipDefaultSchema = false,
} = Astro.props;

// Append the parent brand "The Wellness Way" (not the full local franchise
// name "The Wellness Way - Mason") to stay under Semrush/Google's 70-char
// title cap. "Mason" appears in the body of most page titles already, plus
// the header, footer, JSON-LD, and OG image — local geo signal is preserved.
const fullTitle =
  title.includes(clinic.brandName) || /\bThe Wellness Way\b/i.test(title)
    ? title
    : `${title} | The Wellness Way`;
const canonicalPath = Astro.url.pathname
  .replace(/\/index\.html$/, '/')
  .replace(/\.html$/, '');
const canonical = new URL(canonicalPath, site.url).toString();
const ogImageUrl = ogImage.startsWith('http') ? ogImage : new URL(ogImage, site.url).toString();

// Default schema on every page: LocalBusiness + Person (Dr. DeNome).
// E-E-A-T fix per 2026-05-19 competitive audit — Brenner's /about/ and
// /meet-our-team/ both 404 with no Person schema, leaving Google's medical
// YMYL author-identity signal unfulfilled. Emitting Person on every page
// (via shared @id = ${site.url}/#owner) gives Google a stable, dedupe-able
// author entity across every URL on the site. The full Person entity lives
// on /about-us via personSchema({full: true}); everywhere else uses the
// reference-only form.
// The reference-only personSchema (full: false) intentionally omits @context
// because it's also used nested as `author` inside articleSchema. When emitted
// as its OWN standalone <script> block here, it needs @context to be a valid
// top-level JSON-LD object (Manus audit 1.4 / Semrush). Spread it with @context
// prepended so the standalone block parses while the nested usage stays clean.
const personRef = { '@context': 'https://schema.org', ...personSchema({ full: false }) };
const allJsonLd = skipDefaultSchema
  ? jsonLd
  : [localBusiness(), personRef, ...jsonLd];
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta http-equiv="X-UA-Compatible" content="IE=edge" />

    <title>{fullTitle}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />

    {noIndex && <meta name="robots" content="noindex, nofollow" />}

    <!-- OpenGraph -->
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content={clinic.brandName} />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:locale" content="en_US" />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={fullTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageUrl} />

    <!-- Favicons -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="alternate icon" href="/favicon.ico" />

    <!-- Brand fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Lora:ital,wght@0,400;0,500;0,600;0,700;1,400;1,500&display=swap"
    />

    <!-- Sitemap + RSS -->
    <link rel="sitemap" type="application/xml" href="/sitemap-index.xml" />
    <link rel="alternate" type="application/rss+xml" title={`${clinic.brandName} Blog`} href="/rss.xml" />

    <!-- JSON-LD: LocalBusiness + page-specific schema -->
    {allJsonLd.map((block) => (
      <script type="application/ld+json" set:html={jsonLdString(block)} />
    ))}

    <slot name="head" />
  </head>
  <body>
    <PageLoader />
    <a href="#main" class="skip-link">Skip to main content</a>
    <Header />
    <main id="main">
      <slot />
    </main>
    <Footer />
    <script>
      import Lenis from 'lenis';

      // Respect reduced-motion users — disable smooth scroll + reveals
      const prefersReduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

      // === Lenis smooth scroll ===
      if (!prefersReduced) {
        const lenis = new Lenis({
          duration: 1.05,
          easing: (t) => Math.min(1, 1.001 - Math.pow(2, -10 * t)), // exponential ease-out
          smoothWheel: true,
        });
        function raf(time: number) {
          lenis.raf(time);
          requestAnimationFrame(raf);
        }
        requestAnimationFrame(raf);
      }

      // === Scroll-reveal observer ===
      // Auto-applies `.is-visible` class to elements with `data-reveal`,
      // or to common section primitives so we don't have to mark up every page.
      const REVEAL_SELECTORS = [
        '[data-reveal]',
        '.section-head',
        '.t-row',
        '.atmosphere-card',
        '.steps li',
        '.expertise-grid > *',
        '.post-grid > *',
        '.provider-teaser',
        '.lab-feature',
        '.our-space',
        '.services-hero',
      ];

      function setupReveals() {
        const targets = document.querySelectorAll<HTMLElement>(REVEAL_SELECTORS.join(','));

        if (prefersReduced) {
          targets.forEach((el) => el.classList.add('is-visible'));
          return;
        }

        if (!('IntersectionObserver' in window)) {
          targets.forEach((el) => el.classList.add('is-visible'));
          return;
        }

        const io = new IntersectionObserver(
          (entries) => {
            entries.forEach((entry) => {
              if (entry.isIntersecting) {
                entry.target.classList.add('is-visible');
                io.unobserve(entry.target);
              }
            });
          },
          { rootMargin: '0px 0px -8% 0px', threshold: 0.08 }
        );

        targets.forEach((el) => {
          // Mark as reveal target so Agent 2's CSS hooks in
          el.classList.add('reveal');
          io.observe(el);
        });
      }

      if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', setupReveals);
      } else {
        setupReveals();
      }
    </script>
  </body>
</html>
