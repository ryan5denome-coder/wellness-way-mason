---
/**
 * TestimonialCard — note the source flag (composite / signed-consent) which
 * is required by Ohio compliance (OAC 4734-9-02(Q)). Composite testimonials
 * must NOT include real patient names or identifiers.
 */
interface Props {
  quote: string;
  attribution: string;
  condition?: string;
  source: 'composite' | 'signed-consent';
}

const { quote, attribution, condition, source } = Astro.props;

// Composite testimonials display a generic attribution (e.g., "Patient, Mason OH")
// — never a name + identifying detail combination.
const isComposite = source === 'composite';
---

<figure class="testimonial">
  <blockquote class="testimonial-quote">
    <p>{quote}</p>
  </blockquote>
  <figcaption class="testimonial-attribution">
    <span class="attribution-name">{attribution}</span>
    {condition && <span class="attribution-condition">— {condition}</span>}
    {isComposite && <span class="composite-flag" title="Composite — combines multiple patient experiences. No identifying details.">Composite</span>}
  </figcaption>
</figure>

<style>
  .testimonial {
    background: var(--color-paper);
    border-radius: var(--radius-lg);
    padding: 2rem;
    box-shadow: var(--shadow-card);
    margin: 0;
    position: relative;
    border-top: 4px solid var(--color-brand-primary);
  }
  .testimonial-quote {
    margin: 0 0 1rem;
    color: var(--color-ink);
    font-family: var(--font-display);
    font-size: var(--text-lg);
    line-height: 1.55;
    font-style: italic;
  }
  .testimonial-quote p {
    margin: 0;
  }
  .testimonial-quote::before {
    content: "\201C";
    display: block;
    font-size: var(--text-5xl);
    line-height: 0.8;
    color: var(--color-brand-primary);
    height: 1rem;
    margin-bottom: 0.5rem;
  }
  .testimonial-attribution {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    align-items: center;
    color: var(--color-ink-muted);
    font-size: var(--text-sm);
  }
  .attribution-name {
    font-weight: 600;
    color: var(--color-ink);
    font-style: normal;
  }
  .attribution-condition { color: var(--color-mute); }
  .composite-flag {
    background: var(--color-paper-tint);
    color: var(--color-ink-muted);
    border-radius: var(--radius-pill);
    padding: 0.15rem 0.6rem;
    font-size: var(--text-xs);
    font-weight: 500;
    border: 1px solid var(--color-line);
    cursor: help;
  }
</style>
