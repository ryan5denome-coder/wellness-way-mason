---
/**
 * SectionContainer — structural wrapper.
 * Soft UI Evolution: generous spacing, subtle background variation for visual flow.
 *
 * Background tokens:
 *   paper (white) — primary
 *   paper-soft (off-white) — alternating sections
 *   paper-warm (TWW Beige) — warmth accent (use sparingly, like Oura's "Why Oura")
 *   paper-warm-tint (pale beige) — subtler warmth
 *   paper-cool (pale grey) — neutral accent
 *   ink (TWW Dark Grey) — inverted, for hero/CTA breaks
 *   brand (TWW Green) — high-impact accent
 *   transparent — no background
 */
interface Props {
  width?: 'narrow' | 'default' | 'wide' | 'prose';
  background?: 'paper' | 'paper-soft' | 'paper-warm' | 'paper-warm-tint' | 'paper-cool' | 'ink' | 'brand' | 'transparent';
  spacing?: 'sm' | 'md' | 'lg' | 'xl' | 'hero';
  id?: string;
  ariaLabel?: string;
  as?: 'section' | 'article' | 'div' | 'aside';
  edgeTreatment?: 'none' | 'top-fade' | 'bottom-fade';
}

const {
  width = 'default',
  background = 'paper',
  spacing = 'lg',
  id,
  ariaLabel,
  as = 'section',
  edgeTreatment = 'none',
} = Astro.props;

const Tag = as;
const classes = ['section', `bg-${background}`, `space-${spacing}`, `edge-${edgeTreatment}`].join(' ');
const innerClass = `inner inner-${width}`;
---

<Tag class={classes} id={id} aria-label={ariaLabel}>
  <div class={innerClass}>
    <slot />
  </div>
</Tag>

<style>
  .section { width: 100%; }

  .bg-paper { background: var(--color-paper); color: var(--color-ink); }
  .bg-paper-soft { background: var(--color-paper-soft); color: var(--color-ink); }
  .bg-paper-warm { background: var(--color-paper-warm); color: var(--color-ink-strong); }
  .bg-paper-warm-tint { background: var(--color-paper-warm-tint); color: var(--color-ink); }
  .bg-paper-cool { background: var(--color-paper-cool); color: var(--color-ink); }
  .bg-ink { background: var(--color-ink-strong); color: var(--color-paper); }
  .bg-brand { background: var(--color-brand-primary); color: var(--color-ink-strong); }
  .bg-transparent { background: transparent; }

  /* Soft UI Evolution spacing (more generous than v1) */
  .space-sm { padding: 2.25rem 1.25rem; }
  .space-md { padding: 3.5rem 1.25rem; }
  .space-lg { padding: 5rem 1.25rem; }
  .space-xl { padding: 6.5rem 1.25rem; }
  .space-hero { padding: 5rem 1.25rem 4rem; }

  .inner {
    margin: 0 auto;
    width: 100%;
  }
  .inner-narrow { max-width: var(--container-narrow); }
  .inner-default { max-width: var(--container-default); }
  .inner-wide { max-width: var(--container-wide); }
  .inner-prose { max-width: var(--container-prose); }

  @media (min-width: 768px) {
    .space-sm { padding: 3.5rem 2rem; }
    .space-md { padding: 5rem 2rem; }
    .space-lg { padding: 7rem 2rem; }
    .space-xl { padding: 9rem 2rem; }
    .space-hero { padding: 7.5rem 2rem 6rem; }
  }
  @media (min-width: 1024px) {
    .space-hero { padding: 9rem 2rem 7rem; }
  }
</style>
