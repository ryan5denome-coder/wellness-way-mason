---
import { clinic } from '../lib/site';
import Button from './Button.astro';

const navItems = [
  { label: 'Home', href: '/' },
  { label: 'About', href: '/about-us' },
  { label: 'Services', href: '/our-services' },
  { label: 'Pricing', href: '/pricing' },
  { label: 'Blog', href: '/blog' },
  { label: 'Contact', href: '/contact' },
];

const currentPath = Astro.url.pathname.replace(/\/$/, '') || '/';
---

<div class="header-scroll-sentinel" aria-hidden="true"></div>
<header class="site-header" role="banner">
  <div class="header-inner">
    <a href="/" class="brand" aria-label={`${clinic.brandName} home`}>
      <svg
        class="brand-mark"
        width="14"
        height="14"
        viewBox="0 0 24 24"
        fill="currentColor"
        aria-hidden="true"
        xmlns="http://www.w3.org/2000/svg"
      >
        <path d="M20.5 11H19V7c0-1.1-.9-2-2-2h-4V3.5C13 2.12 11.88 1 10.5 1S8 2.12 8 3.5V5H4c-1.1 0-1.99.9-1.99 2v3.8H3.5c1.49 0 2.7 1.21 2.7 2.7s-1.21 2.7-2.7 2.7H2V20c0 1.1.9 2 2 2h3.8v-1.5c0-1.49 1.21-2.7 2.7-2.7s2.7 1.21 2.7 2.7V22H17c1.1 0 2-.9 2-2v-4h1.5c1.38 0 2.5-1.12 2.5-2.5S21.88 11 20.5 11z"/>
      </svg>
      <span class="brand-name">{clinic.brandName}</span>
    </a>

    <button
      class="menu-toggle"
      aria-expanded="false"
      aria-controls="primary-nav"
      aria-label="Toggle menu"
    >
      <span class="menu-bar"></span>
      <span class="menu-bar"></span>
      <span class="menu-bar"></span>
    </button>

    <nav id="primary-nav" class="primary-nav" aria-label="Primary">
      <ul>
        {navItems.map((item) => {
          const itemPath = item.href.replace(/\/$/, '') || '/';
          const isActive = currentPath === itemPath ||
            (itemPath !== '/' && currentPath.startsWith(itemPath));
          return (
            <li>
              <a href={item.href} aria-current={isActive ? 'page' : undefined}>
                {item.label}
              </a>
            </li>
          );
        })}
      </ul>
    </nav>

    <div class="header-cta">
      <Button href={clinic.bookingUrl} variant="primary" size="sm" external={true}>
        Book Appointment
      </Button>
    </div>
  </div>
</header>

<script is:inline>
  document.addEventListener('DOMContentLoaded', () => {
    const toggle = document.querySelector('.menu-toggle');
    const nav = document.getElementById('primary-nav');
    if (toggle && nav) {
      toggle.addEventListener('click', () => {
        const expanded = toggle.getAttribute('aria-expanded') === 'true';
        toggle.setAttribute('aria-expanded', String(!expanded));
        nav.classList.toggle('open');
      });
    }

    // Scroll acknowledgment: once the top sentinel leaves the viewport the
    // header gains a soft shadow (pre-rendered on ::after, crossfaded via
    // opacity — never transitioning box-shadow). IntersectionObserver, no
    // scroll listener.
    const sentinel = document.querySelector('.header-scroll-sentinel');
    const header = document.querySelector('.site-header');
    if (sentinel && header && 'IntersectionObserver' in window) {
      const io = new IntersectionObserver(
        ([entry]) => header.classList.toggle('is-scrolled', !entry.isIntersecting),
        { threshold: 0 }
      );
      io.observe(sentinel);
    }
  });
</script>

<style>
  .header-scroll-sentinel {
    position: absolute;
    top: 0;
    left: 0;
    width: 1px;
    height: 8px;
    pointer-events: none;
  }
  .site-header {
    border-bottom: 1px solid var(--color-line);
    background: rgba(255, 255, 255, 0.92);
    backdrop-filter: saturate(180%) blur(12px);
    -webkit-backdrop-filter: saturate(180%) blur(12px);
    position: sticky;
    top: 0;
    z-index: 50;
    transition: border-color var(--duration-normal) var(--ease-soft);
  }
  .site-header::after {
    content: "";
    position: absolute;
    inset: 0;
    pointer-events: none;
    box-shadow: 0 8px 24px -12px rgba(31, 34, 34, 0.18);
    opacity: 0;
    transition: opacity var(--duration-normal) var(--ease-soft);
  }
  .site-header.is-scrolled { border-bottom-color: transparent; }
  .site-header.is-scrolled::after { opacity: 1; }
  .header-inner {
    max-width: var(--container-default);
    margin: 0 auto;
    padding: 1rem 1.5rem;
    display: flex;
    align-items: center;
    gap: 2rem;
  }
  .brand {
    text-decoration: none;
    color: var(--color-ink-strong);
    font-family: var(--font-display);
    font-size: var(--text-base);
    font-weight: 600;
    margin-right: auto;
    line-height: 1.1;
    display: inline-flex;
    align-items: center;
    gap: 0.65rem;
    letter-spacing: -0.005em;
  }
  .brand-mark {
    display: inline-block;
    width: 14px;
    height: 14px;
    color: var(--color-brand-primary);
    flex-shrink: 0;
  }
  .brand:hover { color: var(--color-brand-primary-dark); }

  .menu-toggle {
    display: flex;
    flex-direction: column;
    gap: 4px;
    background: transparent;
    border: 1px solid var(--color-line);
    border-radius: var(--radius-md);
    padding: 0.5rem;
    cursor: pointer;
  }
  .menu-bar {
    width: 22px;
    height: 2px;
    background: var(--color-ink);
    border-radius: 2px;
  }

  .primary-nav ul {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    gap: 2rem;
  }
  .primary-nav a {
    text-decoration: none;
    color: var(--color-ink);
    font-size: var(--text-sm);
    font-weight: 500;
    padding: 0.5rem 0;
    border-bottom: 2px solid transparent;
    transition: all var(--duration-fast) var(--ease-soft);
    position: relative;
  }
  .primary-nav a:hover {
    color: var(--color-brand-primary-dark);
  }
  .primary-nav a[aria-current="page"] {
    color: var(--color-ink-strong);
    border-bottom-color: var(--color-brand-primary);
  }

  .header-cta { display: flex; }

  @media (max-width: 900px) {
    .menu-toggle { display: flex; }
    .primary-nav {
      display: none;
      position: absolute;
      top: 100%;
      left: 0;
      right: 0;
      background: var(--color-paper);
      border-bottom: 1px solid var(--color-line);
      box-shadow: var(--shadow-card);
    }
    .primary-nav.open { display: block; }
    .primary-nav ul {
      flex-direction: column;
      gap: 0;
      padding: 1rem 0;
    }
    .primary-nav li {
      width: 100%;
    }
    .primary-nav a {
      display: block;
      padding: 0.85rem 1.5rem;
      border-bottom: none;
      border-left: 3px solid transparent;
    }
    .primary-nav a[aria-current="page"] {
      border-bottom: none;
      border-left-color: var(--color-brand-primary);
      background: var(--color-paper-soft);
    }
  }
  @media (min-width: 901px) {
    .menu-toggle { display: none; }
  }
  @media (max-width: 767px) {
    /* Booking moves to the sticky bottom bar on phones — hiding the header
       CTA declutters the cramped mobile header. */
    .header-cta { display: none; }
  }
  @media (max-width: 480px) {
    .header-inner {
      gap: 0.75rem;
      padding: 0.75rem 1rem;
    }
  }
</style>
