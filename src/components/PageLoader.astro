---
/**
 * PageLoader — full-screen brand loader shown once per browser session on
 * first page load. The Wellness Way logo (puzzle pieces + wordmark) fades
 * in with a soft scale + bounce, holds briefly, then fades out and unblocks
 * the page.
 *
 * Design rules:
 *  - Shows only on first visit per session (sessionStorage gate)
 *  - Skips entirely when prefers-reduced-motion: reduce (immediate hide)
 *  - Caps at ~1100ms total so we never block content on a return visit
 *  - anime.js loaded only on the first paint of the session
 *  - Brand-cream background so it doesn't feel like a hard interruption
 *
 * Wired in BaseLayout.astro at the very top of the body so the overlay
 * paints before page content hydrates.
 */
---

<div id="page-loader" class="page-loader" aria-hidden="true">
  <div class="loader-inner">
    <img
      class="loader-logo"
      src="/images/brand/tww-logo.png"
      alt=""
      width="640"
      height="240"
      fetchpriority="high"
      decoding="sync"
    />
  </div>
</div>

<script>
  import { animate, createTimeline, utils } from 'animejs';

  const KEY = 'tww-mason-loader-shown';
  const loader = document.getElementById('page-loader');
  const logo = loader?.querySelector('.loader-logo') as HTMLImageElement | null;

  if (loader && logo) {
    const alreadyShown = sessionStorage.getItem(KEY) === '1';
    const prefersReduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

    if (alreadyShown || prefersReduce) {
      loader.style.display = 'none';
    } else {
      sessionStorage.setItem(KEY, '1');

      // Set initial state via inline styles (paints before anime takes over)
      logo.style.opacity = '0';
      logo.style.transform = 'scale(0.7) translateY(20px)';

      const timeline = createTimeline({
        onComplete: () => {
          animate(loader, {
            opacity: 0,
            duration: 380,
            ease: 'inQuad',
            onComplete: () => { loader.style.display = 'none'; },
          });
        },
      });

      // Logo: fade in + scale up + settle with a soft bounce
      timeline.add(logo, {
        opacity: 1,
        scale: 1,
        translateY: 0,
        duration: 700,
        ease: 'outBack(1.2)',
      });

      // Hold for a beat so the brand actually registers
      timeline.add(logo, {
        scale: [1, 1.025, 1],
        duration: 360,
        ease: 'inOutQuad',
      });
    }
  }

  // Safety net: if anything goes wrong, never let the loader block the page > 3s
  setTimeout(() => {
    if (loader && loader.style.display !== 'none') {
      loader.style.transition = 'opacity 250ms ease';
      loader.style.opacity = '0';
      setTimeout(() => { loader.style.display = 'none'; }, 280);
    }
  }, 3000);
</script>

<style>
  .page-loader {
    position: fixed;
    inset: 0;
    z-index: 9999;
    background: var(--color-paper-soft, #fafaf9);
    display: flex;
    align-items: center;
    justify-content: center;
    pointer-events: auto;
  }

  .loader-inner {
    display: flex;
    align-items: center;
    justify-content: center;
    max-width: 80vw;
    max-height: 60vh;
  }

  .loader-logo {
    width: clamp(220px, 50vw, 480px);
    height: auto;
    display: block;
    transform-origin: center center;
    /* Visible by default — JS sets opacity:0 ONLY if it's running, so a
       failed/slow JS attach still shows the logo rather than an empty screen */
  }

  /* Hard fallback: respect reduced-motion preference even without JS */
  @media (prefers-reduced-motion: reduce) {
    .page-loader { display: none !important; }
  }
</style>

<noscript>
  <style>
    /* If JS is disabled entirely, never show the loader at all */
    .page-loader { display: none !important; }
  </style>
</noscript>
