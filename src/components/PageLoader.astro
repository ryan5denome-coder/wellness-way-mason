---
/**
 * PageLoader — first-visit brand loader.
 *
 * Shows the real Wellness Way logo with a soft fade-in + scale + bounce,
 * then the "Do Health Differently" tagline rises in below it, holds a beat,
 * and the overlay fades out.
 *
 * Sequence (~1.4s total):
 *   1. Cream overlay paints immediately.
 *   2. Logo fades in from scale 0.7 → 1.0 with a soft outBack (700ms).
 *   3. Logo settles with a tiny scale pulse (1.0 → 1.025 → 1.0, 360ms).
 *   4. Tagline lifts in from below (420ms).
 *   5. Brief hold so the brand registers.
 *   6. Overlay fades out and unblocks the page (380ms).
 *
 * Gates:
 *   - sessionStorage: shows ONLY on first visit per browser session.
 *   - prefers-reduced-motion: skips animation, hides loader immediately.
 *   - <noscript>: hides loader if JS disabled.
 *   - 4s hard timeout: emergency fade-out so the loader never blocks forever.
 *
 * Tech: anime.js v4 (~17 KB min+gzip), loaded only in this component.
 */
---

<div id="page-loader" class="page-loader" aria-hidden="true">
  <div class="loader-stack">
    <img
      class="loader-logo"
      src="/images/brand/tww-logo.png"
      alt=""
      width="640"
      height="240"
      fetchpriority="high"
      decoding="sync"
    />
    <p class="loader-tagline">Do Health Differently.</p>
  </div>
</div>

<script>
  import { animate, createTimeline } from 'animejs';

  const KEY = 'tww-mason-loader-shown';
  const loader = document.getElementById('page-loader');
  const logo = loader?.querySelector<HTMLImageElement>('.loader-logo');
  const tagline = loader?.querySelector<HTMLParagraphElement>('.loader-tagline');

  if (loader && logo && tagline) {
    const alreadyShown = sessionStorage.getItem(KEY) === '1';
    const prefersReduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

    if (alreadyShown || prefersReduce) {
      loader.style.display = 'none';
    } else {
      sessionStorage.setItem(KEY, '1');

      // Set initial state via inline styles (paints before anime takes over)
      logo.style.opacity = '0';
      logo.style.transform = 'scale(0.7) translateY(20px)';
      tagline.style.opacity = '0';
      tagline.style.transform = 'translateY(12px)';

      const timeline = createTimeline({
        onComplete: () => {
          animate(loader, {
            opacity: 0,
            duration: 380,
            ease: 'inQuad',
            onComplete: () => { loader.style.display = 'none'; },
          });
        },
      });

      // Logo: fade in + scale up + soft bounce in place
      timeline.add(logo, {
        opacity: 1,
        scale: 1,
        translateY: 0,
        duration: 700,
        ease: 'outBack(1.2)',
      });

      // Logo settles with a tiny scale pulse
      timeline.add(logo, {
        scale: [1, 1.025, 1],
        duration: 360,
        ease: 'inOutQuad',
      });

      // Tagline rises in from below
      timeline.add(
        tagline,
        { opacity: 1, translateY: 0, duration: 420, ease: 'outQuad' },
        '-=200',
      );

      // Hold so the eye registers the brand mark + tagline before fade-out
      timeline.add({ duration: 450 });
    }
  } else if (loader) {
    loader.style.display = 'none';
  }

  // Safety net: never let the loader block the page for more than 4s
  setTimeout(() => {
    if (loader && loader.style.display !== 'none') {
      loader.style.transition = 'opacity 250ms ease';
      loader.style.opacity = '0';
      setTimeout(() => { loader.style.display = 'none'; }, 280);
    }
  }, 4000);
</script>

<style>
  .page-loader {
    position: fixed;
    inset: 0;
    z-index: 9999;
    background: var(--color-paper-soft, #fafaf9);
    display: flex;
    align-items: center;
    justify-content: center;
    pointer-events: auto;
  }

  .loader-stack {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1.5rem;
    max-width: 80vw;
    max-height: 80vh;
  }

  .loader-logo {
    width: clamp(220px, 50vw, 480px);
    height: auto;
    display: block;
    transform-origin: center center;
  }

  .loader-tagline {
    margin: 0;
    color: var(--color-brand-primary-dark, #5e8a30);
    font-family: var(--font-display, 'Lora', Georgia, serif);
    font-size: clamp(1.25rem, 3vw, 1.75rem);
    font-weight: 500;
    font-style: italic;
    letter-spacing: 0.01em;
    text-align: center;
    line-height: 1.3;
  }

  /* Hard fallback: respect reduced-motion preference even without JS */
  @media (prefers-reduced-motion: reduce) {
    .page-loader { display: none !important; }
  }
</style>

<noscript>
  <style>
    /* If JS is disabled entirely, never show the loader at all */
    .page-loader { display: none !important; }
  </style>
</noscript>
