---
/**
 * PageLoader — first-visit puzzle-piece "draw-in" loader.
 *
 * Sequence (~1.6s):
 *   1. Brand-cream overlay paints immediately (visible before JS attaches).
 *   2. Four puzzle pieces draw their outlines in via stroke animation,
 *      staggered slightly so the eye follows the pen.
 *   3. As each outline completes, the piece fills with its brand color
 *      (gray for the top row, green for the TWW piece).
 *   4. The "TWW" wordmark inside the green piece fades in last.
 *   5. The whole overlay fades out and unblocks the page.
 *
 * Gates:
 *   - sessionStorage: shows ONLY on first visit per browser session.
 *   - prefers-reduced-motion: skips animation, hides loader immediately.
 *   - <noscript>: hides loader if JS disabled.
 *   - 4s hard timeout: emergency fade-out so the loader never blocks forever.
 *
 * Tech: anime.js v4 stroke-dasharray draw, ~17 KB min+gzip, loaded only here.
 */
---

<div id="page-loader" class="page-loader" aria-hidden="true">
  <div class="loader-stack">
    <svg
      class="loader-svg"
      viewBox="0 -10 250 200"
      xmlns="http://www.w3.org/2000/svg"
      role="img"
      aria-label="The Wellness Way - Mason"
    >
    <!-- Top-left gray piece — flat top, flat left, KNOB right, flat bottom -->
    <path
      class="piece piece-gray"
      data-idx="0"
      d="M 4 4
         L 64 4
         L 64 26
         C 76 26 76 50 64 50
         L 64 76
         L 4 76 Z"
    />

    <!-- Top-mid gray piece — NOTCH left, KNOB right, KNOB bottom, flat top -->
    <path
      class="piece piece-gray"
      data-idx="1"
      d="M 64 4
         L 124 4
         L 124 26
         C 136 26 136 50 124 50
         L 124 76
         L 100 76
         C 100 88 76 88 76 76
         L 64 76
         L 64 50
         C 76 50 76 26 64 26 Z"
    />

    <!-- Top-right gray piece — NOTCH left, flat right, flat top, flat bottom -->
    <path
      class="piece piece-gray"
      data-idx="2"
      d="M 124 4
         L 184 4
         L 184 76
         L 124 76
         L 124 50
         C 136 50 136 26 124 26 Z"
    />

    <!-- Green TWW piece — NOTCH top (where top-mid's bottom knob fits), all other edges flat -->
    <path
      class="piece piece-green"
      data-idx="3"
      d="M 64 76
         L 76 76
         C 76 88 100 88 100 76
         L 124 76
         L 124 148
         L 64 148 Z"
    />

    <!-- TWW wordmark inside green piece -->
    <text class="tww-text" x="94" y="120" text-anchor="middle">TWW</text>
    </svg>

    <p class="loader-tagline">We don't guess <span class="dash">—</span> we test.</p>
  </div>
</div>

<script>
  import { animate, createTimeline } from 'animejs';

  const KEY = 'tww-mason-loader-shown';
  const loader = document.getElementById('page-loader');
  const pieces = loader?.querySelectorAll<SVGPathElement>('.piece');
  const tww = loader?.querySelector<SVGTextElement>('.tww-text');
  const tagline = loader?.querySelector<HTMLParagraphElement>('.loader-tagline');

  if (loader && pieces && pieces.length === 4 && tww && tagline) {
    const alreadyShown = sessionStorage.getItem(KEY) === '1';
    const prefersReduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

    if (alreadyShown || prefersReduce) {
      loader.style.display = 'none';
    } else {
      sessionStorage.setItem(KEY, '1');

      // Set every piece to "undrawn" state: stroke ready, fill transparent
      pieces.forEach((path) => {
        const len = path.getTotalLength();
        path.style.strokeDasharray = `${len}`;
        path.style.strokeDashoffset = `${len}`;
        path.style.fillOpacity = '0';
      });
      tww.style.opacity = '0';
      tagline.style.opacity = '0';
      tagline.style.transform = 'translateY(8px)';

      const timeline = createTimeline({
        defaults: { ease: 'inOutQuad' },
        onComplete: () => {
          animate(loader, {
            opacity: 0,
            duration: 380,
            ease: 'inQuad',
            onComplete: () => { loader.style.display = 'none'; },
          });
        },
      });

      // Pen-draws each piece outline with a slight stagger
      pieces.forEach((path, i) => {
        timeline.add(
          path,
          { strokeDashoffset: 0, duration: 700, ease: 'outQuad' },
          i * 200, // stagger 200ms between piece starts
        );
      });

      // After the last stroke finishes (i * 200 + 700 for i=3 → 1300ms),
      // fade in fills together. Then the TWW wordmark fades in.
      timeline.add(pieces, { fillOpacity: 1, duration: 320 }, 1100);
      timeline.add(tww, { opacity: 1, duration: 280, ease: 'outQuad' }, 1300);

      // Tagline lifts in from below as the closing beat
      timeline.add(
        tagline,
        { opacity: 1, translateY: 0, duration: 420, ease: 'outQuad' },
        1450,
      );

      // Hold so the completed brand mark + tagline register before fade-out
      timeline.add({ duration: 500 });
    }
  } else if (loader) {
    // SVG missing or malformed — bail out gracefully
    loader.style.display = 'none';
  }

  // Safety net: never let the loader block the page for more than 4s
  setTimeout(() => {
    if (loader && loader.style.display !== 'none') {
      loader.style.transition = 'opacity 250ms ease';
      loader.style.opacity = '0';
      setTimeout(() => { loader.style.display = 'none'; }, 280);
    }
  }, 4000);
</script>

<style>
  .page-loader {
    position: fixed;
    inset: 0;
    z-index: 9999;
    background: var(--color-paper-soft, #fafaf9);
    display: flex;
    align-items: center;
    justify-content: center;
    pointer-events: auto;
  }

  .loader-stack {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1.25rem;
  }

  .loader-svg {
    width: clamp(220px, 50vw, 440px);
    height: auto;
    display: block;
  }

  .loader-tagline {
    margin: 0;
    color: var(--color-brand-primary-dark, #5e8a30);
    font-family: var(--font-display, 'Lora', Georgia, serif);
    font-size: clamp(1.25rem, 3vw, 1.75rem);
    font-weight: 500;
    font-style: italic;
    letter-spacing: 0.01em;
    text-align: center;
    line-height: 1.3;
  }

  .loader-tagline .dash {
    color: var(--color-brand-primary, #80b741);
    font-style: normal;
    padding: 0 0.15em;
  }

  /* Puzzle piece base style — stroke draws first, then fill comes in */
  .piece {
    fill: transparent;
    stroke-width: 2.5;
    stroke-linejoin: round;
    stroke-linecap: round;
  }

  .piece-gray {
    fill: #c9c9c9;
    stroke: #8a8a8a;
  }

  .piece-green {
    fill: #80b741;
    stroke: #5e8a30;
  }

  /* TWW wordmark inside the green piece */
  .tww-text {
    fill: #ffffff;
    font-family: 'Inter', system-ui, sans-serif;
    font-weight: 800;
    font-size: 18px;
    letter-spacing: 0.04em;
  }

  /* Hard fallback: respect reduced-motion preference even without JS */
  @media (prefers-reduced-motion: reduce) {
    .page-loader { display: none !important; }
  }
</style>

<noscript>
  <style>
    /* If JS is disabled entirely, never show the loader at all */
    .page-loader { display: none !important; }
  </style>
</noscript>
