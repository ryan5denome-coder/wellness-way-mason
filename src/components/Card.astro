---
/**
 * Card — generic content card.
 * Soft UI Evolution treatment: ambient (less boxed), subtle border or no border,
 * lift on hover, refined typography.
 *
 * `image` accepts either:
 *   - a STRING URL (remote Wix CDN images for blog posts — passed through to <img>)
 *   - an IMPORTED ImageMetadata (local src/assets/* — rendered through <Image> for
 *     automatic WebP + responsive srcset).
 */
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';

interface Props {
  href?: string;
  image?: string | ImageMetadata;
  imageAlt?: string;
  title?: string;
  eyebrow?: string;
  variant?: 'default' | 'flat' | 'feature' | 'ambient';
  ariaLabel?: string;
}

const {
  href,
  image,
  imageAlt = '',
  title,
  eyebrow,
  variant = 'ambient',
  ariaLabel,
} = Astro.props;

const Tag = href ? 'a' : 'article';
const classes = ['card', `card-${variant}`, href ? 'card-link' : ''].filter(Boolean).join(' ');
const isLocalAsset = image && typeof image !== 'string';
---

<Tag class={classes} href={href} aria-label={ariaLabel}>
  {image && (
    <div class="card-image">
      {isLocalAsset ? (
        <Image
          src={image}
          alt={imageAlt}
          widths={[400, 600, 800]}
          sizes="(min-width: 1024px) 380px, (min-width: 768px) 50vw, 100vw"
          loading="lazy"
          quality={82}
        />
      ) : (
        <img src={image as string} alt={imageAlt} loading="lazy" decoding="async" />
      )}
    </div>
  )}
  <div class="card-body">
    {eyebrow && <p class="card-eyebrow">{eyebrow}</p>}
    {title && <h3 class="card-title">{title}</h3>}
    <slot />
    {(Astro.slots.has('footer')) && (
      <div class="card-footer">
        <slot name="footer" />
      </div>
    )}
  </div>
</Tag>

<style>
  .card {
    display: flex;
    flex-direction: column;
    background: var(--color-paper);
    border-radius: var(--radius-lg);
    overflow: hidden;
    color: var(--color-ink);
    text-decoration: none;
    transition: transform var(--duration-normal) var(--ease-soft),
                box-shadow var(--duration-normal) var(--ease-soft),
                border-color var(--duration-normal) var(--ease-soft);
  }

  /* Soft UI Evolution variants */
  .card-default {
    box-shadow: var(--shadow-card);
    border: 1px solid var(--color-line-soft);
  }
  .card-ambient {
    box-shadow: none;
    border: 1px solid var(--color-line);
    background: var(--color-paper);
  }
  .card-flat {
    box-shadow: none;
    border: 1px solid var(--color-line);
    background: var(--color-paper-soft);
  }
  .card-feature {
    box-shadow: var(--shadow-card);
    border: 1px solid var(--color-brand-primary-light);
    background: var(--color-paper);
  }

  .card-link:hover, .card-link:focus-visible {
    transform: translateY(-3px);
    box-shadow: var(--shadow-card-hover);
    border-color: var(--color-brand-primary-light);
    outline: none;
  }
  .card-link:focus-visible {
    box-shadow: var(--shadow-focus), var(--shadow-card-hover);
  }

  .card-image {
    aspect-ratio: 4 / 3;
    overflow: hidden;
    background: var(--color-paper-soft);
  }
  .card-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform var(--duration-slow) var(--ease-soft);
  }
  .card-link:hover .card-image img {
    transform: scale(1.04);
  }

  .card-body {
    padding: 1.75rem 1.75rem 1.75rem;
    display: flex;
    flex-direction: column;
    gap: 0.85rem;
    flex: 1;
  }
  .card-eyebrow {
    font-size: var(--text-xs);
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--color-mute);
    margin: 0;
    font-weight: 500;
  }
  .card-title {
    font-family: var(--font-display);
    font-size: var(--text-xl);
    font-weight: 500;
    line-height: 1.3;
    margin: 0;
    color: var(--color-ink-strong);
    letter-spacing: -0.01em;
  }
  .card-footer {
    margin-top: auto;
    padding-top: 1.25rem;
    border-top: 1px solid var(--color-line-soft);
    color: var(--color-ink-muted);
    font-size: var(--text-sm);
  }
</style>
