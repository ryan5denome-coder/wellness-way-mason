---
import { clinic } from '../lib/site';
import HoursTable from './HoursTable.astro';

const secondaryNav = [
  { label: 'Our Approach', href: '/our-approach' },
  { label: 'Pricing', href: '/pricing' },
  { label: 'Find My Condition', href: '/find-my-condition' },
  { label: 'Service Area', href: '/locations' },
  { label: 'Events', href: '/events' },
  { label: 'Privacy Policy', href: '/privacy-policy' },
];
---

<footer class="site-footer" role="contentinfo">
  <div class="footer-inner">
    <div class="footer-block footer-nap">
      <p class="footer-brand">
        <svg
          class="brand-mark"
          width="14"
          height="14"
          viewBox="0 0 24 24"
          fill="currentColor"
          aria-hidden="true"
          xmlns="http://www.w3.org/2000/svg"
        >
          <path d="M20.5 11H19V7c0-1.1-.9-2-2-2h-4V3.5C13 2.12 11.88 1 10.5 1S8 2.12 8 3.5V5H4c-1.1 0-1.99.9-1.99 2v3.8H3.5c1.49 0 2.7 1.21 2.7 2.7s-1.21 2.7-2.7 2.7H2V20c0 1.1.9 2 2 2h3.8v-1.5c0-1.49 1.21-2.7 2.7-2.7s2.7 1.21 2.7 2.7V22H17c1.1 0 2-.9 2-2v-4h1.5c1.38 0 2.5-1.12 2.5-2.5S21.88 11 20.5 11z"/>
        </svg>
        {clinic.brandName}
      </p>
      <p class="footer-tagline">{clinic.tagline}</p>
      <address>
        {clinic.address.streetAddress}<br />
        {clinic.address.addressLocality}, {clinic.address.addressRegion} {clinic.address.postalCode}
      </address>
      <p class="contact-line">
        <a href={`tel:${clinic.phoneTel}`}>{clinic.phone}</a>
      </p>
      <p class="contact-line">
        <a href={`mailto:${clinic.email}`}>{clinic.email}</a>
      </p>
    </div>

    <div class="footer-block footer-hours">
      <h4>Hours</h4>
      <HoursTable />
    </div>

    <div class="footer-block footer-nav">
      <h4>More</h4>
      <nav aria-label="Footer">
        <ul>
          {secondaryNav.map((item) => (
            <li><a href={item.href}>{item.label}</a></li>
          ))}
        </ul>
      </nav>
    </div>
  </div>

  <div class="footer-base">
    <div class="footer-base-inner">
      <p class="footer-copy">
        © {new Date().getFullYear()} {clinic.legalName}. All rights reserved.
      </p>
      <div class="footer-social">
        {clinic.social.facebook && (
          <a
            href={clinic.social.facebook}
            target="_blank"
            rel="noopener noreferrer"
            aria-label="Follow The Wellness Way - Mason on Facebook"
          >
            <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true" focusable="false">
              <path d="M22 12c0-5.523-4.477-10-10-10S2 6.477 2 12c0 4.99 3.657 9.128 8.438 9.879V14.89H7.898V12h2.54V9.797c0-2.506 1.492-3.89 3.777-3.89 1.094 0 2.238.195 2.238.195v2.46h-1.26c-1.243 0-1.63.771-1.63 1.562V12h2.773l-.443 2.89h-2.33V21.88C18.343 21.128 22 16.99 22 12Z"/>
            </svg>
            <span class="visually-hidden">Facebook</span>
          </a>
        )}
        {clinic.social.instagram && (
          <a
            href={clinic.social.instagram}
            target="_blank"
            rel="noopener noreferrer"
            aria-label="Follow The Wellness Way - Mason on Instagram"
          >
            <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true" focusable="false">
              <path d="M12 2.163c3.204 0 3.584.012 4.85.07 1.366.062 2.633.336 3.608 1.311.975.975 1.249 2.242 1.311 3.608.058 1.266.069 1.646.069 4.85s-.011 3.584-.069 4.85c-.062 1.366-.336 2.633-1.311 3.608-.975.975-2.242 1.249-3.608 1.311-1.266.058-1.646.069-4.85.069s-3.584-.011-4.85-.069c-1.366-.062-2.633-.336-3.608-1.311-.975-.975-1.249-2.242-1.311-3.608C2.175 15.747 2.163 15.367 2.163 12s.012-3.584.07-4.85c.062-1.366.336-2.633 1.311-3.608.975-.975 2.242-1.249 3.608-1.311 1.266-.058 1.646-.069 4.85-.069M12 0C8.741 0 8.332.014 7.052.072 5.776.13 4.904.333 4.14.63a5.918 5.918 0 0 0-2.14 1.392A5.918 5.918 0 0 0 .63 4.14C.333 4.904.131 5.776.072 7.052.014 8.332 0 8.741 0 12c0 3.259.014 3.668.072 4.948.058 1.276.261 2.148.558 2.913a5.918 5.918 0 0 0 1.392 2.14 5.918 5.918 0 0 0 2.14 1.392c.764.297 1.636.5 2.912.558C8.332 23.986 8.741 24 12 24s3.668-.014 4.948-.072c1.276-.058 2.148-.261 2.913-.558a5.918 5.918 0 0 0 2.14-1.392 5.918 5.918 0 0 0 1.392-2.14c.297-.764.5-1.636.558-2.912C23.986 15.668 24 15.259 24 12s-.014-3.668-.072-4.948c-.058-1.276-.261-2.148-.558-2.913a5.918 5.918 0 0 0-1.392-2.14A5.918 5.918 0 0 0 19.86.63C19.096.333 18.224.131 16.948.072 15.668.014 15.259 0 12 0Zm0 5.838a6.162 6.162 0 1 0 0 12.324 6.162 6.162 0 0 0 0-12.324ZM12 16a4 4 0 1 1 0-8 4 4 0 0 1 0 8Zm6.406-11.845a1.44 1.44 0 1 0 0 2.881 1.44 1.44 0 0 0 0-2.881Z"/>
            </svg>
            <span class="visually-hidden">Instagram</span>
          </a>
        )}
        {clinic.social.youtube && (
          <a
            href={clinic.social.youtube}
            target="_blank"
            rel="noopener noreferrer"
            aria-label="Watch The Wellness Way - Mason on YouTube"
          >
            <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true" focusable="false">
              <path d="M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 0 0 2.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814ZM9.545 15.568V8.432L15.818 12l-6.273 3.568Z"/>
            </svg>
            <span class="visually-hidden">YouTube</span>
          </a>
        )}
        {clinic.social.linkedin && (
          <a
            href={clinic.social.linkedin}
            target="_blank"
            rel="noopener noreferrer"
            aria-label="Dr. Ryan DeNome on LinkedIn"
          >
            <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true" focusable="false">
              <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286ZM5.337 7.433a2.062 2.062 0 0 1-2.063-2.065 2.063 2.063 0 1 1 2.063 2.065Zm1.782 13.019H3.555V9h3.564v11.452ZM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003Z"/>
            </svg>
            <span class="visually-hidden">LinkedIn</span>
          </a>
        )}
      </div>
    </div>
  </div>
</footer>

<style>
  .site-footer {
    background: var(--color-ink-strong);
    color: var(--color-paper);
    margin-top: 6rem;
    border-top: 4px solid var(--color-brand-primary);
  }
  .site-footer :global(a) {
    color: var(--color-paper);
    opacity: 0.85;
  }
  .site-footer :global(a:hover) {
    color: var(--color-brand-primary);
    opacity: 1;
  }
  .footer-inner {
    max-width: var(--container-default);
    margin: 0 auto;
    padding: 4rem 1.5rem 3rem;
    display: grid;
    gap: 2.5rem;
  }
  .footer-block h4 {
    font-family: var(--font-body);
    font-size: var(--text-xs);
    text-transform: uppercase;
    letter-spacing: 0.18em;
    margin: 0 0 1.25rem;
    color: var(--color-paper);
    opacity: 0.6;
    font-weight: 600;
  }
  .footer-brand {
    font-family: var(--font-display);
    font-size: var(--text-xl);
    font-weight: 500;
    margin: 0 0 0.75rem;
    color: var(--color-paper);
    display: flex;
    align-items: center;
    gap: 0.6rem;
    letter-spacing: -0.005em;
  }
  .brand-mark {
    display: inline-block;
    width: 14px;
    height: 14px;
    color: var(--color-brand-primary);
    flex-shrink: 0;
  }
  .footer-tagline {
    font-style: italic;
    color: var(--color-paper);
    opacity: 0.75;
    margin: 0 0 1.5rem;
    font-size: var(--text-sm);
    font-family: var(--font-display);
  }
  address {
    font-style: normal;
    margin-bottom: 1rem;
    line-height: 1.7;
    color: var(--color-paper);
    opacity: 0.85;
  }
  .contact-line { margin: 0.25rem 0; font-size: var(--text-sm); }

  /* Hours table contrast on dark */
  .footer-hours :global(.hours-row) { border-bottom-color: rgba(255,255,255,0.1); }
  .footer-hours :global(.hours-row dt) { color: var(--color-paper); opacity: 0.95; }
  .footer-hours :global(.hours-row dd) { color: var(--color-paper); opacity: 0.7; }
  .footer-hours :global(.is-today) {
    background: rgba(128, 183, 65, 0.18);
  }
  .footer-hours :global(.is-today dt),
  .footer-hours :global(.is-today dd) {
    color: var(--color-paper);
    opacity: 1;
  }

  .footer-nav ul {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 0.65rem;
  }
  .footer-nav a {
    text-decoration: none;
    font-size: var(--text-sm);
  }

  .footer-base {
    border-top: 1px solid rgba(255,255,255,0.1);
  }
  .footer-base-inner {
    max-width: var(--container-default);
    margin: 0 auto;
    padding: 1.5rem 1.5rem;
    display: flex;
    justify-content: space-between;
    align-items: center;
    flex-wrap: wrap;
    gap: 1rem;
  }
  .footer-copy {
    margin: 0;
    color: var(--color-paper);
    opacity: 0.55;
    font-size: var(--text-xs);
  }
  .footer-social {
    display: flex;
    gap: 1rem;
    align-items: center;
  }
  .footer-social a {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 2.25rem;
    height: 2.25rem;
    border-radius: 50%;
    background: rgba(255, 255, 255, 0.08);
    text-decoration: none;
    transition: background 0.18s ease, color 0.18s ease, transform 0.18s ease;
  }
  .footer-social a:hover {
    background: var(--color-brand-primary);
    color: var(--color-ink-strong);
    opacity: 1;
    transform: translateY(-1px);
  }
  .footer-social svg {
    width: 1.15rem;
    height: 1.15rem;
    display: block;
  }
  .visually-hidden {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }

  @media (min-width: 768px) {
    .footer-inner {
      grid-template-columns: 1.6fr 1fr 1fr;
      gap: 3.5rem;
      padding: 5rem 2rem 4rem;
    }
  }
</style>
